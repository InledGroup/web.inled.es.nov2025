---
import Footer from '../components/Footer.astro';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import { getLangFromLocals } from '../i18n/utils';
import { getFeaturedItems } from '../config/featured';
import { apps } from '../config/apps';
import { saas } from '../config/saas';

const lang = getLangFromLocals(Astro.locals);

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Inled Group", image = "https://hosted.inled.es/hero-bg.jpg" } = Astro.props;

const featuredItems = getFeaturedItems();

const currentPath = Astro.url.pathname;
const allProducts = [...saas, ...apps];
const isArchivedPage = allProducts.some(p => p.archive && (
  currentPath === p.link || 
  currentPath === p.link + '/' ||
  p.link === currentPath ||
  (p.id && currentPath.includes('/apps/' + p.id))
));

// Generar navegación dinámica para SEO (Sitelinks)
const featuredApps = featuredItems
  .filter(item => item.type === 'app')
  .slice(0, 4);

const featuredSaas = featuredItems
  .filter(item => item.type === 'saas')
  .slice(0, 4);

const siteNavigation = [
  ...featuredSaas.map(s => ({
    name: s.name,
    url: s.link.startsWith('http') ? s.link : `https://inled.es${s.link}`
  })),
  ...featuredApps.map(a => ({
    name: a.name,
    url: `https://inled.es${a.link}`
  })),
  { name: lang === 'es' ? 'Contacto' : 'Contact', url: 'https://inled.es/contacto' }
].slice(0, 8);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://inled.es/#organization",
      "name": "Inled Group",
      "url": "https://inled.es",
      "logo": {
        "@type": "ImageObject",
        "url": "https://hosted.inled.es/INLED_simple-removebg-preview.png"
      },
      "sameAs": [
        "https://github.com/InledGroup",
        "https://www.youtube.com/@inledgroup"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://inled.es/#website",
      "url": "https://inled.es",
      "name": "Inled Group",
      "publisher": { "@id": "https://inled.es/#organization" }
    },
    {
      "@type": "ItemList",
      "name": "Main Projects",
      "itemListElement": siteNavigation.map((item, index) => ({
        "@type": "SiteNavigationElement",
        "position": index + 1,
        "name": item.name,
        "url": item.url
      }))
    }
  ]
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <link rel="icon" href="https://hosted.inled.es/cropped-INLED_simple-removebg-preview.png" type="image/x-icon">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap" rel="stylesheet">
    <script src={import.meta.env.BASE_URL + "/upload/https://kit.fontawesome.com/4bf0ac964c.js"} crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,1,0" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="sitemap" href="/sitemap.xml" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "rkxkde17af");
        </script>

  </head>
  <body class={isArchivedPage ? "archive-active-body" : ""}>
    {isArchivedPage && (
      <div class="archive-overlay-banner">
        <div class="archive-overlay-content">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;"><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
          <span>
            {lang === 'es' 
              ? 'Este proyecto está archivado y no se mantiene activamente por ahora.' 
              : 'This project is archived and is not actively maintained for now.'}
          </span>
        </div>
      </div>
    )}
    <slot />
    <Footer />
    <script>
      import Lenis from 'lenis';

      // Inicializar Lenis smooth scroll
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: true,
        wheelMultiplier: 1,
        touchMultiplier: 2,
        infinite: false,
      });

      (window as any).lenis = lenis;

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    overflow-x: hidden;
    background: #000 url('https://hosted.inled.es/better.inled.png') no-repeat center center fixed;
    background-size: cover;
    color: #fff;
  }

  html {
    scroll-behavior: auto; /* Desactivar para que Lenis tome control */
  }

  html.lenis {
    height: auto;
  }

  .lenis.lenis-smooth {
    scroll-behavior: auto;
  }

  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }

  .lenis.lenis-stopped {
    overflow: hidden;
  }

  .lenis.lenis-scrolling iframe {
    pointer-events: none;
  }

  .archive-overlay-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(239, 68, 68, 0.1);
    border-bottom: 1px solid rgba(239, 68, 68, 0.2);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #f87171;
    z-index: 10000;
    padding: 0.6rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .archive-overlay-content {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  body.archive-active-body .floating-header-container {
    top: 3.5rem !important;
  }
</style>
