---
import { getLangFromLocals, useTranslations, useTranslatedPath } from '../i18n/utils';
import { getFeaturedItems } from '../config/featured';
import SocialLinks from './SocialLinks.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
const translatePath = useTranslatedPath();

const featuredItems = getFeaturedItems();

// Proyectos destacados para el footer (máximo 6 en total)
const featuredApps = featuredItems
  .filter(item => item.type === 'app')
  .slice(0, 3);

const featuredSaas = featuredItems
  .filter(item => item.type === 'saas')
  .slice(0, 3);
---

<footer>
  <div class="footer-content">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="https://hosted.inled.es/inled-logo-full.png" alt="INLED Group">
        </div>
        <p class="footer-tagline">{t('footer.description')}</p>
      </div>

      <div class="footer-nav-grid">
        <div class="footer-column">
          <h4>{t('grid.saas')}</h4>
          <nav>
            {featuredSaas.map(s => (
              <a href={s.link} target={s.link.startsWith('http') ? "_blank" : "_self"}>{s.name}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column">
          <h4>{t('grid.apps')}</h4>
          <nav>
            {featuredApps.map(a => (
              <a href={translatePath(a.link)}>{a.name}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column">
          <h4>{t('footer.legaltitle')}</h4>
          <nav>
            <a href={translatePath('/privacy-policy')}>{t('footer.privacy')}</a>
            <a href={translatePath('/cookie-policy')}>{t('footer.cookies')}</a>
            <a href={translatePath('/aviso-legal')}>{t('footer.legal')}</a>
            <a href={translatePath('/eu-ai-act')}>{t('footer.aiact')}</a>
            <a href={translatePath('/contacto')}>{t('nav.contact')}</a>
          </nav>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-social">
        <SocialLinks />
      </div>

      <div class="footer-copyright">
        <p>Inled Group es una marca registrada. Todos los proyectos, a excepción de forks, están licenciados bajo <a href="https://license.inled.es">MIT-INLED</a></p>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    background: rgba(15, 15, 20, 0.4);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 4rem 2rem 2rem;
    color: white;
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.3);
  }

  /* Añadimos un pequeño gradiente interno para simular el reflejo del cristal */
  footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 3fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-logo img {
    height: 32px;
    width: auto;
  }

  .footer-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 300px;
  }

  .footer-nav-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-column h4 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
  }

  .footer-column nav {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .footer-column nav a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .footer-column nav a:hover {
    color: white;
    transform: translateX(4px);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-social {
    display: flex;
    gap: 1rem;
  }

  .footer-copyright p {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8rem;
  }

  @media (max-width: 968px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-brand {
      align-items: center;
      text-align: center;
    }

    .footer-tagline {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .footer-nav-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .footer-column nav a:hover {
      transform: none;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }
  }
</style>
