---
import { getLangFromLocals, useTranslations, useTranslatedPath } from '../i18n/utils';
import { apps } from '../config/apps';
import { saas } from '../config/saas';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
const translatePath = useTranslatedPath();

// Proyectos destacados para el footer (máximo 6 en total)
const featuredApps = apps
  .filter(app => app.isFeatured)
  .sort((a, b) => (Number(a.isFeatured) || 99) - (Number(b.isFeatured) || 99))
  .slice(0, 3);

const featuredSaas = saas
  .filter(s => s.isFeatured)
  .sort((a, b) => (Number(a.isFeatured) || 99) - (Number(b.isFeatured) || 99))
  .slice(0, 3);
---

<footer>
  <div class="footer-content">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="https://hosted.inled.es/inled-logo-full.png" alt="INLED Group">
        </div>
        <p class="footer-tagline">{t('footer.description')}</p>
      </div>

      <div class="footer-nav-grid">
        <div class="footer-column">
          <h4>{t('grid.saas')}</h4>
          <nav>
            {featuredSaas.map(s => (
              <a href={s.link} target={s.link.startsWith('http') ? "_blank" : "_self"}>{s.name}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column">
          <h4>{t('grid.apps')}</h4>
          <nav>
            {featuredApps.map(a => (
              <a href={translatePath(a.link)}>{a.name}</a>
            ))}
          </nav>
        </div>
        <div class="footer-column">
          <h4>{t('footer.projects')}</h4>
          <nav>
            <a href={translatePath('/privacy-policy')}>{t('footer.privacy')}</a>
            <a href={translatePath('/cookie-policy')}>{t('footer.cookies')}</a>
            <a href={translatePath('/contacto')}>{t('nav.contact')}</a>
          </nav>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-social">
        <a href="https://github.com/InledGroup" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.477 2 2 6.484 2 12.012c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.892 1.53 2.341 1.088 2.91.832.091-.646.35-1.088.636-1.339-2.221-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.338 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.847-2.337 4.695-4.566 4.944.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.749 0 .268.18.579.688.481C19.138 20.174 22 16.426 22 12.012 22 6.484 17.523 2 12 2z"/></svg>
        </a>
        <a href="https://www.youtube.com/@inledgroup" target="_blank" rel="noopener" aria-label="YouTube">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M21.8 8.001s-.2-1.429-.8-2.057c-.763-.8-1.617-.803-2.011-.849C16.2 5 12 5 12 5h-.01s-4.2 0-7 .095c-.394.046-1.248.049-2.011.849-.6.628-.8 2.057-.8 2.057S2 9.571 2 11.143v1.714c0 1.572.2 3.142.2 3.142s.2 1.429.8 2.057c.763.8 1.767.775 2.221.86C7.8 19 12 19 12 19s4.2 0 7-.095c.394-.046 1.248-.049 2.011-.849.6-.628.8-2.057.8-2.057s.2-1.57.2-3.142v-1.714c0-1.572-.2-3.142-.2-3.142zM10 15.5v-7l6 3.5-6 3.5z"/></svg>
        </a>
        <a href="https://mastodon.social/@inled" target="_blank" rel="noopener" aria-label="Mastodon">
          <i class="fa-brands fa-mastodon"></i>
        </a>
        <a href="https://sourceforge.net/u/inledgroup/profile/" target="_blank" rel="noopener" aria-label="SourceForge">
          <img src="https://a.fsdn.com/con/img/sandiego/logo-180x180.png" width="24" height="24" alt="SourceForge Logo" />
        </a>
      </div>

      <div class="footer-copyright">
        <p>Inled Group es una marca registrada. Todos los proyectos, a excepción de forks, están licenciados bajo <a href="https://license.inled.es">MIT-INLED</a></p>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    background: rgba(15, 15, 20, 0.4);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 4rem 2rem 2rem;
    color: white;
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.3);
  }

  /* Añadimos un pequeño gradiente interno para simular el reflejo del cristal */
  footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 3fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-logo img {
    height: 32px;
    width: auto;
  }

  .footer-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 300px;
  }

  .footer-nav-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-column h4 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
  }

  .footer-column nav {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .footer-column nav a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .footer-column nav a:hover {
    color: white;
    transform: translateX(4px);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-social {
    display: flex;
    gap: 1rem;
  }

  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-social a:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
    transform: translateY(-3px);
  }

  .footer-social svg,
  .footer-social i,
  .footer-social img {
    width: 18px;
    height: 18px;
    object-fit: contain;
  }

  .footer-copyright p {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8rem;
  }

  @media (max-width: 968px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .footer-brand {
      align-items: center;
      text-align: center;
    }

    .footer-tagline {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .footer-nav-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .footer-column nav a:hover {
      transform: none;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }
  }
</style>
