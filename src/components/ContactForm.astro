---
import { getLangFromLocals, useTranslations } from '../i18n/utils';

interface Props {
  showBackground?: boolean;
}

const { showBackground = true } = Astro.props;

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
---

<section class={`contact-full-width ${showBackground ? 'with-bg' : 'transparent'}`}>
  <div class="contact-inner-container">
    <div class="form-header">
      <h2 class="translatable">{t('contact.title')}</h2>
      <p class="form-description translatable">{t('contact.description')}</p>
    </div>

    <form action="https://mailform.inled.es/send.php" method="POST" class="contact-form">
      <div class="form-grid">
        <div class="form-group">
          <label for="name" class="entry__label">{t('contact.name')}</label>
          <input type="text" name="name" id="name" class="input" placeholder="Tu nombre" />
        </div>

        <div class="form-group">
          <label for="subject" class="entry__label">{t('contact.subject')}</label>
          <input type="text" name="subject" id="subject" class="input" placeholder="Asunto" required />
        </div>
      </div>

      <div class="form-group">
        <label for="message" class="entry__label">{t('contact.message')}</label>
        <textarea name="message" id="message" class="input textarea" rows="5" placeholder="Cuéntanos..." required></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="cta-button">
          {t('contact.button')}
        </button>
      </div>
    </form>
  </div>
</section>

<style>
  .contact-full-width {
    width: 100%;
    padding: 6rem 1.5rem;
    margin: 0;
    position: relative;
    z-index: 10;
    transition: all 0.3s ease;
  }

  .contact-full-width.with-bg {
    background: rgba(10, 10, 12, 0.7);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .contact-full-width.transparent {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border: none;
    padding-top: 2rem;
  }

  .contact-inner-container {
    max-width: 800px; /* Reducimos el ancho para que no se vea tan estirado */
    margin: 0 auto;
  }

  .form-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .form-header h2 {
    margin: 0;
    font-size: 3rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
  }

  .form-description {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    max-width: 550px;
    margin: 0 auto;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .entry__label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 800;
    margin-left: 0.2rem;
  }

  .input {
    width: 100%;
    padding: 1.2rem 1.5rem;
    background: rgba(255, 255, 255, 0.05); /* Más visible */
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 14px;
    color: #fff;
    font-size: 1rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-sizing: border-box;
  }

  .input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.1);
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.2);
  }

  .textarea {
    resize: vertical;
    min-height: 160px;
  }

  .form-actions {
    margin-top: 1.5rem;
  }

  .cta-button {
    width: 100%;
    background: #fff;
    color: #000;
    border: none;
    padding: 1.4rem;
    border-radius: 100px;
    font-weight: 900;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .cta-button:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 40px rgba(255, 255, 255, 0.2);
    background: #f0f0f0;
  }

  @media (max-width: 768px) {
    .contact-full-width {
      padding: 4rem 1.2rem;
    }
    
    .form-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .form-header h2 {
      font-size: 2.2rem;
    }

    .form-description {
      font-size: 1rem;
    }

    .contact-form {
      gap: 1.5rem;
    }
  }
</style>
