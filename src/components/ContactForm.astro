---
import { getLangFromLocals, useTranslations } from '../i18n/utils';

interface Props {
  showBackground?: boolean;
}

const { showBackground = true } = Astro.props;
const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
---

<section class={`contact-full-width ${showBackground ? 'with-bg' : 'transparent'}`}>
  <div class="contact-inner-container">
    <div class="form-header">
      <h2 class="translatable">{t('contact.title')}</h2>
      <p class="form-description translatable">{t('contact.description')}</p>
    </div>

    <div class="iframe-container">
      {/* 
          Usamos la ruta local /mailform-embed que actúa como proxy.
          Esto soluciona los problemas de Turnstile al mantener el origen inled.es
      */}
      <iframe
        id="contact-iframe"
        title="Formulario de contacto"
        src="/mailform-embed"
        frameborder="0"
        width="100%"
        height="750px"
        allowtransparency="true"
        loading="lazy"
        style="background: transparent; border: none;"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .contact-full-width {
    width: 100%;
    padding: 6rem 1.5rem;
    margin: 0;
    position: relative;
    z-index: 10;
  }

  .contact-full-width.with-bg {
    background: rgba(15, 15, 20, 0.5);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .contact-full-width.transparent {
    background: transparent;
    backdrop-filter: none;
    border: none;
  }

  .contact-inner-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .form-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .form-header h2 {
    margin: 0;
    font-size: 3rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
  }

  .form-description {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    max-width: 550px;
    margin: 0 auto;
  }

  .iframe-container {
    width: 100%;
    display: flex;
    justify-content: center;
    /* Efecto de cristal para el contenedor del iframe si es necesario */
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 32px;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .contact-full-width { padding: 4rem 1rem; }
    .form-header h2 { font-size: 2.2rem; }
    #contact-iframe { height: 850px; }
  }
</style>

