---
import { getLangFromLocals, useTranslations } from '../i18n/utils';
import { saas } from '../config/saas';
import { apps } from '../config/apps';

interface Props {
  ids: string[];
  badge?: string;
  title?: string;
  subtitle?: string;
}

const { ids, badge, title, subtitle } = Astro.props;

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const allProducts = [...saas, ...apps];
const products = ids.map(id => allProducts.find(p => p.id === id)).filter(Boolean);

const hasMany = products.length > 4;
const hasMedium = products.length === 4;
---

<section class="saas-showcase">
  <div class="showcase-inner">
    <div class="showcase-header">
      {title && <h2 class="showcase-title">{title}</h2>}
      {subtitle && <p class="showcase-subtitle">{subtitle}</p>}
    </div>

    <div class:list={["cards-row", { "has-many": hasMany, "has-medium": hasMedium }]}>
      {products.map(p => (
        <a href={p.link} class="product-card">
          <div class="card-icon">
            <img src={p.icon} alt={p.name} loading="lazy" />
          </div>
          <h3 class="card-name">{p.name}</h3>
          <p class="card-desc">{p.description[lang]}</p>
        </a>
      ))}
    </div>

    <div class="sec-progress">
      <div class="sec-progress-bar">
        <div class="sec-progress-fill"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .saas-showcase {
    min-width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 4rem;
    flex-shrink: 0;
    position: relative;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    background: rgba(0, 0, 0, 0.4);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    border-left: 1px solid rgba(255, 255, 255, 0.04);
  }

  .showcase-inner {
    width: 100%;
    max-width: 1400px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    height: 100%;
    justify-content: center;
    padding: 2rem 0;
  }

  .showcase-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .badge {
    display: inline-block;
    width: fit-content;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .showcase-title {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0;
  }

  .showcase-subtitle {
    font-size: clamp(1rem, 1.3vw, 1.25rem);
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    max-width: 720px;
    margin: 0;
  }

  .cards-row {
    display: flex;
    gap: 2rem;
    flex-wrap: nowrap;
    overflow-x: auto;
    padding: 1rem 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
    align-items: stretch;
    min-height: 0;
  }

  .cards-row::-webkit-scrollbar {
    display: none;
  }

  .product-card {
    flex: 1;
    min-width: 320px;
    max-width: 400px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: none;
    position: relative;
    overflow: hidden;
  }

  .product-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px);
  }

  .card-icon {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .card-name {
    font-size: 1.4rem;
    font-weight: 800;
    color: #fff;
    margin: 0;
    line-height: 1.25;
  }

  .card-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  /* Ajustes dinámicos si hay más de 4 tarjetas */
  .cards-row.has-many {
    gap: 1.25rem;
  }
  .cards-row.has-many .product-card {
    min-width: 220px;
    max-width: 250px;
    padding: 1.75rem 1.25rem;
    gap: 1rem;
  }
  .cards-row.has-many .card-icon {
    width: 44px;
    height: 44px;
  }
  .cards-row.has-many .card-name {
    font-size: 1.15rem;
  }
  .cards-row.has-many .card-desc {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Ajuste intermedio si hay exactamente 4 tarjetas */
  .cards-row.has-medium {
    gap: 1.5rem;
  }
  .cards-row.has-medium .product-card {
    min-width: 260px;
    max-width: 300px;
    padding: 2rem 1.5rem;
  }

  .sec-progress {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }

  .sec-progress-bar {
    width: 200px;
    height: 3px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 1px;
    overflow: hidden;
  }

  .sec-progress-fill {
    height: 100%;
    background: #ffffff;
    width: 0%;
  }

  @media (max-width: 1024px), (orientation: portrait) {
    .saas-showcase {
      min-width: 0;
      width: 100%;
      height: auto;
      padding: 5rem 1.5rem;
      border-left: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .showcase-inner {
      height: auto;
      padding: 0;
      gap: 2rem;
    }

    .cards-row {
      flex-direction: column;
      overflow-x: visible;
      gap: 1.25rem;
    }

    .cards-row.has-many .product-card,
    .cards-row.has-medium .product-card,
    .product-card {
      min-width: 0 !important;
      max-width: 100% !important;
      width: 100%;
      flex: 1 1 auto !important;
      padding: 2rem 1.5rem;
      gap: 1rem;
    }

    .cards-row.has-many .card-icon,
    .cards-row.has-medium .card-icon,
    .card-icon {
      width: 48px;
      height: 48px;
    }

    .cards-row.has-many .card-name,
    .cards-row.has-medium .card-name,
    .card-name {
      font-size: 1.25rem;
    }

    .cards-row.has-many .card-desc,
    .cards-row.has-medium .card-desc,
    .card-desc {
      font-size: 0.95rem;
      line-height: 1.5;
    }

    .sec-progress {
      display: none !important;
    }
  }

  @media (max-width: 768px) {
    .saas-showcase {
      padding: 4rem 1rem;
    }
  }
</style>
