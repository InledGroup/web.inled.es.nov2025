---
import { getLangFromLocals, useTranslations } from '../i18n/utils';
import { saas } from '../config/saas';
import { apps } from '../config/apps';

interface Props {
  ids: string[];
  reversed?: boolean;
  badge?: string;
  title?: string;
}

const { ids, reversed = false, badge, title } = Astro.props;

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

// Combine both sources and filter by provided IDs
const allProducts = [...saas, ...apps];
const products = ids.map(id => allProducts.find(p => p.id === id)).filter(Boolean);

const showcaseProducts = products.map(p => {
  return { ...p };
});
---

<section class={`saas-showcase ${reversed ? 'reversed' : ''}`}>
  <div class="container">
    <div class="showcase-grid">
      <!-- Visual Column -->
      <div class="showcase-visual">
        <div class="visual-glass">
          {showcaseProducts.map((p, index) => (
            <div class={`screenshot-placeholder ${index === 0 ? 'active' : ''}`} data-id={p.id}>
              <div class="placeholder-content">
                <img src={p.icon} alt="" class="placeholder-icon" />
                <div class="placeholder-text">
                  <span>SCREENSHOT PLACEHOLDER</span>
                  <p>{p.name}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="visual-controls">
          <div class="progress-bar"><div class="progress-fill"></div></div>
          <div class="dots-nav">
             {showcaseProducts.map((_, i) => <span class={`dot ${i === 0 ? 'active' : ''}`} data-index={i}></span>)}
          </div>
        </div>
      </div>

      <!-- Content Column -->
      <div class="showcase-content">
        <div class="content-header">
            {badge && <span class="badge">{badge}</span>}
            {title && <h2>{title}</h2>}
        </div>

        <div class="product-list">
          {showcaseProducts.map((p, index) => (
            <div class={`product-item ${index === 0 ? 'active' : ''}`} data-id={p.id} data-index={index}>
              <div class="product-icon-wrapper">
                <img src={p.icon} alt={p.name} />
              </div>
              <div class="product-info">
                <h3>{p.name}</h3>
                <div class="description-expand">
                    <p>{p.description[lang]}</p>
                    <div class="product-actions">
                        <a href={p.link} class="btn-primary">{lang === 'es' ? 'Acceder' : 'Access'}</a>
                        <a href={p.link} class="btn-link">
                            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M9 18l6-6-6-6"/></svg>
                        </a>
                    </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .saas-showcase {
    position: relative;
    padding: 12rem 2rem;
    overflow: hidden;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    background: rgba(0, 0, 0, 0.4);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .container {
    position: relative;
    z-index: 2;
    max-width: 1300px;
    margin: 0 auto;
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
    align-items: center;
  }

  .reversed .showcase-grid {
    grid-template-columns: 0.9fr 1.1fr;
  }

  .reversed .showcase-visual {
    order: 2;
  }
  .reversed .showcase-content {
    order: 1;
  }

  /* Visual Column */
  .showcase-visual {
    position: relative;
    width: 100%;
  }

  .visual-glass {
    aspect-ratio: 16/10;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.6);
  }

  .screenshot-placeholder {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .screenshot-placeholder.active {
    opacity: 1;
    visibility: visible;
  }

  .placeholder-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    opacity: 0.3;
  }

  .placeholder-icon {
    width: 80px;
    height: 80px;
    filter: grayscale(1);
  }

  .placeholder-text {
    text-align: center;
  }

  .placeholder-text span {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .placeholder-text p {
    font-size: 1.2rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .visual-controls {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0 1.5rem;
  }

  .progress-bar {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.05);
    border-radius: 1px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: #fff;
    width: 0%;
  }

  .dots-nav {
    display: flex;
    gap: 12px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background: #fff;
    transform: scale(1.4);
  }

  /* Content Column */
  .showcase-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .content-header h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-top: 1rem;
    letter-spacing: -0.03em;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .badge {
    background: rgba(255,255,255,0.08);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .product-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .product-item {
    display: flex;
    gap: 1.5rem;
    padding: 1.75rem;
    border-radius: 2rem;
    background: transparent;
    border: 1px solid transparent;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    user-select: none;
  }

  .product-item:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .product-item.active {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .product-icon-wrapper {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.03);
    border-radius: 14px;
    padding: 0.75rem;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .product-icon-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-info h3 {
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: rgba(255,255,255,0.7);
    transition: color 0.4s ease;
  }

  .product-item.active h3 {
    color: #fff;
  }

  .description-expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-item.active .description-expand {
    grid-template-rows: 1fr;
  }

  .description-expand > div {
    overflow: hidden;
  }

  .product-info p {
    color: rgba(255,255,255,0.4);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    color: rgba(255,255,255,0.6);
  }

  .product-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 0.5rem;
  }

  .btn-primary {
    background: #fff;
    color: #000;
    padding: 0.6rem 1.75rem;
    border-radius: 100px;
    font-weight: 800;
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    transform: scale(1.05);
  }

  .btn-link {
    color: #fff;
    opacity: 0.5;
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
  }

  .btn-link:hover {
    opacity: 1;
    transform: translateX(5px);
  }

  @media (max-width: 1024px) {
    .showcase-grid, .reversed .showcase-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
    }
    .showcase-visual, .reversed .showcase-visual {
        order: 2;
    }
    .showcase-content, .reversed .showcase-content {
        order: 1;
    }
    .saas-showcase {
        padding: 6rem 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .product-item {
        padding: 1.25rem;
    }
  }
</style>

<script>
  function initShowcase() {
    const sections = document.querySelectorAll('.saas-showcase');
    
    sections.forEach(section => {
      const items = section.querySelectorAll('.product-item');
      const screenshots = section.querySelectorAll('.screenshot-placeholder');
      const dots = section.querySelectorAll('.dot');
      const progressFill = section.querySelector('.progress-fill') as HTMLElement;
      
      let currentIndex = 0;
      const intervalTime = 6000;
      let timer: any;

      function updateShowcase(index: number) {
        if (index === currentIndex && items[index].classList.contains('active')) return;

        items.forEach(i => i.classList.remove('active'));
        screenshots.forEach(s => s.classList.remove('active'));
        dots.forEach(d => d.classList.remove('active'));

        items[index].classList.add('active');
        screenshots[index].classList.add('active');
        dots[index].classList.add('active');
        
        currentIndex = index;
        resetProgress();
      }

      function resetProgress() {
        if (progressFill) {
          progressFill.style.transition = 'none';
          progressFill.style.width = '0%';
          setTimeout(() => {
            progressFill.style.transition = `width ${intervalTime}ms linear`;
            progressFill.style.width = '100%';
          }, 50);
        }
      }

      function startTimer() {
        stopTimer();
        timer = setInterval(() => {
          let next = (currentIndex + 1) % items.length;
          updateShowcase(next);
        }, intervalTime);
      }

      function stopTimer() {
        if (timer) clearInterval(timer);
      }

      items.forEach((item, i) => {
        // Handle both click (mobile) and mouseenter (desktop)
        item.addEventListener('mouseenter', () => {
          if (window.innerWidth > 1024) {
            stopTimer();
            updateShowcase(i);
          }
        });

        item.addEventListener('click', (e) => {
          // On mobile or small screens, we use click
          if (window.innerWidth <= 1024) {
             stopTimer();
             updateShowcase(i);
          }
        });

        item.addEventListener('mouseleave', () => {
          if (window.innerWidth > 1024) {
            startTimer();
          }
        });
      });

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          updateShowcase(i);
          startTimer();
        });
      });

      updateShowcase(0);
      startTimer();
    });
  }

  document.addEventListener('DOMContentLoaded', initShowcase);
  document.addEventListener('astro:page-load', initShowcase);
</script>
