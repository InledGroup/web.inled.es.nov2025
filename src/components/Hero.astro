---
import { getLangFromLocals, useTranslations } from '../i18n/utils';
import ProductCarousel from './ProductCarousel.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const stats = [
  { value: 60, label: t('stats.apps'), suffix: '+' },
  { value: 100, label: t('stats.users'), suffix: '%' },
];
---

<section class="hero" id="hero">
  <div class="hero-content">
    <h1 class="hero-title">{t('hero.title')}</h1>
    <p class="hero-subtitle">{t('hero.subtitle')}</p>
    
    <div class="hero-carousel-wrapper">
      <ProductCarousel />
    </div>

    <div class="hero-stats">
      {stats.map(stat => (
        <div class="stat-item">
          <span class="stat-value">{stat.value}{stat.suffix}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    padding: 8rem 0 4rem 0;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    background: rgba(0, 0, 0, 0.45);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(4rem, 15vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 0.9;
    margin-bottom: 1.5rem;
    color: #fff;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
    animation: fadeInDown 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: #fff;
    max-width: 850px;
    margin: 0 auto 1.5rem auto;
    line-height: 1.5;
    padding: 0 2rem;
    animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.2s backwards;
    font-weight: 500;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5), 0 0 20px rgba(0,0,0,0.3);
  }

  .hero-carousel-wrapper {
    animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.4s backwards;
    width: 100%;
    margin: 3rem 0;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 5rem;
    margin-top: 2rem;
    animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.6s backwards;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-value {
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    text-shadow: 0 4px 15px rgba(0,0,0,0.5);
  }

  .stat-label {
    font-size: 0.8rem;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-top: 0.5rem;
    font-weight: 600;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 10rem 0 4rem 0;
    }
    
    .hero-title {
      font-size: clamp(3.5rem, 12vw, 6rem);
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }

    .hero-stats {
      gap: 3rem;
      margin-top: 3rem;
    }

    .stat-value {
      font-size: 2rem;
    }

    .stat-label {
      font-size: 0.7rem;
    }
  }
</style>
