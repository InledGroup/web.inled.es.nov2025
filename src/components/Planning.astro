---
import { getLangFromLocals, useTranslations } from '../i18n/utils';
import projectData from '../data/github-project.json';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const githubProjectUrl = "https://github.com/orgs/InledGroup/projects/1";

interface GithubItem {
  content: {
    title: string;
    url?: string;
    state?: string;
    labels?: {
      nodes: { name: string }[];
    };
  };
  fieldValues: {
    nodes: {
      name?: string;
      field?: { name: string };
    }[];
  };
}

const items = (projectData?.items?.nodes || []) as GithubItem[];

function getStatus(item: GithubItem) {
  const statusField = item.fieldValues.nodes.find(f => f.field?.name === 'Status');
  return statusField?.name || 'Backlog';
}

const columns = {
  'Backlog': items.filter(item => {
    const s = getStatus(item).toLowerCase();
    return s.includes('backlog') || s.includes('triage') || s === 'todo';
  }),
  'In progress': items.filter(item => getStatus(item).toLowerCase().includes('progress')),
  'Done': items.filter(item => {
    const s = getStatus(item).toLowerCase();
    return s.includes('done') || s.includes('complete');
  })
};

const columnIcons = {
  'Backlog': '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>',
  'In progress': '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m16.2 7.8 2.9-2.9"/><path d="M18 12h4"/><path d="m16.2 16.2 2.9 2.9"/><path d="M12 18v4"/><path d="m4.9 19.1 2.9-2.9"/><path d="M2 12h4"/><path d="m4.9 4.9 2.9 2.9"/></svg>',
  'Done': '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>'
};
---

<section class="planning-section">
  <div class="container">
    <div class="section-header">
      <div class="title-group">
        <h2 class="section-title">{t('planning.title')}</h2>
        <p class="section-subtitle">{t('planning.subtitle')}</p>
      </div>
      <a href={githubProjectUrl} target="_blank" rel="noopener noreferrer" class="github-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        {t('planning.button')}
      </a>
    </div>

    <div class="board-wrapper">
      <div class="kanban-board" data-lenis-prevent>
        {Object.entries(columns).map(([colName, colItems]) => (
          <div class="kanban-column">
            <div class="column-header">
              <div class={`column-icon-wrapper icon-${colName.toLowerCase().replace(' ', '-')}`}>
                <span class="column-icon" set:html={columnIcons[colName]} />
              </div>
              <div class="column-info">
                <h3 class="column-title">{colName}</h3>
                <span class="column-count">{colItems.length} {colItems.length === 1 ? 'tarea' : 'tareas'}</span>
              </div>
            </div>
            
            <div class="column-tasks">
              {colItems.length > 0 ? colItems.map((item) => (
                <div class="task-card">
                  <div class="task-labels">
                    {item.content.labels?.nodes.map(label => (
                      <span class="label-badge">{label.name}</span>
                    ))}
                  </div>
                  <h4 class="task-title">
                    {item.content.url ? (
                      <a href={item.content.url} target="_blank" rel="noopener noreferrer">{item.content.title}</a>
                    ) : (
                      item.content.title
                    )}
                  </h4>
                  <div class="task-footer">
                    <span class={`task-state-tag state-${item.content.state?.toLowerCase()}`}>
                      {item.content.state || 'OPEN'}
                    </span>
                  </div>
                </div>
              )) : (
                <div class="empty-column">
                  <p>No hay tareas activas</p>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .planning-section {
    padding: 8rem 2rem;
    background: transparent;
    position: relative;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 5rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    color: #fff;
    margin: 0;
    letter-spacing: -0.05em;
    line-height: 1.1;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 1rem 0 0 0;
    font-weight: 400;
  }

  .github-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 1rem 2rem;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(10px);
  }

  .github-button:hover {
    background: #fff;
    color: #000;
    transform: translateY(-4px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
  }

  .board-wrapper {
    margin: 0 -2rem;
    padding: 0 2rem;
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
  }

  .kanban-board {
    display: grid;
    grid-template-columns: repeat(3, minmax(350px, 1fr));
    gap: 2.5rem;
    padding-bottom: 2rem;
    min-width: 1100px;
  }

  .kanban-column {
    background: rgba(15, 15, 20, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2rem;
    padding: 2rem;
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
  }

  .column-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1.5rem;
  }

  .column-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.05);
  }

  .icon-backlog { background: rgba(255, 255, 255, 0.05); color: #fff; }
  .icon-in-progress { background: rgba(50, 150, 255, 0.15); color: #4faaff; }
  .icon-done { background: rgba(50, 200, 100, 0.15); color: #4ade80; }

  .column-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .column-count {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .column-tasks {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-height: 600px;
    overflow-y: auto;
    padding-right: 0.5rem;
  }

  .column-tasks::-webkit-scrollbar {
    width: 4px;
  }

  .column-tasks::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
  }

  .task-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.25rem;
    padding: 1.5rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .task-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-6px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4);
  }

  .task-labels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .label-badge {
    font-size: 0.7rem;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .task-title {
    font-size: 1.1rem;
    margin: 0;
    line-height: 1.5;
    font-weight: 600;
    color: #fff;
  }

  .task-title a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .task-title a:hover {
    opacity: 0.7;
  }

  .task-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .task-state-tag {
    font-size: 0.65rem;
    font-weight: 800;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .state-open { color: #4faaff; background: rgba(50, 150, 255, 0.1); }
  .state-closed { color: #4ade80; background: rgba(50, 200, 100, 0.1); }

  .empty-column {
    padding: 3rem 1rem;
    text-align: center;
    border: 2px dashed rgba(255, 255, 255, 0.05);
    border-radius: 1.5rem;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 768px) {
    .section-header {
      margin-bottom: 3rem;
    }
  }
</style>
