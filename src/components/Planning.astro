---
import { getLangFromLocals, useTranslations } from '../i18n/utils';
import projectData from '../data/github-project.json';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const githubProjectUrl = "https://github.com/orgs/InledGroup/projects/1";

interface GithubItem {
  content: {
    title: string;
    url?: string;
    state?: string;
    labels?: {
      nodes: { name: string }[];
    };
  };
  fieldValues: {
    nodes: {
      name?: string;
      field?: { name: string };
    }[];
  };
}

const items = (projectData?.items?.nodes || []) as GithubItem[];

function getStatus(item: GithubItem) {
  const statusField = item.fieldValues.nodes.find(f => f.field?.name === 'Status');
  return statusField?.name || 'Backlog';
}

const columns = {
  'Backlog': items.filter(item => {
    const s = getStatus(item).toLowerCase();
    return s.includes('backlog') || s.includes('triage') || s === 'todo';
  }),
  'In progress': items.filter(item => getStatus(item).toLowerCase().includes('progress')),
  'Done': items.filter(item => {
    const s = getStatus(item).toLowerCase();
    return s.includes('done') || s.includes('complete');
  })
};

const columnIcons = {
  'Backlog': '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>',
  'In progress': '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m16.2 7.8 2.9-2.9"/><path d="M18 12h4"/><path d="m16.2 16.2 2.9 2.9"/><path d="M12 18v4"/><path d="m4.9 19.1 2.9-2.9"/><path d="M2 12h4"/><path d="m4.9 4.9 2.9 2.9"/></svg>',
  'Done': '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>'
};
---

<section class="planning-section">
  <div class="container">
    <div class="section-header">
      <div class="title-group">
        <h3 class="planning-board-title">{t('planning.title')}</h3>
      </div>
      <a href={githubProjectUrl} target="_blank" rel="noopener noreferrer" class="github-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        {t('planning.button')}
      </a>
    </div>

    <div class="board-wrapper">
      <div class="kanban-board" data-lenis-prevent>
        {Object.entries(columns).map(([colName, colItems]) => (
          <div class="kanban-column">
            <div class={`column-header icon-${colName.toLowerCase().replace(' ', '-')}`}>
              <span class="column-icon" set:html={columnIcons[colName]} />
              <div class="column-info">
                <h4 class="column-title">{colName}</h4>
                <span class="column-count">{colItems.length}</span>
              </div>
            </div>
            
            <div class="column-tasks">
              {colItems.length > 0 ? colItems.map((item) => (
                <div class="task-card">
                  <div class="task-labels">
                    {item.content.labels?.nodes.map(label => (
                      <span class="label-badge">{label.name}</span>
                    ))}
                  </div>
                  <h4 class="task-title">
                    {item.content.url ? (
                      <a href={item.content.url} target="_blank" rel="noopener noreferrer">{item.content.title}</a>
                    ) : (
                      item.content.title
                    )}
                  </h4>
                  <div class="task-footer">
                    <span class={`task-state-tag state-${item.content.state?.toLowerCase()}`}>
                      {item.content.state || 'OPEN'}
                    </span>
                  </div>
                </div>
              )) : (
                <div class="empty-column">
                  <p>No hay tareas activas</p>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .planning-section {
    padding: 3rem 2rem;
    background: transparent;
    position: relative;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1.5rem;
  }

  .planning-board-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    letter-spacing: -0.02em;
    opacity: 0.9;
  }

  .github-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.02);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }

  .github-button:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .board-wrapper {
    margin: 0 -2rem;
    padding: 0 2rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  
  .board-wrapper::-webkit-scrollbar {
    display: none;
  }

  .kanban-board {
    display: grid;
    grid-template-columns: repeat(3, minmax(320px, 1fr));
    gap: 1.5rem;
    padding-bottom: 1rem;
    min-width: 1000px;
  }

  .kanban-column {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .column-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1rem;
  }

  .column-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: rgba(255, 255, 255, 0.4);
  }

  .icon-backlog .column-icon { color: rgba(255, 255, 255, 0.4); }
  .icon-in-progress .column-icon { color: #4faaff; }
  .icon-done .column-icon { color: #4ade80; }

  .column-info {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex: 1;
  }

  .column-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .column-count {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8rem;
    font-family: monospace;
  }

  .column-tasks {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: 500px;
    overflow-y: auto;
    padding-right: 0.25rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .column-tasks::-webkit-scrollbar {
    display: none;
  }

  .task-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 8px;
    padding: 1.25rem;
    transition: border-color 0.2s ease, background-color 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .task-card:hover {
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .task-labels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .label-badge {
    font-size: 0.65rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.85);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .task-title {
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.45;
    font-weight: 500;
    color: #fff;
  }

  .task-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .task-title a:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .task-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .task-state-tag {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
    font-family: monospace;
  }

  .state-open { color: #4faaff; background: rgba(50, 150, 255, 0.08); border: 1px solid rgba(50, 150, 255, 0.15); }
  .state-closed { color: #4ade80; background: rgba(50, 200, 100, 0.08); border: 1px solid rgba(50, 200, 100, 0.15); }

  .empty-column {
    padding: 2.5rem 1rem;
    text-align: center;
    border: 1px dashed rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.9rem;
  }
</style>
