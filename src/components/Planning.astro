---
import { getLangFromLocals, useTranslations } from '../i18n/utils';
import projectData from '../data/github-project.json';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const githubProjectUrl = "https://github.com/orgs/InledGroup/projects/1";

interface GithubItem {
  content: {
    title: string;
    url?: string;
    state?: string;
    labels?: {
      nodes: { name: string }[];
    };
  };
  fieldValues: {
    nodes: {
      name?: string;
      field?: { name: string };
    }[];
  };
}

const items = (projectData?.items?.nodes || []) as GithubItem[];

function getStatus(item: GithubItem) {
  const statusField = item.fieldValues.nodes.find(f => f.field?.name === 'Status');
  return statusField?.name || 'Backlog';
}

// Organizar items por columnas
const columns = {
  'Backlog': items.filter(item => {
    const s = getStatus(item).toLowerCase();
    return s.includes('backlog') || s.includes('triage') || s === 'todo';
  }),
  'In progress': items.filter(item => getStatus(item).toLowerCase().includes('progress')),
  'Done': items.filter(item => {
    const s = getStatus(item).toLowerCase();
    return s.includes('done') || s.includes('complete');
  })
};

const columnIcons = {
  'Backlog': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
  'In progress': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m16.2 7.8 2.9-2.9"/><path d="M18 12h4"/><path d="m16.2 16.2 2.9 2.9"/><path d="M12 18v4"/><path d="m4.9 19.1 2.9-2.9"/><path d="M2 12h4"/><path d="m4.9 4.9 2.9 2.9"/></svg>',
  'Done': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>'
};
---

<section class="planning-section">
  <div class="container">
    <div class="section-header">
      <div class="title-group">
        <h2 class="section-title">{t('planning.title')}</h2>
        <p class="section-subtitle">{t('planning.subtitle')}</p>
      </div>
      <a href={githubProjectUrl} target="_blank" rel="noopener noreferrer" class="github-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        {t('planning.button')}
      </a>
    </div>

    <div class="kanban-board" data-lenis-prevent>
      {Object.entries(columns).map(([colName, colItems]) => (
        <div class="kanban-column">
          <div class="column-header">
            <span class={`column-icon icon-${colName.toLowerCase().replace(' ', '-')}`} set:html={columnIcons[colName]} />
            <h3 class="column-title">{colName}</h3>
            <span class="column-count">{colItems.length}</span>
          </div>
          
          <div class="column-tasks">
            {colItems.length > 0 ? colItems.map((item) => (
              <div class="task-card">
                <div class="task-labels">
                  {item.content.labels?.nodes.map(label => (
                    <span class="label-badge">{label.name}</span>
                  ))}
                </div>
                <h4 class="task-title">
                  {item.content.url ? (
                    <a href={item.content.url} target="_blank" rel="noopener noreferrer">{item.content.title}</a>
                  ) : (
                    item.content.title
                  )}
                </h4>
                {item.content.state && <span class="task-state">{item.content.state}</span>}
              </div>
            )) : (
              <div class="empty-column">
                <p>No hay tareas</p>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .planning-section {
    padding: 6rem 2rem;
    background: transparent;
    overflow: hidden;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    margin: 0;
    letter-spacing: -0.04em;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0.75rem 0 0 0;
    font-weight: 400;
  }

  .github-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.8rem 1.8rem;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(10px);
  }

  .github-button:hover {
    background: #fff;
    color: #000;
    border-color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  .kanban-board {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: start;
    overflow-x: auto;
    padding-bottom: 2rem;
  }

  .kanban-column {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 1.5rem;
    padding: 1.25rem;
    min-height: 400px;
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .column-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.25rem 0.5rem;
  }

  .column-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
  }

  .icon-backlog { background: rgba(255, 255, 255, 0.05); color: #fff; }
  .icon-in-progress { background: rgba(50, 150, 255, 0.1); color: #4faaff; }
  .icon-done { background: rgba(50, 200, 100, 0.1); color: #4ade80; }

  .column-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    flex-grow: 1;
  }

  .column-count {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
  }

  .column-tasks {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .task-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    padding: 1.25rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .task-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .task-labels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .label-badge {
    font-size: 0.65rem;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.5);
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .task-title {
    font-size: 1rem;
    margin: 0;
    line-height: 1.5;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }

  .task-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .task-title a:hover {
    color: #4faaff;
  }

  .task-state {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 400;
  }

  .empty-column {
    padding: 2rem;
    text-align: center;
    border: 1px dashed rgba(255, 255, 255, 0.05);
    border-radius: 1rem;
    color: rgba(255, 255, 255, 0.2);
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .kanban-board {
      grid-template-columns: repeat(3, 320px);
    }
  }

  @media (max-width: 768px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
