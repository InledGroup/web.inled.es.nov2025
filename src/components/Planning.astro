---
import { getLangFromLocals, useTranslations } from '../i18n/utils';
import projectData from '../data/github-project.json';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const githubProjectUrl = "https://github.com/orgs/InledGroup/projects/1";

interface GithubItem {
  content: {
    title: string;
    url?: string;
    state?: string;
    labels?: {
      nodes: { name: string }[];
    };
  };
  fieldValues: {
    nodes: {
      name?: string;
      field?: { name: string };
    }[];
  };
}

const items = (projectData?.items?.nodes || []) as GithubItem[];

function getStatus(item: GithubItem) {
  const statusField = item.fieldValues.nodes.find(f => f.field?.name === 'Status');
  return statusField?.name || 'Todo';
}

function getStatusClass(status: string) {
  const s = status.toLowerCase();
  if (s.includes('progress')) return 'status-progress';
  if (s.includes('done') || s.includes('complete')) return 'status-done';
  return 'status-todo';
}
---

<section class="planning-section">
  <div class="container">
    <div class="section-header">
      <div class="title-group">
        <h2 class="section-title">{t('planning.title')}</h2>
        <p class="section-subtitle">{t('planning.subtitle')}</p>
      </div>
      <a href={githubProjectUrl} target="_blank" rel="noopener noreferrer" class="github-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        {t('planning.button')}
      </a>
    </div>

    <div class="tasks-container">
      {items.length > 0 ? (
        <div class="tasks-grid">
          {items.map((item) => {
            const status = getStatus(item);
            return (
              <div class="task-card">
                <div class="task-header">
                  <span class={`status-badge ${getStatusClass(status)}`}>
                    {status}
                  </span>
                  {item.content.labels?.nodes.map(label => (
                    <span class="label-badge">{label.name}</span>
                  ))}
                </div>
                <h3 class="task-title">
                  {item.content.url ? (
                    <a href={item.content.url} target="_blank" rel="noopener noreferrer">{item.content.title}</a>
                  ) : (
                    item.content.title
                  )}
                </h3>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="empty-state">
          <p>No hay tareas visibles en este momento.</p>
          <a href={githubProjectUrl} target="_blank" class="text-link">Ver en GitHub →</a>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .planning-section {
    padding: 6rem 2rem;
    background: transparent;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    margin: 0;
    letter-spacing: -0.04em;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0.75rem 0 0 0;
    font-weight: 400;
  }

  .github-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.8rem 1.8rem;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(10px);
  }

  .github-button:hover {
    background: #fff;
    color: #000;
    border-color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  .tasks-container {
    width: 100%;
  }

  .tasks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .task-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    backdrop-filter: blur(10px);
  }

  .task-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-5px);
  }

  .task-header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-todo { background: rgba(100, 100, 100, 0.2); color: #ccc; }
  .status-progress { background: rgba(50, 150, 255, 0.2); color: #4faaff; }
  .status-done { background: rgba(50, 200, 100, 0.2); color: #4ade80; }

  .label-badge {
    font-size: 0.7rem;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.6);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .task-title {
    font-size: 1.15rem;
    margin: 0;
    line-height: 1.4;
    font-weight: 500;
    color: #fff;
  }

  .task-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .task-title a:hover {
    color: #4faaff;
  }

  .empty-state {
    text-align: center;
    padding: 4rem;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 2rem;
    border: 1px dashed rgba(255, 255, 255, 0.1);
  }

  .empty-state p {
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }

  .text-link {
    color: #fff;
    text-decoration: none;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
