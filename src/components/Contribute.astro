---
import { getLangFromLocals, useTranslations } from '../i18n/utils';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const discordInviteUrl = "https://discord.com/invite/PSeTkDMnr";
const githubOrgUrl = "https://github.com/InledGroup";
const matrixUrl = "https://matrix.to/#/!POXBFohLnmrKwRBxTi:matrix.org?via=matrix.org";
---

<section class="contribute-section">
  <div class="container">
    <div class="contribute-card">
      <div class="contribute-content">
        <h3 class="contribute-title">{t('contribute.title')}</h3>
        <p class="contribute-text">{t('contribute.text')}</p>
        <p class="contribute-warning">{t('contribute.warning')}</p>
      </div>
      <div class="contribute-actions">
        <a href={discordInviteUrl} target="_blank" rel="noopener noreferrer" class="btn btn-discord">
          <i class="fa-brands fa-discord"></i>
          {t('contribute.discord')}
        </a>
        <a href={matrixUrl} target="_blank" rel="noopener noreferrer" class="btn btn-matrix">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.3.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path fill="rgb(255, 255, 255)" d="M125.6 91L92.7 91L92.7 549L125.6 549L125.6 560L80 560L80 80L125.6 80L125.6 91zM560 560L514.4 560L514.4 549L547.3 549L547.3 91L514.4 91L514.4 80L560 80L560 560zM388.1 231.6C397.1 231.6 405.5 232.7 413.3 234.9C421.1 237.1 427.6 240.6 433.1 245.5C438.6 250.4 442.9 256.7 446 264.5C449 272.3 450.6 281.8 450.6 292.8L450.6 407.3L403.6 407.3L403.6 310.3C403.6 304.6 403.4 299.1 403 294C402.6 288.9 401.3 284.5 399.4 280.8C397.4 277 394.5 274 390.7 271.8C386.9 269.6 381.6 268.5 375 268.5C368.4 268.5 363 269.8 358.9 272.3C354.8 274.9 351.6 278.1 349.3 282.3C347 286.4 345.4 291 344.7 296.2C344 301.4 343.5 306.6 343.5 311.9L343.5 407.2L296.5 407.2L296.5 311.2C296.5 306.1 296.4 301.1 296.1 296.2C295.9 291.2 294.9 286.7 293.2 282.4C291.5 278.3 288.8 274.8 284.9 272.3C281 269.8 275.4 268.5 267.8 268.5C265.6 268.5 262.6 269 259 270C255.4 271 251.8 272.9 248.4 275.6C245 278.3 242 282.3 239.6 287.5C237.2 292.7 236 299.5 236 307.9L236 407.2L189 407.2L189 235.9L233.3 235.9L233.3 259.1L234 259.1C240.2 250.2 247.7 243.4 256.3 238.6C265 233.7 275 231.3 286.3 231.3C297.1 231.3 307 233.4 315.9 237.6C324.8 241.8 331.6 249.2 336.3 259.8C341.4 252.3 348.3 245.7 357 240C365.7 234.3 376 231.4 387.9 231.4z"/></svg>
          {t('contribute.matrix')}
        </a>
        <a href={githubOrgUrl} target="_blank" rel="noopener noreferrer" class="btn btn-github">
          <i class="fa-brands fa-github"></i>
          {t('contribute.github')}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contribute-section {
    padding: 4rem 2rem;
    background: transparent;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .contribute-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .contribute-content {
    flex: 1;
    min-width: 300px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contribute-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .contribute-text {
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }

  .contribute-warning {
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    border-left: 2px solid rgba(255, 255, 255, 0.25);
    padding-left: 0.75rem;
  }

  .contribute-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1.6rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-discord {
    background: rgba(88, 101, 242, 0.1);
    color: #5865f2;
    border: 1px solid rgba(88, 101, 242, 0.25);
  }

  .btn-discord:hover {
    background: #5865f2;
    color: #fff;
    border-color: #5865f2;
  }

  .btn-matrix {
    background: rgba(13, 189, 139, 0.1);
    color: #0dbd8b;
    border: 1px solid rgba(13, 189, 139, 0.25);
  }

  .btn-matrix:hover {
    background: #0dbd8b;
    color: #fff;
    border-color: #0dbd8b;
  }

  .btn-matrix svg {
    margin-right: 0.25rem;
  }

  .btn-github {
    background: rgba(255, 255, 255, 0.02);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .btn-github:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 768px) {
    .contribute-card {
      padding: 2rem 1.5rem;
      gap: 2rem;
    }

    .contribute-actions {
      width: 100%;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
