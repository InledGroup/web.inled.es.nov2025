---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

const lang = getLangFromLocals(Astro.locals);

const app = {
  id: "agent-tunnel",
  title: "Agent Tunnel",
  logo: "https://hosted.inled.es/1/agent-tunnel-churro.png",
  repoUrl: "https://github.com/InledGroup/agent-tunnel",
  cloneCmd: "git clone https://github.com/InledGroup/agent-tunnel.git"
};

const i18n = {
  es: {
    hero: {
      subtitle: "Acceso remoto seguro para tus agentes de IA.",
      description: "Agent Tunnael permite a tus agentes interactuar con máquinas remotas montando carpetas remotas y redirigiendo comandos de forma sencilla. No necesitas instalar el agente en cada maquina, solo dale al de una el acceso al resto",
      button: "Ver en GitHub",
      status: "Beta abierta",
      disclaimer: "Agent Tunnel está en fase beta. Úsalo con precaución en entornos de producción."
    },
    usage: {
      title: "Instalación y Configuración",
      steps: [
        { title: "Clonar repositorio", cmd: app.cloneCmd },
        { title: "Preparar script", cmd: "chmod +x start-bridge.sh" },
        { title: "Iniciar Bridge", cmd: "./start-bridge.sh" }
      ],
      notice: "Al iniciar el bridge, se abrirá una interfaz web donde podrás configurar las conexiones de forma sencilla."
    }
  },
  en: {
    hero: {
      subtitle: "Secure remote access for your AI agents.",
      description: "Agent Tunnel allows your agents to interact with remote machines by mounting remote folders and redirecting commands easily. No need to install the agent on every machine, just give the access to one and it will handle the rest.",
      button: "View on GitHub",
      status: "Open Beta",
      disclaimer: "Agent Tunnel is in beta phase. Use with caution in production environments."
    },
    usage: {
      title: "Installation and Configuration",
      steps: [
        { title: "Clone repository", cmd: app.cloneCmd },
        { title: "Prepare script", cmd: "chmod +x start-bridge.sh" },
        { title: "Start Bridge", cmd: "./start-bridge.sh" }
      ],
      notice: "When starting the bridge, a web interface will open where you can easily configure the connections."
    }
  }
};

const t = i18n[lang] || i18n.es;

const colors = {
  accent: "#FF8205",
  bg: "#1E1E1E",
  surface: "#2A2A2A",
  surfaceHover: "#333333",
  border: "#3D3D3D",
  text: "#F0F0F0",
  lightBg: "#F0F0F0",
  lightText: "#1E1E1E"
};
---

<Layout title="Agent Tunnel - Remote Access for AI Agents - Inled" description={t.hero.subtitle}>
  <div class="page-wrapper" id="page-wrapper">
    <canvas id="vortex-canvas"></canvas>
    
    <Header />
    
    <main>
      <!-- Hero Section -->
      <section class="hero" id="hero-section">
        <div class="content reveal">
          <div class="status-badge" id="hero-status">
            {t.hero.status}
          </div>
          
          <div class="logo-wrapper">
            <img src={app.logo} alt="Agent Tunnel Logo" class="app-logo" />
            <div class="logo-glow"></div>
          </div>
          
          <h1 class="title">Agent <span class="accent-text">Tunnel</span></h1>
          <p class="subtitle" id="hero-subtitle">
            {t.hero.subtitle}
          </p>
          
          <div class="description-box">
            <p id="hero-description">{t.hero.description}</p>
          </div>
          
          <div class="actions">
            <a href={app.repoUrl} target="_blank" class="btn btn-primary" id="hero-button">
              <i class="fa-brands fa-github"></i>
              {t.hero.button}
            </a>
          </div>
          
          <div class="scroll-indicator">
            <p id="scroll-text">{lang === 'es' ? 'Desliza para explorar' : 'Scroll to explore'}</p>
            <div class="mouse"></div>
          </div>
        </div>
      </section>

      <!-- Usage Section (En la zona clara) -->
      <section class="usage reveal" id="usage-section">
        <div class="container">
          <h2 class="section-title" id="usage-title">{t.usage.title}</h2>
          
          <div class="steps-grid">
            {t.usage.steps.map((step, index) => (
              <div class="step-card">
                <div class="step-num">{index + 1}</div>
                <h3 id={`step-title-${index}`}>{step.title}</h3>
                <div class="code-block">
                  <code>{step.cmd}</code>
                  <button class="copy-btn" data-copy={step.cmd} aria-label="Copy command">
                    <i class="fa-regular fa-copy"></i>
                  </button>
                </div>
              </div>
            ))}
          </div>
          
          <div class="usage-notice">
            <i class="fa-solid fa-circle-info"></i>
            <p id="usage-notice-text">{t.usage.notice}</p>
          </div>
          
          <div class="beta-disclaimer">
            <p id="hero-disclaimer">{t.hero.disclaimer}</p>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style define:vars={{ 
  accent: colors.accent, 
  bg: colors.bg, 
  surface: colors.surface, 
  surfaceHover: colors.surfaceHover, 
  border: colors.border, 
  text: colors.text,
  lightBg: colors.lightBg,
  lightText: colors.lightText
}}>
  .page-wrapper {
    background-color: var(--bg);
    color: var(--text);
    min-height: 200vh; /* Espacio extra para el efecto de scroll */
    position: relative;
    transition: background-color 0.4s ease, color 0.4s ease;
    font-family: 'Ubuntu', sans-serif;
  }

  #vortex-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  main {
    position: relative;
    z-index: 1;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero Section */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 140px 2rem 6rem;
  }

  .content {
    max-width: 800px;
    width: 100%;
  }

  .status-badge {
    display: inline-block;
    padding: 0.5rem 1.2rem;
    background: rgba(255, 130, 5, 0.1);
    border: 1px solid var(--accent);
    border-radius: 50px;
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: 2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .logo-wrapper {
    position: relative;
    width: 160px;
    height: 160px;
    margin: 0 auto 2.5rem;
  }

  .app-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    position: relative;
    z-index: 2;
  }

  .logo-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 140%;
    height: 140%;
    background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
    opacity: 0.2;
    filter: blur(30px);
    z-index: 1;
  }

  .title {
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .accent-text {
    color: var(--accent);
    text-shadow: 0 0 30px rgba(255, 130, 5, 0.3);
  }

  .subtitle {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 3rem;
    font-weight: 300;
  }

  .description-box {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 2rem;
    border-radius: 24px;
    margin-bottom: 3rem;
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
  }

  .description-box p {
    font-size: 1.15rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 2.5rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
    box-shadow: 0 10px 25px rgba(255, 130, 5, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 15px 35px rgba(255, 130, 5, 0.6);
  }

  .scroll-indicator {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .mouse {
    width: 26px;
    height: 42px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    position: relative;
  }

  .mouse::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    background: var(--accent);
    border-radius: 2px;
    animation: scroll-anim 2s infinite;
  }

  @keyframes scroll-anim {
    0% { transform: translate(-50%, 0); opacity: 1; }
    100% { transform: translate(-50%, 15px); opacity: 0; }
  }

  /* Usage Section - Lighter state */
  .usage {
    padding: 15rem 0 8rem;
    min-height: 100vh;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
  }

  .usage.active {
    opacity: 1;
    transform: translateY(0);
  }

  .section-title {
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    text-align: center;
    margin-bottom: 4rem;
    font-weight: 800;
  }

  .steps-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .step-card {
    background: transparent;
    border: none;
    padding: 0;
    transition: all 0.4s ease;
    position: relative;
  }

  .step-card:hover {
    transform: translateX(10px);
  }

  .step-num {
    position: absolute;
    top: -15px;
    left: -45px;
    font-size: 5rem;
    font-weight: 900;
    color: var(--accent);
    opacity: 0.1;
    line-height: 1;
    pointer-events: none;
  }

  .step-card h3 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
    font-weight: 700;
    color: var(--accent);
  }

  .code-block {
    background: #111;
    padding: 1.5rem;
    border-radius: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }

  .code-block code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.95rem;
    color: #e0e0e0;
    overflow-x: auto;
  }

  .copy-btn {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    padding: 0.6rem;
    transition: all 0.2s;
  }

  .copy-btn:hover {
    color: var(--accent);
    transform: scale(1.1);
  }

  .usage-notice {
    margin-top: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(255, 130, 5, 0.05);
    border-radius: 16px;
    border: 1px dashed var(--accent);
  }

  .usage-notice i {
    font-size: 1.5rem;
    color: var(--accent);
  }

  .usage-notice p {
    margin: 0;
    font-weight: 500;
  }

  .beta-disclaimer {
    margin-top: 4rem;
    text-align: center;
    color: rgba(0, 0, 0, 0.5);
    font-size: 0.9rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Transition adjustments */
  .page-wrapper.light-mode {
    background-color: var(--lightBg);
    color: var(--lightText);
  }

  .page-wrapper.light-mode .subtitle,
  .page-wrapper.light-mode .description-box p {
    color: rgba(0, 0, 0, 0.7);
  }

  .page-wrapper.light-mode .code-block {
    background: #fdfdfd;
    border-color: rgba(0,0,0,0.1);
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
  }
  
  .page-wrapper.light-mode .code-block code {
    color: #333;
  }

  .page-wrapper.light-mode .step-num {
    color: var(--accent);
    opacity: 0.1;
  }

  .page-wrapper.light-mode .beta-disclaimer {
    color: rgba(0, 0, 0, 0.4);
  }

  .page-wrapper.light-mode .usage-notice {
    background: rgba(255, 130, 5, 0.03);
  }

  /* Reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .title { font-size: 3rem; }
    .subtitle { font-size: 1.1rem; }
    .hero { padding: 120px 1.5rem 4rem; }
    .usage { padding-top: 10rem; }
    .steps-grid { padding-left: 2.5rem; }
    .step-num { left: -35px; font-size: 3.5rem; }
    .page-wrapper { min-height: 200vh; }
  }
</style>

<script define:vars={{ i18n }}>
  // --- Vortex Particles Logic ---
  const canvas = document.getElementById('vortex-canvas');
  const ctx = canvas.getContext('2d');
  const wrapper = document.getElementById('page-wrapper');
  
  let width = window.innerWidth;
  let height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;

  const particles = [];
  const particleCount = 200;
  let scrollY = 0;
  let scrollProgress = 0; // 0 to 1

  class Particle {
    constructor() {
      this.reset();
    }

    reset() {
      this.x = (Math.random() - 0.5) * 2000;
      this.y = (Math.random() - 0.5) * 2000;
      this.z = Math.random() * 2000;
      this.originalZ = this.z;
      this.size = 1 + Math.random() * 2;
      this.color = `rgba(255, 130, 5, ${0.1 + Math.random() * 0.4})`;
    }

    update() {
      // Speed depends on scroll
      const speed = 2 + scrollProgress * 50;
      this.z -= speed;

      if (this.z <= 0) {
        this.reset();
        this.z = 2000;
      }
    }

    draw() {
      const scale = 1000 / this.z;
      const x2d = this.x * scale + width / 2;
      const y2d = this.y * scale + height / 2;
      const s = this.size * scale;

      if (x2d >= 0 && x2d <= width && y2d >= 0 && y2d <= height) {
        if (ctx) {
          ctx.beginPath();
          ctx.fillStyle = this.color;
          ctx.arc(x2d, y2d, s, 0, Math.PI * 2);
          ctx.fill();
        }
      }
    }
  }

  function init() {
    for (let i = 0; i < particleCount; i++) {
      particles.push(new Particle());
    }
  }

  function animate() {
    if (!ctx) return;
    
    // Clear with slight trail or solid color based on progress
    if (scrollProgress < 0.5) {
      ctx.fillStyle = `rgba(30, 30, 30, ${0.2 + scrollProgress * 0.5})`;
    } else {
      // Transition to light clear
      const r = Math.floor(30 + (240 - 30) * ((scrollProgress - 0.5) * 2));
      const g = Math.floor(30 + (240 - 30) * ((scrollProgress - 0.5) * 2));
      const b = Math.floor(30 + (240 - 30) * ((scrollProgress - 0.5) * 2));
      ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.3)`;
    }
    
    ctx.fillRect(0, 0, width, height);

    particles.forEach(p => {
      p.update();
      p.draw();
    });

    requestAnimationFrame(animate);
  }

  window.addEventListener('resize', () => {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
  });

  window.addEventListener('scroll', () => {
    scrollY = window.scrollY;
    // Transición mucho más agresiva
    scrollProgress = Math.min(Math.max((scrollY - window.innerHeight * 0.1) / (window.innerHeight * 0.4), 0), 1);

    // Toggle light mode class
    if (scrollProgress > 0.5) {
      wrapper?.classList.add('light-mode');
    } else {
      wrapper?.classList.remove('light-mode');
    }

    // Handle reveals
    const reveals = document.querySelectorAll(".reveal");
    reveals.forEach((element) => {
      const elementTop = element.getBoundingClientRect().top;
      const elementVisible = 150;
      if (elementTop < window.innerHeight - elementVisible) {
        element.classList.add("active");
      }
    });
  });

  init();
  animate();

  // --- Copy to clipboard ---
  const copyButtons = document.querySelectorAll(".copy-btn");
  copyButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const text = btn.getAttribute("data-copy");
      if (text) {
        navigator.clipboard.writeText(text);
        const icon = btn.querySelector("i");
        if (icon) {
          icon.classList.remove("fa-copy");
          icon.classList.add("fa-check");
          setTimeout(() => {
            icon.classList.remove("fa-check");
            icon.classList.add("fa-copy");
          }, 2000);
        }
      }
    });
  });

  // --- Language Switcher ---
  const elements = {
    heroStatus: document.getElementById('hero-status'),
    heroSubtitle: document.getElementById('hero-subtitle'),
    heroDescription: document.getElementById('hero-description'),
    heroButton: document.getElementById('hero-button'),
    scrollText: document.getElementById('scroll-text'),
    usageTitle: document.getElementById('usage-title'),
    usageNotice: document.getElementById('usage-notice-text'),
    heroDisclaimer: document.getElementById('hero-disclaimer')
  };

  function updateLang(lang) {
    const data = i18n[lang];
    if (!data) return;

    if (elements.heroStatus) elements.heroStatus.textContent = data.hero.status;
    if (elements.heroSubtitle) elements.heroSubtitle.textContent = data.hero.subtitle;
    if (elements.heroDescription) elements.heroDescription.textContent = data.hero.description;
    if (elements.heroButton) {
      elements.heroButton.innerHTML = `<i class="fa-brands fa-github"></i> ${data.hero.button}`;
    }
    if (elements.scrollText) {
      elements.scrollText.textContent = lang === 'es' ? 'Desliza para explorar' : 'Scroll to explore';
    }
    if (elements.usageTitle) elements.usageTitle.textContent = data.usage.title;
    if (elements.usageNotice) elements.usageNotice.textContent = data.usage.notice;
    if (elements.heroDisclaimer) elements.heroDisclaimer.textContent = data.hero.disclaimer;

    data.usage.steps.forEach((step, index) => {
      const titleEl = document.getElementById(`step-title-${index}`);
      if (titleEl) titleEl.textContent = step.title;
    });

    document.documentElement.lang = lang;
  }

  window.addEventListener('langChanged', (e) => {
    updateLang(e.detail.lang);
  });

  // Initialize from preferred lang
  const initialLang = localStorage.getItem('preferred-lang') || 'es';
  updateLang(initialLang);
</script>
