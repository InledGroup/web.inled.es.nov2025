---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

const lang = getLangFromLocals(Astro.locals);

const t = {
  es: {
    hero: {
      title: "Agent Tunnel",
      subtitle: "La pasarela de tus agentes a cualquier dispositivo.",
      description: "Conecta cualquier agente CLI (Claude Code, Gemini CLI, Codex) con tus máquinas remotas de forma segura, rápida y sin fricción.",
      cta: "Ver en GitHub",
      install: "Instalación instantánea"
    },
    features: {
      title: "Capacidades de grado profesional",
      sync: {
        title: "Sync con Mutagen",
        desc: "Sincronización bidireccional de archivos en tiempo real. La carpeta remota se monta en local para que el agente pueda trabajar como si estuviera en un proyecto local, pero con la diferencia de que cada cambio se sincroniza con el remoto.."
      },
      sshOnly: {
        title: "Modo SSH Only",
        desc: "Ideal si no quieres mover muchos archivos y prefieres que el agente trabaje directamente en el servidor. Igualmente puede editarlos con herramientas del sistema remoto, y así te ahorras pasar gigas de un lado a otro."
      },
      noKeys: {
        title: "Modo No Key Management",
        desc: "Cuando no quieres que Agent Tunnel maneje claves ssh, para una máxima seguridad, este dispone de un modo No Key Management."
      },
      multi: {
        title: "Multisesión",
        desc: "Orquestación de múltiples agentes trabajando en paralelo sobre diferentes entornos sin colisiones de estado."
      },
      exclusion: {
        title: "Control de Comandos",
        desc: "Define qué comandos se ejecutan en local o en el remoto."
      }
    },
    security: {
      title: "Seguridad por diseño",
      desc: "Agent Tunnel por su naturaleza trabaja con tus máquinas remotas, por lo que la seguridad es nuestra prioridad.",
      nativeSsh: "Modo No Key Management",
      nativeSshDesc: "Reducción de superficie de ataque impidiendo a Agent Tunnel el manejo de claves, delegando este en el sistema",
      autoAuth: "Autorización Automática",
      autoAuthDesc: "Facilitamos la conexión autorizando claves de forma segura y efímera para que puedas empezar a trabajar en segundos."
    },
    compatibility: {
      title: "Compatibilidad Universal",
      desc: "Simplemente tienes que escoger el nombre del archivo de instrucciones .md."
    },
    desktop: {
      title: "App de Escritorio",
      beta: "BETA",
      subtitle: "Instalar y usar. Sin terminal.",
      macos: "macOS",
      windows: "Windows",
      linuxDeb: "Linux (.deb)",
      linuxRpm: "Linux (.rpm)",
      latest: "Ver última versión en GitHub",
      amd64: "AMD64",
      arm64: "ARM64",
      macosInstruction: "Instrucciones para macOS",
      macosNote: "Si macOS bloquea la aplicación por no estar firmada, abre la terminal en tu carpeta de Aplicaciones y ejecuta:",
      macosCmd: "xattr -r -d com.apple.quarantine Agent\\ Tunnel.app",
      devNote: "Nota del desarrollador: Esta aplicación es gratuita y de código abierto. No se dispone de firma oficial de Apple ya que no voy a pagar una cuenta de desarrollador para un proyecto que no me reporta beneficio económico alguno."
    }
  },
  en: {
    hero: {
      title: "Agent Tunnel",
      subtitle: "The gateway of your agents to any device.",
      description: "Connect any CLI agent (Claude Code, Gemini CLI, Codex) to your remote machines securely, fast, and without friction.",
      cta: "View on GitHub",
      install: "Instant installation"
    },
    features: {
      title: "Professional grade capabilities",
      sync: {
        title: "Sync with Mutagen",
        desc: "Real-time bidirectional file synchronization. The remote folder is mounted locally so the agent can work as if it were in a local project, but with the difference that every change is synced with the remote.."
      },
      sshOnly: {
        title: "SSH Only Mode",
        desc: "Ideal if you don't want to move many files and prefer the agent to work directly on the server. It can also edit them using remote system tools, saving you from transferring gigabytes back and forth."
      },
      noKeys: {
        title: "No Key Management Mode",
        desc: "When you don't want Agent Tunnel to handle SSH keys, for maximum security, it features a No Key Management mode."
      },
      multi: {
        title: "Multi-session",
        desc: "Orchestration of multiple agents working in parallel across different environments without state collisions."
      },
      exclusion: {
        title: "Command Control",
        desc: "Define which commands are executed locally or on the remote."
      }
    },
    security: {
      title: "Security by design",
      desc: "Agent Tunnel by its nature works with your remote machines, so security is our priority.",
      nativeSsh: "No Key Management Mode",
      nativeSshDesc: "Reduction of attack surface by preventing Agent Tunnel from managing keys, delegating this to the system",
      autoAuth: "Automatic Authorization",
      autoAuthDesc: "We facilitate connection by authorizing keys securely and ephemerally so you can start working in seconds."
    },
    compatibility: {
      title: "Universal Compatibility",
      desc: "You simply have to choose the name of the instruction file .md."
    },
    desktop: {
      title: "Desktop App",
      beta: "BETA",
      subtitle: "Install and use. No terminal required.",
      macos: "macOS",
      windows: "Windows",
      linuxDeb: "Linux (.deb)",
      linuxRpm: "Linux (.rpm)",
      latest: "View latest release on GitHub",
      amd64: "AMD64",
      arm64: "ARM64",
      macosInstruction: "macOS Instructions",
      macosNote: "If macOS blocks the app because it's unsigned, open the terminal in your Applications folder and run:",
      macosCmd: "xattr -r -d com.apple.quarantine Agent\\ Tunnel.app",
      devNote: "Developer Note: This app is free and open source. It is not officially signed by Apple as I will not pay for a developer account for a project that provides no financial benefit."
    }
  }
}[lang] || t.es;

const installCmd = "curl -sSL https://s.inled.es/agentunnel.sh | bash";
---

<Layout title="Agent Tunnel - Remote control for AI Agents" description={t.hero.subtitle}>
  <div class="claude-theme">
    <Header />
    
    <main>
      <!-- Hero Section -->
      <section class="hero">
        <div class="container">
          <div class="hero-content">
            <span class="overline">{t.hero.install}</span>
            <h1 class="display-title">{t.hero.title}</h1>
            <p class="body-large">{t.hero.subtitle}</p>
            <p class="hero-description">{t.hero.description}</p>
            
            <div class="install-block">
              <code class="mono-text">{installCmd}</code>
              <button class="copy-btn" data-copy={installCmd} aria-label="Copy">
                <i class="fa-regular fa-copy"></i>
              </button>
            </div>

            <div class="hero-actions">
              <a href="https://github.com/InledGroup/agent-tunnel" class="btn btn-terracotta">
                <i class="fa-brands fa-github"></i>
                {t.hero.cta}
              </a>
              <a href="#desktop-app" class="btn btn-outline">
                <i class="fa-solid fa-desktop"></i>
                {t.desktop.title}
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Desktop App Section -->
      <section id="desktop-app" class="desktop-app-section">
        <div class="container">
          <div class="desktop-card">
            <div class="desktop-header">
              <div class="title-with-badge">
                <h2 class="section-title">{t.desktop.title}</h2>
                <span class="beta-badge">{t.desktop.beta}</span>
              </div>
              <p class="body-standard">{t.desktop.subtitle}</p>
            </div>
            
            <div class="download-grid-main">
              <!-- macOS -->
              <div class="os-group">
                <div class="os-header">
                  <i class="fa-brands fa-apple"></i>
                  <span>{t.desktop.macos}</span>
                </div>
                <div class="arch-btns">
                  <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="btn-arch">{t.desktop.amd64}</a>
                  <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="btn-arch">{t.desktop.arm64}</a>
                </div>
                <div class="macos-notice">
                  <p>{t.desktop.macosNote}</p>
                  <div class="mini-cmd">
                    <code>{t.desktop.macosCmd}</code>
                  </div>
                </div>
              </div>

              <!-- Windows -->
              <div class="os-group">
                <div class="os-header">
                  <i class="fa-brands fa-windows"></i>
                  <span>{t.desktop.windows}</span>
                </div>
                <div class="arch-btns">
                  <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="btn-arch">{t.desktop.amd64}</a>
                  <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="btn-arch">{t.desktop.arm64}</a>
                </div>
              </div>

              <!-- Linux DEB -->
              <div class="os-group">
                <div class="os-header">
                  <i class="fa-brands fa-linux"></i>
                  <span>{t.desktop.linuxDeb}</span>
                </div>
                <div class="arch-btns">
                  <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="btn-arch">{t.desktop.amd64}</a>
                  <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="btn-arch">{t.desktop.arm64}</a>
                </div>
              </div>

              <!-- Linux RPM -->
              <div class="os-group">
                <div class="os-header">
                  <i class="fa-brands fa-linux"></i>
                  <span>{t.desktop.linuxRpm}</span>
                </div>
                <div class="arch-btns">
                  <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="btn-arch">{t.desktop.amd64}</a>
                  <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="btn-arch">{t.desktop.arm64}</a>
                </div>
              </div>
            </div>

            <div class="desktop-footer">
              <a href="https://github.com/InledGroup/agent-tunnel/releases/latest" class="latest-release-link">
                {t.desktop.latest} <i class="fa-solid fa-arrow-right"></i>
              </a>
              <div class="dev-explanation">
                <p>{t.desktop.devNote}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="features">
        <div class="container">
          <h2 class="section-title">{t.features.title}</h2>
          <div class="features-grid">
            <div class="feature-card">
              <div class="feature-icon"><i class="fa-solid fa-sync"></i></div>
              <h3 class="card-title">{t.features.sync.title}</h3>
              <p class="card-text">{t.features.sync.desc}</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon"><i class="fa-solid fa-terminal"></i></div>
              <h3 class="card-title">{t.features.sshOnly.title}</h3>
              <p class="card-text">{t.features.sshOnly.desc}</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon"><i class="fa-solid fa-key"></i></div>
              <h3 class="card-title">{t.features.noKeys.title}</h3>
              <p class="card-text">{t.features.noKeys.desc}</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon"><i class="fa-solid fa-layer-group"></i></div>
              <h3 class="card-title">{t.features.multi.title}</h3>
              <p class="card-text">{t.features.multi.desc}</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon"><i class="fa-solid fa-shield-halved"></i></div>
              <h3 class="card-title">{t.features.exclusion.title}</h3>
              <p class="card-text">{t.features.exclusion.desc}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Security Section (Dark) -->
      <section class="security dark-section">
        <div class="container">
          <div class="security-layout">
            <div class="security-text">
              <h2 class="section-title inverted">{t.security.title}</h2>
              <p class="body-standard inverted">{t.security.desc}</p>
            </div>
            <div class="security-grid">
              <div class="security-item">
                <h4 class="item-title inverted">{t.security.autoAuth}</h4>
                <p class="item-desc inverted">{t.security.autoAuthDesc}</p>
              </div>
              <div class="security-item">
                <h4 class="item-title inverted">{t.security.nativeSsh}</h4>
                <p class="item-desc inverted">{t.security.nativeSshDesc}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Compatibility Section -->
      <section class="compatibility">
        <div class="container">
          <div class="comp-header">
            <h2 class="section-title">{t.compatibility.title}</h2>
            <p class="body-standard">{t.compatibility.desc}</p>
          </div>
          <div class="logos-grid">
            <div class="logo-item">
              <span class="logo-name">Claude Code</span>
            </div>
            <div class="logo-item">
              <span class="logo-name">Gemini CLI</span>
            </div>
            <div class="logo-item">
              <span class="logo-name">Codex</span>
            </div>
            <div class="logo-item">
              <span class="logo-name">OpenCode</span>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  /* Claude-inspired Design System Variables */
  :root {
    --parchment: #f5f4ed;
    --near-black: #141413;
    --terracotta: #c96442;
    --ivory: #faf9f5;
    --warm-sand: #e8e6dc;
    --charcoal-warm: #4d4c48;
    --olive-gray: #5e5d59;
    --stone-gray: #87867f;
    --border-cream: #f0eee6;
    --dark-surface: #30302e;
    --warm-silver: #b0aea5;
    
    /* Typo Fallbacks */
    --serif: 'Georgia', serif;
    --sans: system-ui, -apple-system, sans-serif;
    --mono: 'ui-monospace', 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', monospace;
  }

  .claude-theme {
    background-color: var(--parchment);
    color: var(--near-black);
    font-family: var(--sans);
    line-height: 1.6;
    min-height: 100vh;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Typography Rules */
  .display-title {
    font-family: var(--serif);
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 500;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .section-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 2rem;
  }

  .card-title {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .body-large {
    font-size: 1.25rem;
    color: var(--olive-gray);
    margin-bottom: 1.5rem;
    max-width: 700px;
  }

  .body-standard {
    font-size: 1.1rem;
    color: var(--olive-gray);
  }

  .overline {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--terracotta);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .mono-text {
    font-family: var(--mono);
    font-size: 0.95rem;
  }

  /* Components */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.8rem 1.5rem;
    border-radius: 10px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }

  .btn-terracotta {
    background-color: var(--terracotta);
    color: var(--ivory);
  }

  .btn-terracotta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(201, 100, 66, 0.2);
    filter: brightness(1.1);
  }

  .btn-outline {
    background-color: transparent;
    border: 1px solid var(--border-cream);
    color: var(--olive-gray);
  }

  .btn-outline:hover {
    background-color: var(--ivory);
    border-color: var(--stone-gray);
    color: var(--near-black);
  }

  /* Desktop App Section */
  .desktop-app-section {
    padding: 60px 0 100px;
    background-color: var(--parchment);
  }

  .desktop-card {
    background: var(--ivory);
    border: 1px solid var(--border-cream);
    border-radius: 24px;
    padding: 3.5rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  .desktop-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .title-with-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .title-with-badge .section-title {
    margin-bottom: 0;
  }

  .beta-badge {
    background: var(--terracotta);
    color: var(--ivory);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    letter-spacing: 0.05em;
  }

  .download-grid-main {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .os-group {
    background: var(--parchment);
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid var(--border-cream);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    transition: all 0.2s ease;
  }

  .os-group:hover {
    border-color: var(--warm-sand);
    transform: translateY(-2px);
  }

  .os-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--serif);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--near-black);
  }

  .os-header i {
    font-size: 2rem;
    color: var(--terracotta);
  }

  .arch-btns {
    display: flex;
    gap: 0.75rem;
    width: 100%;
  }

  .btn-arch {
    flex: 1;
    text-align: center;
    padding: 0.6rem;
    background: var(--ivory);
    border: 1px solid var(--border-cream);
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--olive-gray);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-arch:hover {
    border-color: var(--terracotta);
    color: var(--terracotta);
    background: var(--ivory);
  }

  .desktop-footer {
    text-align: center;
    border-top: 1px solid var(--border-cream);
    padding-top: 2rem;
  }

  .latest-release-link {
    color: var(--stone-gray);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .latest-release-link:hover {
    color: var(--terracotta);
  }

  .macos-notice {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-cream);
    font-size: 0.75rem;
    color: var(--stone-gray);
    text-align: left;
    width: 100%;
  }

  .mini-cmd {
    background: var(--ivory);
    padding: 0.5rem;
    border-radius: 6px;
    margin-top: 0.5rem;
    font-family: var(--mono);
    word-break: break-all;
    border: 1px solid var(--border-cream);
    color: var(--near-black);
  }

  .dev-explanation {
    margin-top: 2rem;
    font-size: 0.8rem;
    color: var(--stone-gray);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.4;
    font-style: italic;
    text-align: center;
  }

  /* Sections */
  .hero {
    padding: 160px 0 100px;
    text-align: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-description {
    font-size: 1.1rem;
    color: var(--stone-gray);
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .install-block {
    background: var(--ivory);
    border: 1px solid var(--border-cream);
    padding: 1rem 1.5rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02);
  }

  .copy-btn {
    background: none;
    border: none;
    color: var(--stone-gray);
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s;
  }

  .copy-btn:hover {
    color: var(--terracotta);
  }

  /* Features */
  .features {
    padding: 100px 0;
    background-color: var(--ivory);
    border-top: 1px solid var(--border-cream);
    border-bottom: 1px solid var(--border-cream);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    margin-top: 4rem;
  }

  .feature-card {
    padding: 2.5rem;
    background: var(--parchment);
    border-radius: 16px;
    border: 1px solid var(--border-cream);
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.04);
    border-color: var(--warm-sand);
    transform: translateY(-4px);
  }

  .feature-icon {
    font-size: 1.5rem;
    color: var(--terracotta);
    margin-bottom: 1.5rem;
  }

  .card-text {
    color: var(--olive-gray);
    font-size: 1rem;
  }

  /* Security (Dark) */
  .dark-section {
    background-color: var(--near-black);
    color: var(--ivory);
    padding: 120px 0;
  }

  .inverted {
    color: var(--ivory) !important;
  }

  .security-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .security-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .security-item {
    border-left: 2px solid var(--terracotta);
    padding-left: 2rem;
  }

  .item-title {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .item-desc {
    color: var(--warm-silver);
    font-size: 1rem;
  }

  /* Compatibility */
  .compatibility {
    padding: 100px 0 160px;
    text-align: center;
  }

  .comp-header {
    margin-bottom: 5rem;
  }

  .logos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
    justify-items: center;
  }

  .logo-item {
    padding: 2rem;
    background: var(--ivory);
    border: 1px solid var(--border-cream);
    border-radius: 12px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .logo-item:hover {
    border-color: var(--terracotta);
    background: var(--parchment);
  }

  .logo-name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--charcoal-warm);
  }

  @media (max-width: 968px) {
    .security-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    
    .hero {
      padding: 120px 0 60px;
    }

    .install-block {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }
    
    .mono-text {
      word-break: break-all;
      font-size: 0.85rem;
    }
  }
</style>

<script is:inline>
  // Copy to clipboard functionality
  document.addEventListener('DOMContentLoaded', () => {
    const copyButtons = document.querySelectorAll('.copy-btn');
    
    copyButtons.forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = btn.getAttribute('data-copy');
        try {
          await navigator.clipboard.writeText(text);
          const icon = btn.querySelector('i');
          icon.classList.remove('fa-copy');
          icon.classList.add('fa-check');
          btn.style.color = 'var(--terracotta)';
          
          setTimeout(() => {
            icon.classList.remove('fa-check');
            icon.classList.add('fa-copy');
            btn.style.color = '';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy!', err);
        }
      });
    });
  });
</script>
