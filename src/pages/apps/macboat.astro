        cpu: "CPU: At least 4 CPU threads",
        storage: "Storage: At least 64 GB of free space",
        virtualization: "Virtualization: KVM enabled in BIOS/UEFI",
        macos: "Support: macOS 11 (Big Sur) to macOS 15 (Sequoia)"
      },
      container: {
        title: "Containerization",
        docker: "Docker Desktop is NOT supported. Use native Docker.",
        group: "User added to the docker group (relog required)",
        daemon: "Docker daemon is running"
      }
    },
    faq: {
      title: "Frequently Asked Questions",
      questions: [
        {
          q: "Is this like Winboat?",
