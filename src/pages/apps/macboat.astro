---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

const lang = getLangFromLocals(Astro.locals);

const app = {
  id: "macboat",
  title: "Macboat",
  logo: "https://hosted.inled.es/macboat.png",
  downloadUrl: "https://github.com/InledGroup/macboat/releases/latest",
  githubUrl: "https://github.com/InledGroup/macboat",
  releasesUrl: "https://github.com/InledGroup/macboat/releases/"
};

const translations = {
  es: {
    meta: {
      title: "Macboat | Run MacOS on Linux",
      description: "Run MacOS on x64 PC's, from 11 to 15 (upgradable to Tahoe). Downloads from official Apple servers"
    },
    hero: {
      title: "Run macOS on Linux",
      subtitle: "without headaches",
      download: "Download",
      contribute: "Contribute"
    },
    download: {
      title: "Choose your preferred architecture and format. Macboat is ready for action.",
      currentVersion: "Current version: v1.0.1",
      platforms: [
        { name: "Arch Linux", arch: "x86_64" },
        { name: "Debian / Ubuntu", arch: "amd64, arm64" },
        { name: "Fedora / RedHat", arch: "x86_64, aarch64" }
      ]
    },
    requirements: {
      title: "Pre-Requisites",
      subtitle: "Before running Macboat, make sure your system meets the requirements below.",
      items: [
        "RAM: At least 8 GB (16 GB Recommended)",
        "CPU: At least 4 CPU threads",
        "Storage: At least 64 GB of free space",
        "Virtualization: KVM enabled in BIOS/UEFI",
        "Support: macOS 11 (Big Sur) to macOS 15 (Sequoia)",
        "Docker: Native Docker installed (NOT Docker Desktop)",
        "Docker: User added to the docker group (relog required)",
        "Docker: Docker daemon is running"
      ]
    },
    faq: {
      title: "F.A.Q.",
      questions: [
        {
          q: "Is this like Winboat?",
          a: "No, there is no native integration yet. For now, it's just macOS with its full desktop."
        },
        {
          q: "Can I run Mac apps?",
          a: "Yes, you can install and run macOS applications within the virtualized environment."
        },
        {
          q: "Can I use shared directories?",
          a: "Yes, although we are still perfecting that feature and it may not work perfectly yet."
        },
        {
          q: "It doesn't install, I get an error",
          a: "If you experience issues during installation, we recommend trying an older macOS version."
        }
      ]
    },
    legal: {
      title: "EULA Legal Notice",
      content: "Macboat is a virtualization tool. Apple's EULA specifies that macOS should only be run on official Apple hardware. By using Macboat, you agree that you are solely responsible for complying with such terms."
    }
  },
  en: {
    meta: {
      title: "Macboat | Run macOS on Linux with seamless integration",
      description: "Experience macOS 11 to 15 on your Linux hardware with Macboat. Powerful, simple, and Docker-based."
    },
    hero: {
      title: "Run macOS on Linux",
      subtitle: "without headaches",
      download: "Download",
      contribute: "Contribute"
    },
    download: {
      title: "Choose your preferred architecture and format. Macboat is ready for action.",
      currentVersion: "Current version: v1.0.1",
      platforms: [
        { name: "Arch Linux", arch: "x86_64" },
        { name: "Debian / Ubuntu", arch: "amd64, arm64" },
        { name: "Fedora / RedHat", arch: "x86_64, aarch64" }
      ]
    },
    requirements: {
      title: "Pre-Requisites",
      subtitle: "Before running Macboat, make sure your system meets the requirements below.",
      items: [
        "RAM: At least 8 GB (16 GB Recommended)",
        "CPU: At least 4 CPU threads",
        "Storage: At least 64 GB of free space",
        "Virtualization: KVM enabled in BIOS/UEFI",
        "Support: macOS 11 (Big Sur) to macOS 15 (Sequoia)",
        "Docker: Native Docker installed (NOT Docker Desktop)",
        "Docker: User added to the docker group (relog required)",
        "Docker: Docker daemon is running"
      ]
    },
    faq: {
      title: "F.A.Q.",
      questions: [
        {
          q: "Is this like Winboat?",
          a: "No, there is no native integration yet. For now, it's just macOS with its full desktop."
        },
        {
          q: "Can I run Mac apps?",
          a: "Yes, you can install and run macOS applications within the virtualized environment."
        },
        {
          q: "Can I use shared directories?",
          a: "Yes, although we are still perfecting that feature and it may not work perfectly yet."
        },
        {
          q: "It doesn't install, I get an error",
          a: "If you experience issues during installation, we recommend trying an older macOS version."
        }
      ]
    },
    legal: {
      title: "EULA Legal Notice",
      content: "Macboat is a virtualization tool. Apple's EULA specifies that macOS should only be run on official Apple hardware. By using Macboat, you agree that you are solely responsible for complying with such terms."
    }
  }
};

const t = translations[lang] || translations.en;
---

<Layout title={t.meta.title} description={t.meta.description}>
  <Header />

  <div class="page">

    <main>

      <!-- Hero -->
      <section class="hero">
        <div class="hero-logo">
          <img src={app.logo} alt="Macboat" />
        </div>
        <h1 class="hero-title">
          {t.hero.title}
          <span class="hero-sub">{t.hero.subtitle}</span>
        </h1>
        <div class="hero-btns">
          <a href={app.downloadUrl} class="pill pill-white">
            <span class="pill-inner">
              <i class="fa-solid fa-download"></i>
              {t.hero.download}
            </span>
          </a>
          <a href={app.githubUrl} class="pill pill-dark">
            <span class="pill-inner">
              <i class="fa-brands fa-github"></i>
              {t.hero.contribute}
            </span>
          </a>
        </div>
      </section>

      <!-- Platforms -->
      <section class="platforms">
        <p class="platforms-text">{t.download.title}</p>
        <div class="platform-chips">
          {t.download.platforms.map((p) => (
            <div class="chip">
              <span class="chip-name">{p.name}</span>
              <span class="chip-arch">{p.arch}</span>
            </div>
          ))}
        </div>
        <p class="version">{t.download.currentVersion}</p>
      </section>

      <!-- Requirements -->
      <section class="requirements" id="requirements">
        <h2 class="section-title">{t.requirements.title}</h2>
        <p class="section-subtitle">{t.requirements.subtitle}</p>
        <ul class="req-list">
          {t.requirements.items.map((item) => (
            <li class="req-item">{item}</li>
          ))}
        </ul>
      </section>

      <!-- FAQ -->
      <section class="faq" id="faq">
        <h2 class="section-title">{t.faq.title}</h2>
        <div class="faq-list">
          {t.faq.questions.map((faq) => (
            <details class="faq-item">
              <summary class="faq-q">
                {faq.q}
              </summary>
              <div class="faq-a">
                <p>{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- Legal -->
      <section class="legal">
        <div class="legal-box">
          <span class="legal-icon"><i class="fa-solid fa-scale-balanced"></i></span>
          <p>{t.legal.content}</p>
        </div>
      </section>

    </main>

  </div>
</Layout>

<style is:global>
  body { background: #050505 !important; }
</style>

<style>
  /* ============================
     VARIABLES
     ============================ */
  :root {
    --fg: #ffffff;
    --fg-dim: rgba(255, 255, 255, 0.45);
    --fg-mid: rgba(255, 255, 255, 0.6);
    --bg: #0a0a0a;
    --surface: rgba(255, 255, 255, 0.04);
    --border: rgba(255, 255, 255, 0.08);
    --radius: 16px;
    --radius-pill: 9999px;
    --font: 'Ubuntu', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'Ubuntu Mono', 'Courier New', monospace;
    /* Inner shadow depth - the key visual element */
    --depth-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.5), inset 0 4px 12px rgba(0, 0, 0, 0.3);
    --depth-border: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ============================
     PAGE
     ============================ */
  .page {
    min-height: 100vh;
    background: var(--bg);
    padding-top: 90px;
    padding-bottom: 60px;
  }

  /* ============================
     HERO
     ============================ */
  .hero {
    text-align: center;
    padding: 60px 32px 48px;
  }

  .hero-logo {
    margin-bottom: 28px;
  }

  .hero-logo img {
    width: 110px;
    height: 110px;
    filter: drop-shadow(0 4px 24px rgba(255, 255, 255, 0.08));
    transition: filter 0.4s ease;
  }

  .hero-logo:hover img {
    filter: drop-shadow(0 4px 32px rgba(255, 255, 255, 0.14));
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--fg);
    letter-spacing: -0.02em;
  }

  .hero-sub {
    display: block;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 400;
    color: var(--fg-dim);
    margin-top: 6px;
  }

  .hero-btns {
    display: flex;
    justify-content: center;
    gap: 14px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  /* ============================
     PILLS
     ============================ */
  .pill {
    display: inline-flex;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-family: var(--font);
    font-size: 0.95rem;
    font-weight: 600;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.3s ease;
  }

  .pill:hover { transform: translateY(-2px); }

  .pill-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    position: relative;
    z-index: 2;
    border-radius: var(--radius-pill);
  }

  /* White: the exception */
  .pill-white {
    background: #fff;
    color: #0a0a0a;
    box-shadow: 0 2px 20px rgba(255, 255, 255, 0.1);
  }

  .pill-white:hover {
    box-shadow: 0 4px 30px rgba(255, 255, 255, 0.18);
  }

  .pill-white .pill-inner { color: #0a0a0a; }

  /* Dark: inner depth shadow */
  .pill-dark {
    background: #111;
    color: var(--fg);
    box-shadow: var(--depth-shadow);
    border: var(--depth-border);
  }

  .pill-dark:hover {
    box-shadow: var(--depth-shadow), 0 0 20px rgba(255, 255, 255, 0.04);
  }

  .pill-dark .pill-inner { color: var(--fg); }

  /* ============================
     DEPTH SURFACE (reusable)
     ============================ */
  .depth {
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: var(--radius);
  }

  /* ============================
     PLATFORMS
     ============================ */
  .platforms {
    padding: 32px 32px 40px;
    text-align: center;
  }

  .platforms-text {
    font-size: 0.95rem;
    color: var(--fg-mid);
    margin-bottom: 24px;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .platform-chips {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .chip {
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: 12px;
    padding: 14px 24px;
    text-align: center;
    transition: border-color 0.3s ease;
    min-width: 180px;
  }

  .chip:hover {
    border-color: rgba(255, 255, 255, 0.14);
  }

  .chip-name {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 3px;
  }

  .chip-arch {
    font-size: 0.78rem;
    color: var(--fg-dim);
    font-family: var(--font-mono);
  }

  .version {
    font-size: 0.75rem;
    color: var(--fg-dim);
    opacity: 0.5;
    margin-top: 8px;
  }

  /* ============================
     REQUIREMENTS
     ============================ */
  .requirements {
    padding: 48px 32px;
    text-align: center;
  }

  .section-title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .section-subtitle {
    font-size: 0.9rem;
    color: var(--fg-dim);
    margin-bottom: 36px;
    line-height: 1.5;
  }

  .req-list {
    list-style: none;
    padding: 0;
    max-width: 520px;
    margin: 0 auto;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .req-item {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--fg);
    padding: 12px 18px;
    line-height: 1.5;
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: 10px;
    transition: border-color 0.3s ease;
  }

  .req-item:hover {
    border-color: rgba(255, 255, 255, 0.14);
  }

  /* ============================
     FAQ
     ============================ */
  .faq {
    padding: 48px 32px;
    text-align: center;
  }

  .faq-list {
    max-width: 600px;
    margin: 28px auto 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .faq-item {
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .faq-item[open] {
    border-color: rgba(255, 255, 255, 0.14);
  }

  .faq-q {
    padding: 16px 20px;
    cursor: pointer;
    list-style: none;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--fg);
    transition: background 0.2s ease;
  }

  .faq-q:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-a {
    padding: 0 20px 18px;
  }

  .faq-a p {
    font-size: 0.88rem;
    color: var(--fg-mid);
    line-height: 1.6;
  }

  /* ============================
     LEGAL
     ============================ */
  .legal {
    padding: 32px 32px 48px;
  }

  .legal-box {
    max-width: 600px;
    margin: 0 auto;
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .legal-icon {
    font-size: 1rem;
    color: var(--fg-dim);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .legal-box p {
    font-size: 0.8rem;
    color: var(--fg-dim);
    line-height: 1.6;
  }

  /* ============================
     RESPONSIVE
     ============================ */
  @media (max-width: 768px) {
    .hero { padding: 40px 20px 32px; }

    .platforms,
    .requirements,
    .faq,
    .legal {
      padding-left: 20px;
      padding-right: 20px;
    }

    .platform-chips {
      flex-direction: column;
      align-items: center;
    }

    .chip { width: 100%; max-width: 280px; }

    .hero-btns {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
