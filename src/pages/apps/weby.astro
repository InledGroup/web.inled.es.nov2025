---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const app = {
  id: "weby",
  title: "Weby",
  logo: "https://hosted.inled.es/weby.gif",
  aiLogo: "https://hosted.inled.es/inledai.png",
  downloadUrl: "https://github.com/InledGroup/Weby-edgeai/releases/latest",
  githubUrl: "https://github.com/InledGroup/Weby-edgeai",
  videoUrl: "https://hosted.inled.es/demoweby.mp4"
};

const i18n = {
  es: {
    hero: {
      title: "Tu Copiloto de IA Local y Privado.",
      subtitle: "Una barra lateral inteligente que utiliza IA local pionera para resolver tus dudas acerca del sitio web que estás visitando. Privacidad total, rendimiento máximo.",
      badge: "IA Local Pionera"
    },
    features: {
      title: "Inteligencia que respeta tu privacidad",
      subtitle: "Weby no es solo una IA, es tu asistente personal que vive en tu navegador, no en la nube.",
      items: [
        { 
          name: "Privacidad Absoluta", 
          desc: "Tus datos y conversaciones nunca salen de tu dispositivo. Procesamiento 100% local.", 
          icon: "shield-check" 
        },
        { 
          name: "Análisis de Contexto", 
          desc: "Entiende profundamente el contenido de la web que visitas para darte respuestas precisas.", 
          icon: "brain-circuit" 
        },
        { 
          name: "Inled AI Technology", 
          desc: "Impulsado por el motor de IA local más avanzado desarrollado por Inled Group.", 
          icon: "zap" 
        },
        { 
          name: "Confidencialidad", 
          desc: "Funciona con datos sensibles sin riesgos. Nada de lo que veas se comparte externamente.", 
          icon: "lock" 
        }
      ]
    },
    inledAiFeatures: {
      title: "Todas las características de InledAI, en Weby",
      subtitle: "La potencia del motor InledAI integrada directamente en tu barra lateral para una experiencia sin límites.",
      items: [
        { name: "Soporte para MCPs personalizados", desc: "Integra Model Context Protocol para expandir las capacidades de la IA con herramientas y datos externos personalizados.", icon: "file-text" },
        { name: "Soporte para búsqueda web", desc: "Acceso inteligente a internet para contrastar datos y ofrecerte información actualizada al instante.", icon: "globe" },
        { name: "Ajuste fino de variables RAG", desc: "Control total sobre los parámetros internos del RAG (Top-K, temperatura, umbrales) en una UI sencilla e intuitiva.", icon: "settings-2" },
        { name: "Memoria IA", desc: "Capacidad de recordar contextos previos para mantener conversaciones coherentes y personalizadas a largo plazo.", icon: "brain" },
        { name: "Crea el Chatbot de tu Web", desc: "Genera un chatbot para tu propia web basado en el contenido que estás visitando, sin documentación adicional.", icon: "message-square" }
      ]
    },
    cta: {
      title: "Lleva la IA local a tu navegación",
      button: "Descargar Weby",
      github: "Explorar Código"
    }
  },
  en: {
    hero: {
      title: "Your Local and Private AI Copilot.",
      subtitle: "A smart sidebar using pioneering local AI to solve your doubts about the website you're visiting. Total privacy, maximum performance.",
      badge: "Pioneering Local AI"
    },
    features: {
      title: "Intelligence that respects your privacy",
      subtitle: "Weby isn't just an AI, it's your personal assistant that lives in your browser, not in the cloud.",
      items: [
        { 
          name: "Absolute Privacy", 
          desc: "Your data and conversations never leave your device. 100% local processing.", 
          icon: "shield-check" 
        },
        { 
          name: "Context Analysis", 
          desc: "Deeply understands the content of the web you're visiting to give you precise answers.", 
          icon: "brain-circuit" 
        },
        { 
          name: "Inled AI Technology", 
          desc: "Powered by the most advanced local AI engine developed by Inled Group.", 
          icon: "zap" 
        },
        { 
          name: "Confidentiality", 
          desc: "Works with sensitive data without risks. Nothing you see is shared externally.", 
          icon: "lock" 
        }
      ]
    },
    inledAiFeatures: {
      title: "All InledAI Features, in Weby",
      subtitle: "The power of the InledAI engine integrated directly into your sidebar for a boundless experience.",
      items: [
        { name: "Custom MCP Support", desc: "Integrate Model Context Protocol to expand AI capabilities with custom external tools and data.", icon: "file-text" },
        { name: "Web Search Support", desc: "Intelligent internet access to cross-reference data and provide instant updated information.", icon: "globe" },
        { name: "RAG Variables Tuning", desc: "Total control over internal RAG parameters (Top-K, temperature, thresholds) with a simple, intuitive UI.", icon: "settings-2" },
        { name: "AI Memory", desc: "Ability to remember previous contexts to maintain coherent and personalized conversations long-term.", icon: "brain" },
        { name: "Build your Web's Chatbot", desc: "Generate a chatbot for your own website based on the content you're visiting, with no extra documentation.", icon: "message-square" }
      ]
    },
    cta: {
      title: "Bring local AI to your browsing",
      button: "Download Weby",
      github: "Explore Code"
    }
  }
};
---

<Layout title="Weby - IA Local para tu Navegador - Inled Apps" description="Weby utiliza IA local pionera para resolver tus dudas acerca del sitio web que estás visitando con privacidad absoluta.">
  <div id="page-content" class="theme-dark">
    <Header />
    
    <main>
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="container">
          <div class="hero-content">
            <div class="badges-container fade-in">
              <span class="badge">{i18n.es.hero.badge}</span>
              <div class="ai-tech-badge">
                <img src={app.aiLogo} alt="Inled AI" class="badge-icon" />
                <span>Tecnología Inled AI</span>
              </div>
            </div>
            
            <div class="hero-logo-container fade-in">
              <img src={app.logo} alt="Weby Logo" class="main-logo-hero" />
            </div>

            <h1 class="fade-in delay-1" id="hero-title">{i18n.es.hero.title}</h1>
            <p class="fade-in delay-2" id="hero-subtitle">{i18n.es.hero.subtitle}</p>
          </div>
        </div>
      </section>

      <!-- Video Demo Section -->
      <section class="video-section" id="video-trigger">
        <div class="container">
           <div class="browser-mockup fade-up">
              <div class="browser-header">
                 <div class="dots">
                    <span class="dot"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                 </div>
                 <div class="address-bar">inled.es/apps/weby</div>
              </div>
              <div class="browser-content">
                 <video 
                   src={app.videoUrl} 
                   autoplay 
                   muted 
                   loop 
                   playsinline 
                   class="demo-video">
                 </video>
                 <div class="video-overlay"></div>
              </div>
           </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="features-section">
        <div class="container">
          <h2 class="section-title fade-up" id="features-title">{i18n.es.features.title}</h2>
          <p class="section-subtitle fade-up" id="features-subtitle">{i18n.es.features.subtitle}</p>
          
          <div class="features-grid">
            {i18n.es.features.items.map((item, index) => (
              <div class="feature-card fade-up" style={`--delay: ${index * 0.1}s`}>
                <div class="feature-icon">
                  {item.icon === 'shield-check' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>}
                  {item.icon === 'brain-circuit' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4.5V4M10.222 5.5l-.333-.333M15.5 10.222l.333-.333M15.5 13.778l.333.333M10.222 18.5l-.333.333M4 12H4.5M10.5 12h3M13.5 12l1.5-1.5M13.5 12l1.5 1.5M7 8l2 4-2 4M21 12H19.5"/><circle cx="12" cy="12" r="8"/></svg>}
                  {item.icon === 'zap' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14.5l10-10.5-2 8h8l-10 10.5 2-8z"/></svg>}
                  {item.icon === 'lock' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>}
                </div>
                <h3>{item.name}</h3>
                <p>{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- InledAI Features Section -->
      <section class="features-section inledai-features">
        <div class="container">
          <h2 class="section-title fade-up" id="inledai-features-title">{i18n.es.inledAiFeatures.title}</h2>
          <p class="section-subtitle fade-up" id="inledai-features-subtitle">{i18n.es.inledAiFeatures.subtitle}</p>
          
          <div class="features-grid centered-grid">
            {i18n.es.inledAiFeatures.items.map((item, index) => (
              <div class="feature-card fade-up" style={`--delay: ${index * 0.1}s`}>
                <div class="feature-icon ai-icon">
                  {item.icon === 'file-text' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>}
                  {item.icon === 'globe' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>}
                  {item.icon === 'settings-2' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>}
                  {item.icon === 'brain' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-2.54Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-2.54Z"/></svg>}
                  {item.icon === 'message-square' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>}
                </div>
                <h3>{item.name}</h3>
                <p>{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="cta-section">
        <div class="container">
          <div class="cta-card fade-up">
            <h2 id="cta-title">{i18n.es.cta.title}</h2>
            <div class="cta-actions">
              <a href={app.downloadUrl} class="btn-primary" id="cta-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                {i18n.es.cta.button}
              </a>
              <a href={app.githubUrl} target="_blank" rel="noopener noreferrer" class="btn-outline" id="github-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                {i18n.es.cta.github}
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style is:global>
  #page-content {
    --bg-color: #000000;
    --text-color: #ffffff;
    --accent-color: #00fefe;
    --muted-color: #a1a1a1;
    --card-bg: #0a0a0a;
    --border-color: rgba(0, 254, 254, 0.15);
    
    background-color: var(--bg-color);
    color: var(--text-color);
    min-height: 100vh;
    font-family: 'Ubuntu', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  body { background-color: #000000 !important; overflow-x: hidden; }

  #page-content :global(header) {
    background: transparent !important;
    backdrop-filter: blur(10px);
  }
</style>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  /* Hero Section */
  .hero-section {
    padding-top: 180px;
    padding-bottom: 80px;
    min-height: 90vh;
    display: flex;
    align-items: center;
    text-align: center;
  }

  .hero-content {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badges-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .badge {
    padding: 0.6rem 1.2rem;
    background: rgba(0, 254, 254, 0.1);
    color: var(--accent-color);
    border: 1px solid var(--border-color);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ai-tech-badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1.2rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 100px;
    font-size: 0.85rem;
    color: #fff;
    font-weight: 600;
    backdrop-filter: blur(5px);
  }

  .badge-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
  }

  .hero-logo-container {
    margin-bottom: 3rem;
  }

  .main-logo-hero {
    width: clamp(150px, 20vw, 240px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 50px rgba(0, 254, 254, 0.3));
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .main-logo-hero:hover {
    transform: scale(1.08) rotate(2deg);
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 4.8rem);
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 2rem;
    letter-spacing: -0.03em;
    background: linear-gradient(to bottom, #fff 60%, rgba(255,255,255,0.6));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  p {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--muted-color);
    line-height: 1.6;
    margin-bottom: 0;
    max-width: 700px;
  }

  /* Video Section */
  .video-section {
    padding: 4rem 0 8rem;
  }

  .browser-mockup {
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8), 0 0 40px rgba(0, 254, 254, 0.1);
    max-width: 1000px;
    margin: 0 auto;
  }

  .browser-header {
    background: #1a1a1a;
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dots {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
  }

  .address-bar {
    flex: 1;
    background: #0a0a0a;
    border-radius: 6px;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    color: var(--muted-color);
    text-align: center;
  }

  .browser-content {
    position: relative;
    aspect-ratio: 16/9;
    background: #000;
  }

  .demo-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.4), transparent);
    pointer-events: none;
  }

  /* Features Section */
  .features-section { padding: 8rem 0; text-align: center; }
  .section-title { font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; color: #fff; }
  .section-subtitle { margin-bottom: 4rem; color: var(--muted-color); max-width: 600px; margin-left: auto; margin-right: auto; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background: var(--card-bg);
    padding: 3rem 2rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    text-align: left;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .feature-card:hover {
    border-color: var(--border-color);
    background: rgba(0, 254, 254, 0.02);
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .feature-icon {
    width: 64px;
    height: 64px;
    background: rgba(0, 254, 254, 0.1);
    color: var(--accent-color);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .feature-card h3 { font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: #fff; }
  .feature-card p { font-size: 1rem; color: var(--muted-color); margin-bottom: 0; line-height: 1.5; }

  .inledai-features {
    background: linear-gradient(to bottom, transparent, rgba(0, 254, 254, 0.03), transparent);
    border-top: 1px solid rgba(0, 254, 254, 0.05);
    border-bottom: 1px solid rgba(0, 254, 254, 0.05);
  }

  .ai-icon {
    background: rgba(255, 255, 255, 0.05) !important;
    color: #fff !important;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .centered-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .centered-grid .feature-card {
    flex: 1 1 300px;
    max-width: 350px;
  }

  /* CTA Section */
  .cta-section { padding: 8rem 0; }
  .cta-card {
    background: linear-gradient(135deg, #00fefe 0%, #008080 100%);
    padding: 5rem 2rem;
    border-radius: 40px;
    text-align: center;
    color: #000;
    box-shadow: 0 30px 60px rgba(0, 254, 254, 0.2);
  }

  .cta-card h2 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; margin-bottom: 3rem; color: #000; }
  .cta-actions { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }

  .btn-primary, .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.1rem 2.5rem;
    border-radius: 100px;
    font-weight: 700;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    font-size: 1.05rem;
  }

  .btn-primary { background: #000; color: #fff; }
  .btn-primary:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.3); background: #111; }

  .btn-outline { border: 2.5px solid #000; color: #000; }
  .btn-outline:hover { background: rgba(0,0,0,0.05); transform: translateY(-4px); }

  /* Animations */
  .fade-in { opacity: 0; transform: translateY(20px); animation: fadeIn 1s forwards; }
  .fade-up { opacity: 0; transform: translateY(30px); transition: all 1s cubic-bezier(0.4, 0, 0.2, 1); }
  .fade-up.visible { opacity: 1; transform: translateY(0); }
  @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }
  .delay-1 { animation-delay: 0.2s; }
  .delay-2 { animation-delay: 0.4s; }

  @media (max-width: 768px) {
    .hero-section { padding-top: 140px; }
    .cta-card { padding: 4rem 1.5rem; border-radius: 30px; }
    .app-logos { gap: 1rem; }
    .app-logo { width: 70px; height: 70px; }
    .main-logo { width: 85px; height: 85px; }
  }
</style>

<script define:vars={{ app, i18n }}>
  function updateLang(lang) {
    const data = i18n[lang];
    if (!data) return;
    document.getElementById('hero-title').textContent = data.hero.title;
    document.getElementById('hero-subtitle').textContent = data.hero.subtitle;
    document.querySelector('.badge').textContent = data.hero.badge;
    document.getElementById('features-title').textContent = data.features.title;
    document.getElementById('features-subtitle').textContent = data.features.subtitle;
    
    // Update features grid
    const featureCards = document.querySelectorAll('.features-section:not(.inledai-features) .feature-card');
    data.features.items.forEach((item, i) => {
        if (featureCards[i]) {
            featureCards[i].querySelector('h3').textContent = item.name;
            featureCards[i].querySelector('p').textContent = item.desc;
        }
    });

    // Update InledAI features
    document.getElementById('inledai-features-title').textContent = data.inledAiFeatures.title;
    document.getElementById('inledai-features-subtitle').textContent = data.inledAiFeatures.subtitle;
    const inledAiCards = document.querySelectorAll('.inledai-features .feature-card');
    data.inledAiFeatures.items.forEach((item, i) => {
        if (inledAiCards[i]) {
            inledAiCards[i].querySelector('h3').textContent = item.name;
            inledAiCards[i].querySelector('p').textContent = item.desc;
        }
    });

    document.getElementById('cta-title').textContent = data.cta.title;
    document.getElementById('cta-btn').innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      ${data.cta.button}
    `;
    document.getElementById('github-btn').innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      ${data.cta.github}
    `;
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  updateLang(localStorage.getItem('preferred-lang') || 'es');
  window.addEventListener('langChanged', (e) => updateLang(e.detail.lang));
</script>