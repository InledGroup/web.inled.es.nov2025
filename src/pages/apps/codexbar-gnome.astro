                <div class="provider-logo-slot" title="OpenRouter"><svg  viewBox="0 0 512 512" fill="#ffff" stroke="#ffff"><g clip-path="url(#openrouter_dark__clip0_205_3)"><path d="M3 248.945C18 248.945 76 236 106 219C136 202 136 202 198 158C276.497 102.293 332 120.945 423 120.945" stroke-width="20"/><path d="M511 121.5L357.25 210.268L357.25 32.7324L511 121.5Z"/><path d="M0 249C15 249 73 261.945 103 278.945C133 295.945 133 295.945 195 339.945C273.497 395.652 329 377 420 377" stroke-width="20"/><path d="M508 376.445L354.25 287.678L354.25 465.213L508 376.445Z"/></g></svg></div>
            </div>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section class="features">
        <div class="container">
          <h2 class="section-title">{t.features.title}</h2>
          <div class="features-grid">
            <div class="feature-card">
              <div class="icon"><i class="fa-solid fa-terminal"></i></div>
              <h3>{t.features.cli.title}</h3>
              <p>{t.features.cli.desc}</p>
            </div>
            <div class="feature-card">
              <div class="icon"><i class="fa-solid fa-desktop"></i></div>
              <h3>{t.features.native.title}</h3>
              <p>{t.features.native.desc}</p>
            </div>
            <div class="feature-card">
              <div class="icon"><i class="fa-solid fa-microchip"></i></div>
              <h3>{t.features.providers.title}</h3>
              <p>{t.features.providers.desc}</p>

            </div>
          </div>
        </div>
      </section>

      <!-- Contribute -->
      <section class="contribute">
        <div class="container">
          <div class="contribute-content">
            <h2 class="section-title">{t.contribute.title}</h2>
            <p class="contribute-desc">{t.contribute.desc}</p>
            <div class="contribute-actions">
              <a href="https://github.com/InledGroup/codexbar-gnome" class="btn btn-primary">
                <i class="fa-brands fa-github"></i> {t.contribute.button}
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  :root {
    --gnome-bg: #242424;
    --gnome-fg: #eeeeee;
    --gnome-accent: #3584e4;
    --gnome-surface: #303030;
    --gnome-border: rgba(255, 255, 255, 0.1);
    --adwaita-blue: #3584e4;
    --adwaita-dark: #1e1e1e;
  }

  .gnome-page {
    background-color: #121212;
    color: white;
    min-height: 100vh;
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hero {
    padding: 140px 0 100px;
    background: radial-gradient(circle at top right, rgba(53, 132, 228, 0.1), transparent);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .app-icon {
    width: 100px;
    height: 100px;
    border-radius: 22px;
    margin-bottom: 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .title {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    background: linear-gradient(to bottom, #fff, #999);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: 1.5rem;
    color: var(--gnome-accent);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .description {
    font-size: 1.1rem;
    color: #aaa;
    max-width: 500px;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .actions {
    display: flex;
    gap: 1rem;
  }

  .btn {
    padding: 0.8rem 2rem;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--gnome-accent);
    color: white;
  }

  .btn-primary:hover {
    background: #4a91e9;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
  }

  /* GNOME Mockup */
  .simulation-container {
    perspective: 1000px;
  }

  .gnome-shell-mockup {
    width: 100%;
    aspect-ratio: 16/10;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 30px 60px rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.1);
    transform: rotateY(-5deg) rotateX(2deg);
    transition: transform 0.5s ease;
  }

  .gnome-shell-mockup:hover {
    transform: rotateY(0) rotateX(0);
  }

  .top-bar {
    height: 32px;
    background: #000;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 12px;
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    position: relative;
    z-index: 10;
  }

  .top-bar .right {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .gnome-icon {
    opacity: 0.8;
  }

  .extension-trigger {
    height: 24px;
    width: 24px;
    display: flex;
    align-items: center;
