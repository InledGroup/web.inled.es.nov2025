---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

const lang = getLangFromLocals(Astro.locals);

const translations = {
  es: {
    meta: {
      title: "CodexBar for GNOME | Monitor de IA en tu Escritorio",
      description: "Extensión de GNOME Shell para monitorizar el uso de proveedores de IA (OpenAI, Claude, Codex) directamente en tu barra de herramientas."
    },
    hero: {
      title: "CodexBar for GNOME",
      subtitle: "Tu consumo de IA, siempre a la vista.",
      description: "Lleva el control de tus tokens y costes de IA a la barra superior de Linux. Basado en codexbar-cli de steipete, diseñado para GNOME.",
      cta: "Instalar Extensión",
      secondaryCta: "Ver en GitHub"
    },
    simulation: {
      title: "Integración nativa",
      desc: "Haz clic en el icono para ver cómo se integra en tu GNOME Shell."
    },
    features: {
      title: "Diseñado para el flujo de trabajo moderno",
      cli: {
        title: "Basado en codexbar-cli",
        desc: "Aprovecha la potencia y estabilidad del CLI de Peter Steinberg para obtener datos precisos de tus proveedores."
      },
      native: {
        title: "Interfaz GNOME Nativa",
        desc: "Nada de terminales ni navegadores. Una interfaz limpia que sigue las líneas de diseño de Adwaita."
      },
      providers: {
        title: "Multi-proveedor",
        desc: "Soporte para todos los proveedores de CodexBar (steipete) accesibles vía API, incluyendo ahora soporte nativo para OpenAI Codex."
      }
    },
    roadmap: {
      title: "Próximamente",
      claude: {
        title: "Claude Code",
        desc: "Pronto podrás ver el uso de Claude Code directamente desde la extensión."
      },
      web: {
        title: "Codexbar CLI web-fetch",
        desc: "Estamos trabajando para portar completamente la experiencia de Codexbar de Macos para ser 100% usable en Linux."
      }
    }
  },
  en: {
    meta: {
      title: "CodexBar for GNOME | AI Monitor on your Desktop",
      description: "GNOME Shell extension to monitor AI provider usage (OpenAI, Claude, Codex) directly on your toolbar."
    },
    hero: {
      title: "CodexBar for GNOME",
      subtitle: "Your AI consumption, always in sight.",
      description: "Track your AI tokens and costs in the Linux top bar. Based on steipete's codexbar-cli, designed for GNOME.",
      cta: "Install Extension",
      secondaryCta: "View on GitHub"
    },
    simulation: {
      title: "Native Integration",
      desc: "Click on the icon to see how it integrates into your GNOME Shell."
    },
    features: {
      title: "Designed for the modern workflow",
      cli: {
        title: "Based on codexbar-cli",
        desc: "Take advantage of the power and stability of Peter Steinberg's CLI to obtain accurate data from your suppliers."
      },
      native: {
        title: "Native GNOME Interface",
        desc: "No terminals or browsers. A clean interface that follows Adwaita design guidelines."
      },
      providers: {
        title: "Multi-provider",
        desc: "Support for all CodexBar (steipete) providers accessible via API, now including native support for OpenAI Codex."
      }
    },
    roadmap: {
      title: "Coming Soon",
      claude: {
        title: "Claude Code",
        desc: "Soon you'll be able to see Claude Code usage directly from the extension."
      },
      web: {
        title: "Codexbar CLI web-fetch",
        desc: "We are working to port the complete Codexbar experience from Macos to be 100% usable on Linux."
      }
    }
  }
};

const t = translations[lang] || translations.es;
---

<Layout title={t.meta.title} description={t.meta.description}>
  <div class="gnome-page">
    <Header />
    
    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="container">
          <div class="hero-grid">
            <div class="hero-text">
              <div class="app-icon-wrapper">
                <img src="https://hosted.inled.es/codexbar-logo.png" alt="CodexBar Logo" class="app-icon" />
              </div>
              <h1 class="title">{t.hero.title}</h1>
              <p class="subtitle">{t.hero.subtitle}</p>
              <p class="description">{t.hero.description}</p>
              <div class="actions">
                <a href="https://extensions.gnome.org/extension/9841/codexbar/" class="btn btn-primary">{t.hero.cta}</a>
                <a href="https://github.com/jaimegh-es/codexbar-gnome" class="btn btn-secondary">{t.hero.secondaryCta}</a>
              </div>
            </div>

            <!-- GNOME Shell Simulation -->
            <div class="simulation-container">
              <div class="gnome-shell-mockup">
                <div class="top-bar">
                  <div class="left">Actividades</div>
                  <div class="center">May 6 12:45</div>
                  <div class="right">
                    <div class="gnome-icon"><i class="fa-solid fa-wifi"></i></div>
                    <div class="gnome-icon"><i class="fa-solid fa-volume-high"></i></div>
                    <div class="gnome-icon"><i class="fa-solid fa-battery-full"></i></div>
                    <!-- The Extension Icon -->
                    <div class="extension-trigger active" id="extension-trigger">
                      <img src="https://hosted.inled.es/codexbar-logo.png" alt="AI" />
                    </div>
                  </div>
                </div>
                
                <!-- The Dropdown Menu (Cloned from Image) -->
                <div class="extension-menu" id="extension-menu">
                  <div class="popup-header">
                    <span class="popup-title">CodexBar</span>
                    <div class="popup-icons">
                      <i class="fa-solid fa-rotate-right"></i>
                      <i class="fa-solid fa-screwdriver-wrench"></i>
                    </div>
                  </div>

                  <div class="popup-tabs">
                    <div class="tab">Codex</div>
                    <div class="tab active">Gemini</div>
                  </div>

                  <div class="popup-content">
                    <div class="provider-info">
                      <h3 class="provider-title">Gemini</h3>
                      <p class="provider-status">user@inled.es (Paid)</p>
                      <p class="last-updated">Updated 18:44</p>
                    </div>

                    <div class="usage-section">
                      <div class="model-row">
                        <span class="model-name">Pro</span>
                        <div class="progress-bar-container">
                          <div class="progress-bar" style="width: 94.7%;"></div>
                        </div>
                        <div class="model-stats">
                          <span class="left-pct">94.7% left</span>
                          <span class="reset-time">Resets in 22h 42m</span>
                        </div>
                      </div>

                      <div class="model-row">
                        <span class="model-name">Flash</span>
                        <div class="progress-bar-container">
                          <div class="progress-bar" style="width: 82.4%;"></div>
                        </div>
                        <div class="model-stats">
                          <span class="left-pct">82.4% left</span>
                          <span class="reset-time">Resets in 21h 1m</span>
                        </div>
                      </div>

                      <div class="model-row">
                        <span class="model-name">Flash Lite</span>
                        <div class="progress-bar-container">
                          <div class="progress-bar" style="width: 95.6%;"></div>
                        </div>
                        <div class="model-stats">
                          <span class="left-pct">95.6% left</span>
                          <span class="reset-time">Resets in 21h 1m</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="desktop-wallpaper"></div>
              </div>
              <p class="simulation-hint">{t.simulation.desc}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section class="features">
        <div class="container">
          <h2 class="section-title">{t.features.title}</h2>
          <div class="features-grid">
            <div class="feature-card">
              <div class="icon"><i class="fa-solid fa-terminal"></i></div>
              <h3>{t.features.cli.title}</h3>
              <p>{t.features.cli.desc}</p>
            </div>
            <div class="feature-card">
              <div class="icon"><i class="fa-solid fa-desktop"></i></div>
              <h3>{t.features.native.title}</h3>
              <p>{t.features.native.desc}</p>
            </div>
            <div class="feature-card">
              <div class="icon"><i class="fa-solid fa-microchip"></i></div>
              <h3>{t.features.providers.title}</h3>
              <p>{t.features.providers.desc}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Roadmap -->
      <section class="roadmap">
        <div class="container">
          <h2 class="section-title">{t.roadmap.title}</h2>
          <div class="roadmap-grid">
            <div class="roadmap-item">
              <div class="badge">PROXIMAMENTE</div>
              <h3>{t.roadmap.claude.title}</h3>
              <p>{t.roadmap.claude.desc}</p>
            </div>
            <div class="roadmap-item">
              <div class="badge">EXCLUSIVO</div>
              <h3>{t.roadmap.web.title}</h3>
              <p>{t.roadmap.web.desc}</p>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  :root {
    --gnome-bg: #242424;
    --gnome-fg: #eeeeee;
    --gnome-accent: #3584e4;
    --gnome-surface: #303030;
    --gnome-border: rgba(255, 255, 255, 0.1);
    --adwaita-blue: #3584e4;
    --adwaita-dark: #1e1e1e;
  }

  .gnome-page {
    background-color: #121212;
    color: white;
    min-height: 100vh;
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hero {
    padding: 140px 0 100px;
    background: radial-gradient(circle at top right, rgba(53, 132, 228, 0.1), transparent);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .app-icon {
    width: 100px;
    height: 100px;
    border-radius: 22px;
    margin-bottom: 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .title {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    background: linear-gradient(to bottom, #fff, #999);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: 1.5rem;
    color: var(--gnome-accent);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .description {
    font-size: 1.1rem;
    color: #aaa;
    max-width: 500px;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .actions {
    display: flex;
    gap: 1rem;
  }

  .btn {
    padding: 0.8rem 2rem;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--gnome-accent);
    color: white;
  }

  .btn-primary:hover {
    background: #4a91e9;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
  }

  /* GNOME Mockup */
  .simulation-container {
    perspective: 1000px;
  }

  .gnome-shell-mockup {
    width: 100%;
    aspect-ratio: 16/10;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 30px 60px rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.1);
    transform: rotateY(-5deg) rotateX(2deg);
    transition: transform 0.5s ease;
  }

  .gnome-shell-mockup:hover {
    transform: rotateY(0) rotateX(0);
  }

  .top-bar {
    height: 32px;
    background: #000;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 12px;
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    position: relative;
    z-index: 10;
  }

  .top-bar .right {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .gnome-icon {
    opacity: 0.8;
  }

  .extension-trigger {
    height: 24px;
    width: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .extension-trigger:hover, .extension-trigger.active {
    background: rgba(255,255,255,0.15);
  }

  .extension-trigger img {
    width: 16px;
    height: 16px;
  }

  .desktop-wallpaper {
    position: absolute;
    top: 32px;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('https://hosted.inled.es/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.7);
  }

  /* Extension Menu (Cloned from Image) */
  .extension-menu {
    position: absolute;
    top: 40px;
    right: 8px;
    width: 280px;
    background: #2d2d2d;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.6);
    z-index: 100;
    padding: 16px;
    display: none;
    color: #eeeeee;
    text-align: left;
  }

  .extension-menu.show {
    display: block;
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .popup-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .popup-title {
    font-size: 14px;
    font-weight: 500;
    opacity: 0.95;
  }

  .popup-icons {
    display: flex;
    gap: 14px;
    font-size: 14px;
    opacity: 0.9;
  }

  .popup-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: 24px;
  }

  .tab {
    padding: 4px 12px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
    color: rgba(255,255,255,0.8);
  }

  .tab.active {
    background: #454545;
    color: white;
    font-weight: 700;
  }

  .provider-info {
    margin-bottom: 16px;
  }

  .provider-title {
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 4px;
    color: #fff;
  }

  .provider-status {
    font-size: 11px;
    color: #999;
    margin-bottom: 2px;
    font-weight: 400;
  }

  .last-updated {
    font-size: 11px;
    color: #777;
    margin-bottom: 0;
  }

  .usage-section {
    display: flex;
    flex-direction: column;
    gap: 14px;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 16px;
  }

  .model-name {
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 6px;
    display: block;
    color: #fff;
  }

  .progress-bar-container {
    height: 6px;
    background: #3d3d3d;
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .progress-bar {
    height: 100%;
    background: #3584e4;
    border-radius: 3px;
  }

  .model-stats {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: #888;
    font-weight: 400;
  }

  .simulation-hint {
    text-align: center;
    margin-top: 1.5rem;
    color: #666;
    font-size: 0.9rem;
  }

  /* Features */
  .features {
    padding: 100px 0;
    background: #0a0a0a;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 4rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    padding: 3rem;
    background: #161616;
    border: 1px solid #222;
    border-radius: 24px;
    transition: all 0.3s;
  }

  .feature-card:hover {
    border-color: var(--gnome-accent);
    transform: translateY(-5px);
  }

  .feature-card .icon {
    font-size: 2rem;
    color: var(--gnome-accent);
    margin-bottom: 1.5rem;
  }

  .feature-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .feature-card p {
    color: #888;
    line-height: 1.6;
  }

  /* Roadmap */
  .roadmap {
    padding: 100px 0 140px;
  }

  .roadmap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .roadmap-item {
    padding: 2rem;
    background: linear-gradient(135deg, #1e1e1e, #121212);
    border-radius: 20px;
    border: 1px solid #333;
  }

  .roadmap-item .badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: rgba(53, 132, 228, 0.1);
    color: var(--gnome-accent);
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .roadmap-item h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .roadmap-item p {
    color: #777;
    font-size: 0.95rem;
  }

  @media (max-width: 968px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-text {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .title {
      font-size: 3rem;
    }

    .description {
      margin: 0 auto 2.5rem auto;
    }

    .simulation-container {
      margin-top: 3rem;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('extension-trigger');
    const menu = document.getElementById('extension-menu');
    const tabs = document.querySelectorAll('.tab');
    
    // Start with menu visible for the simulation "wow" effect
    setTimeout(() => {
      menu.classList.add('show');
    }, 1000);

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('show');
      trigger.classList.toggle('active');
    });

    document.addEventListener('click', () => {
      menu.classList.remove('show');
      trigger.classList.remove('active');
    });

    menu.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    // Tab switching simulation
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        
        const providerTitle = menu.querySelector('.provider-title');
        const providerStatus = menu.querySelector('.provider-status');
        const usageSection = menu.querySelector('.usage-section');

        if (tab.textContent === 'Codex') {
          providerTitle.textContent = 'Codex';
          providerStatus.textContent = 'codex-api-key (Active)';
          usageSection.style.opacity = '0.5'; // Simulate loading/different view
          setTimeout(() => { usageSection.style.opacity = '1'; }, 200);
        } else {
          providerTitle.textContent = 'Gemini';
          providerStatus.textContent = 'user@inled.es (Paid)';
          usageSection.style.opacity = '1';
        }
      });
    });
  });
</script>
