---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

const lang = getLangFromLocals(Astro.locals);

const translations = {
  es: {
    meta: {
      title: "CodexBar for GNOME | Monitor de IA en tu Escritorio",
      description: "Extensión de GNOME Shell para monitorizar el uso de proveedores de IA (OpenAI, Claude, Codex, Gemini, OpenRouter) directamente en tu barra de herramientas."
    },
    hero: {
      title: "CodexBar for GNOME",
      subtitle: "Tu consumo de IA, siempre a la vista.",
      description: "Lleva el control de tus tokens y costes de IA a la barra superior de Linux. Basado en codexbar-cli de steipete, diseñado para GNOME.",
      cta: "Instalar Extensión",
      secondaryCta: "Ver en GitHub"
    },
    simulation: {
      title: "Integración nativa",
      desc: "Haz clic en el icono para ver cómo se integra en tu GNOME Shell."
    },
    features: {
      title: "Diseñado para el flujo de trabajo moderno",
      cli: {
        title: "Basado en codexbar-cli",
        desc: "Aprovecha la potencia y estabilidad del CLI de Peter Steinberg para obtener datos precisos de tus proveedores."
      },
      native: {
        title: "Interfaz GNOME Nativa",
        desc: "Nada de terminales ni navegadores. Una interfaz limpia que sigue las líneas de diseño de Adwaita."
      },
      providers: {
        title: "Multi-proveedor",
        desc: "Soporta todos los proveedores que Codexbar CLI soporta, entre ellos Claude, Codex, Gemini, OpenRouter..."
      },
      supportedProviders: "Soporta, entre otros muchos:"
    },
    contribute: {
      title: "Proyecto Comunitario",
      desc: "CodexBar for GNOME es de código abierto. ¡Te invitamos a contribuir para seguir mejorando la experiencia de IA en Linux!",
      button: "Contribuir en GitHub"
    }
  },
  en: {
    meta: {
      title: "CodexBar for GNOME | AI Monitor on your Desktop",
      description: "GNOME Shell extension to monitor AI provider usage (OpenAI, Claude, Codex, Gemini, OpenRouter) directly on your toolbar."
    },
    hero: {
      title: "CodexBar for GNOME",
      subtitle: "Your AI consumption, always in sight.",
      description: "Track your AI tokens and costs in the Linux top bar. Based on steipete's codexbar-cli, designed for GNOME.",
      cta: "Install Extension",
      secondaryCta: "View on GitHub"
    },
    simulation: {
      title: "Native Integration",
      desc: "Click on the icon to see how it integrates into your GNOME Shell."
    },
    features: {
      title: "Designed for the modern workflow",
      cli: {
        title: "Based on codexbar-cli",
        desc: "Take advantage of the power and stability of Peter Steinberg's CLI to obtain accurate data from your suppliers."
      },
      native: {
        title: "Native GNOME Interface",
        desc: "No terminals or browsers. A clean interface that follows Adwaita design guidelines."
      },
      providers: {
        title: "Multi-provider",
        desc: "Supports all providers supported by Codexbar CLI, including Claude, Codex, Gemini, OpenRouter..."
      },
      supportedProviders: "Supports, among many others:"
    },
    contribute: {
      title: "Community Project",
      desc: "CodexBar for GNOME is open source. We invite you to contribute and help us improve the AI experience on Linux!",
      button: "Contribute on GitHub"
    }
  }
};

const t = translations[lang] || translations.es;
---

<Layout title={t.meta.title} description={t.meta.description}>
  <div class="gnome-page">
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="container">
          <div class="hero-grid">
            <div class="hero-text">
              <div class="app-icon-wrapper">
                <img src="https://hosted.inled.es/codexbar-logo.png" alt="CodexBar Logo" class="app-icon" />
              </div>
              <h1 class="title">{t.hero.title}</h1>
              <p class="subtitle">{t.hero.subtitle}</p>
              <p class="description">{t.hero.description}</p>
              <div class="actions">
                <a href="https://extensions.gnome.org/extension/9841/codexbar/" class="btn btn-primary">
                  <span class="gnome-btn-icon">
                      <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor"><path d="M19.703 0c-4.99 0-5.927 7.111-3.12 7.111 2.81 0 8.113-7.111 3.12-7.111M11.99.872q-.119-.001-.25.016c-2.811.364-1.82 5.25-.324 5.34 1.449.09 3.032-5.347.574-5.356M7.123 2.803a1.4 1.4 0 0 0-.488.114c-2.259.933-.344 4.776.921 4.519 1.168-.24 1.319-4.671-.433-4.632Zm-3.6 3.016a1.05 1.05 0 0 0-.634.215c-1.807 1.248.607 4.269 1.671 3.799.93-.41.338-3.967-1.037-4.014m10.032 2.309c-3.835.033-8.716 1.978-9.567 5.784C3.044 18.14 7.875 24 12.915 24c2.48 0 5.34-2.24 5.875-5.077.409-2.163-4.81-1.295-4.623.137.225 1.715-1.258 2.561-2.711 1.454-4.623-3.52 7.658-5.276 6.847-10.086-.263-1.56-2.29-2.322-4.748-2.301Z"/></svg>
                  </span>
                  {t.hero.cta}
                </a>
                <a href="https://github.com/InledGroup/codexbar-gnome" class="btn btn-secondary">{t.hero.secondaryCta}</a>
              </div>
            </div>

            <!-- GNOME Shell Simulation -->
            <div class="simulation-container">
              <div class="gnome-shell-mockup">
                <div class="top-bar">
                  <div class="left">Actividades</div>
                  <div class="center">May 6 12:45</div>
                  <div class="right">
                    <div class="gnome-icon"><i class="fa-solid fa-wifi"></i></div>
                    <div class="gnome-icon"><i class="fa-solid fa-volume-high"></i></div>
                    <div class="gnome-icon"><i class="fa-solid fa-battery-full"></i></div>
                    <!-- The Extension Icon -->
                    <div class="extension-trigger active" id="extension-trigger">
                      <img src="https://hosted.inled.es/codexbar-logo.png" alt="AI" />
                    </div>
                  </div>
                </div>

                <!-- The Dropdown Menu (Cloned from Image) -->
                <div class="extension-menu" id="extension-menu">
                  <div class="popup-header">
                    <span class="popup-title">CodexBar</span>
                    <div class="popup-icons">
                      <i class="fa-solid fa-rotate-right"></i>
                      <i class="fa-solid fa-screwdriver-wrench"></i>
                    </div>
                  </div>

                  <div class="popup-tabs">
                    <div class="tab">Codex</div>
                    <div class="tab active">Gemini</div>
                  </div>

                  <div class="popup-content">
                    <div class="provider-info">
                      <h3 class="provider-title">Gemini</h3>
                      <p class="provider-status">user@inled.es (Paid)</p>
                      <p class="last-updated">Updated 18:44</p>
                    </div>

                    <div class="usage-section">
                      <div class="model-row">
                        <span class="model-name">Pro</span>
                        <div class="progress-bar-container">
                          <div class="progress-bar" style="width: 94.7%;"></div>
                        </div>
                        <div class="model-stats">
                          <span class="left-pct">94.7% left</span>
                          <span class="reset-time">Resets in 22h 42m</span>
                        </div>
                      </div>

                      <div class="model-row">
                        <span class="model-name">Flash</span>
                        <div class="progress-bar-container">
                          <div class="progress-bar" style="width: 82.4%;"></div>
                        </div>
                        <div class="model-stats">
                          <span class="left-pct">82.4% left</span>
                          <span class="reset-time">Resets in 21h 1m</span>
                        </div>
                      </div>

                      <div class="model-row">
                        <span class="model-name">Flash Lite</span>
                        <div class="progress-bar-container">
                          <div class="progress-bar" style="width: 95.6%;"></div>
                        </div>
                        <div class="model-stats">
                          <span class="left-pct">95.6% left</span>
                          <span class="reset-time">Resets in 21h 1m</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="desktop-wallpaper"></div>
              </div>
              <p class="simulation-hint">{t.simulation.desc}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Mini Hero: Providers -->
      <section class="mini-hero">
        <div class="container">
          <div class="mini-hero-content">
            <h2 class="mini-hero-title">{t.supportedProviders}</h2>
            <div class="provider-logos-mini">
                <div class="provider-logo-slot" title="Claude"><svg  preserveAspectRatio="xMidYMid" viewBox="0 0 256 257"><path fill="#D97757" d="m50.228 170.321 50.357-28.257.843-2.463-.843-1.361h-2.462l-8.426-.518-28.775-.778-24.952-1.037-24.175-1.296-6.092-1.297L0 125.796l.583-3.759 5.12-3.434 7.324.648 16.202 1.101 24.304 1.685 17.629 1.037 26.118 2.722h4.148l.583-1.685-1.426-1.037-1.101-1.037-25.147-17.045-27.22-18.017-14.258-10.37-7.713-5.25-3.888-4.925-1.685-10.758 7-7.713 9.397.649 2.398.648 9.527 7.323 20.35 15.75L94.817 91.9l3.889 3.24 1.555-1.102.195-.777-1.75-2.917-14.453-26.118-15.425-26.572-6.87-11.018-1.814-6.61c-.648-2.723-1.102-4.991-1.102-7.778l7.972-10.823L71.42 0 82.05 1.426l4.472 3.888 6.61 15.101 10.694 23.786 16.591 32.34 4.861 9.592 2.592 8.879.973 2.722h1.685v-1.556l1.36-18.211 2.528-22.36 2.463-28.776.843-8.1 4.018-9.722 7.971-5.25 6.222 2.981 5.12 7.324-.713 4.73-3.046 19.768-5.962 30.98-3.889 20.739h2.268l2.593-2.593 10.499-13.934 17.628-22.036 7.778-8.749 9.073-9.657 5.833-4.601h11.018l8.1 12.055-3.628 12.443-11.342 14.388-9.398 12.184-13.48 18.147-8.426 14.518.778 1.166 2.01-.194 30.46-6.481 16.462-2.982 19.637-3.37 8.88 4.148.971 4.213-3.5 8.62-20.998 5.184-24.628 4.926-36.682 8.685-.454.324.519.648 16.526 1.555 7.065.389h17.304l32.21 2.398 8.426 5.574 5.055 6.805-.843 5.184-12.962 6.611-17.498-4.148-40.83-9.721-14-3.5h-1.944v1.167l11.666 11.406 21.387 19.314 26.767 24.887 1.36 6.157-3.434 4.86-3.63-.518-23.526-17.693-9.073-7.972-20.545-17.304h-1.36v1.814l4.73 6.935 25.017 37.59 1.296 11.536-1.814 3.76-6.481 2.268-7.13-1.297-14.647-20.544-15.1-23.138-12.185-20.739-1.49.843-7.194 77.448-3.37 3.953-7.778 2.981-6.48-4.925-3.436-7.972 3.435-15.749 4.148-20.544 3.37-16.333 3.046-20.285 1.815-6.74-.13-.454-1.49.194-15.295 20.999-23.267 31.433-18.406 19.702-4.407 1.75-7.648-3.954.713-7.064 4.277-6.286 25.47-32.405 15.36-20.092 9.917-11.6-.065-1.686h-.583L44.07 198.125l-12.055 1.555-5.185-4.86.648-7.972 2.463-2.593 20.35-13.992z"/></svg></div>
                <div class="provider-logo-slot" title="OpenAI"><svg  fill="#fff" fill-rule="evenodd" style="flex:none;line-height:1" viewBox="0 0 24 24"><title>Codex</title><path clip-rule="evenodd" d="M8.086.457a6.105 6.105 0 013.046-.415c1.333.153 2.521.72 3.564 1.7a.117.117 0 00.107.029c1.408-.346 2.762-.224 4.061.366l.063.03.154.076c1.357.703 2.33 1.77 2.918 3.198.278.679.418 1.388.421 2.126a5.655 5.655 0 01-.18 1.631.167.167 0 00.04.155 5.982 5.982 0 011.578 2.891c.385 1.901-.01 3.615-1.183 5.14l-.182.22a6.063 6.063 0 01-2.934 1.851.162.162 0 00-.108.102c-.255.736-.511 1.364-.987 1.992-1.199 1.582-2.962 2.462-4.948 2.451-1.583-.008-2.986-.587-4.21-1.736a.145.145 0 00-.14-.032c-.518.167-1.04.191-1.604.185a5.924 5.924 0 01-2.595-.622 6.058 6.058 0 01-2.146-1.781c-.203-.269-.404-.522-.551-.821a7.74 7.74 0 01-.495-1.283 6.11 6.11 0 01-.017-3.064.166.166 0 00.008-.074.115.115 0 00-.037-.064 5.958 5.958 0 01-1.38-2.202 5.196 5.196 0 01-.333-1.589 6.915 6.915 0 01.188-2.132c.45-1.484 1.309-2.648 2.577-3.493.282-.188.55-.334.802-.438.286-.12.573-.22.861-.304a.129.129 0 00.087-.087A6.016 6.016 0 015.635 2.31C6.315 1.464 7.132.846 8.086.457zm-.804 7.85a.848.848 0 00-1.473.842l1.694 2.965-1.688 2.848a.849.849 0 001.46.864l1.94-3.272a.849.849 0 00.007-.854l-1.94-3.393zm5.446 6.24a.849.849 0 000 1.695h4.848a.849.849 0 000-1.696h-4.848z"/></svg></div>
