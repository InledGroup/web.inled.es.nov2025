          </div>
        </div>
      </section>

      <!-- Setup -->
      <section class="setup">
        <h2 class="section-title">{t.setup.title}</h2>
        <div class="setup-grid">
          {t.setup.items.map((s) => (
            <div class="setup-card">
              <div class="setup-head">
                <span class="setup-provider">{s.provider}</span>
                <span class="setup-name">{s.name}</span>
              </div>
              <code class="setup-cmd">{s.cmd}</code>
              <p class="setup-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Contribute -->
      <section class="contribute">
        <h2 class="section-title">{t.contribute.title}</h2>
        <p class="contribute-desc">{t.contribute.desc}</p>
        <div class="contributors">
          <img src="https://avatars.githubusercontent.com/u/3518684?s=64&v=4" alt="Contributor" class="avatar" />
          <img src="https://avatars.githubusercontent.com/u/802826?s=64&v=4" alt="Contributor" class="avatar" />
          <img src="https://avatars.githubusercontent.com/u/4976355?s=64&v=4" alt="Contributor" class="avatar" />
          <img src="https://avatars.githubusercontent.com/u/265568982?s=64&v=4" alt="Contributor" class="avatar" />
        </div>
        <a href="https://github.com/InledGroup/codexbar-gnome" class="pill pill-dark" style="margin-top: 24px;">
          <span class="pill-inner">
            <i class="fa-brands fa-github"></i>
            {t.contribute.button}
          </span>
        </a>
      </section>

      <!-- Review -->
      <section class="review">
        <p>{t.reviewers.title}</p>
      </section>

    </main>
  </div>
</Layout>

<style is:global>
  body { background: #0a0a0a !important; }
</style>

<style>
  :root {
    --fg: #ffffff;
    --fg-dim: rgba(255, 255, 255, 0.45);
    --fg-mid: rgba(255, 255, 255, 0.6);
    --bg: #0a0a0a;
    --surface: rgba(255, 255, 255, 0.04);
    --border: rgba(255, 255, 255, 0.08);
    --accent: #3584e4;
    --depth-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.5), inset 0 4px 12px rgba(0, 0, 0, 0.3);
    --depth-border: 1px solid rgba(255, 255, 255, 0.06);
    --radius: 10px;
    --radius-pill: 9999px;
  }

  .page {
    min-height: 100vh;
    background: var(--bg);
    padding-top: 72px;
    padding-bottom: 60px;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--fg);
    text-align: center;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .section-subtitle {
    text-align: center;
    color: var(--fg-dim);
    font-size: 0.9rem;
    margin-bottom: 32px;
  }

  /* ============================
     PILLS
     ============================ */
  .pill {
    display: inline-flex;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.3s ease;
  }

  .pill:hover { transform: translateY(-2px); }

  .pill-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    position: relative;
    z-index: 2;
    border-radius: var(--radius-pill);
  }

  .pill-accent {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 2px 20px rgba(53, 132, 228, 0.2);
  }

  .pill-accent:hover {
    box-shadow: 0 4px 30px rgba(53, 132, 228, 0.3);
  }

  .pill-accent .pill-inner { color: #fff; }

  .pill-dark {
    background: #111;
    color: var(--fg);
    box-shadow: var(--depth-shadow);
    border: var(--depth-border);
  }

  .pill-dark:hover {
    box-shadow: var(--depth-shadow), 0 0 20px rgba(255, 255, 255, 0.04);
  }

  .pill-dark .pill-inner { color: var(--fg); }

  /* ============================
     HERO
     ============================ */
  .hero {
    padding: 48px 32px 56px;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-logo {
    width: 72px;
    height: 72px;
    margin-bottom: 20px;
    filter: drop-shadow(0 4px 20px rgba(53, 132, 228, 0.3));
  }

  .hero-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .hero-desc {
    font-size: 0.95rem;
    color: var(--fg-mid);
    line-height: 1.6;
    max-width: 520px;
    margin-bottom: 28px;
  }

  .hero-btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ============================
     FEATURES
     ============================ */
  .features {
    padding: 64px 32px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .features .section-title { margin-bottom: 32px; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px;
  }

  .feature-card {
    padding: 24px;
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: var(--radius);
    transition: border-color 0.3s ease;
  }

  .feature-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 6px;
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--fg-mid);
    line-height: 1.5;
  }

  /* ============================
     PROVIDERS
     ============================ */
  .providers {
    padding: 56px 32px;
    text-align: center;
  }

  .providers-label {
    font-size: 0.8rem;
    color: var(--fg-dim);
    margin-bottom: 16px;
  }

  .provider-logos {
    display: flex;
    gap: 24px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .provider-slot {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: var(--radius);
    transition: border-color 0.3s ease, transform 0.2s ease;
  }

  .provider-slot:hover {
    border-color: rgba(255, 255, 255, 0.14);
    transform: translateY(-2px);
  }

  .provider-slot svg {
    width: 28px;
    height: 28px;
  }

  .provider-initial {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--fg-dim);
  }

  /* ============================
     SETUP
     ============================ */
  .setup {
    padding: 56px 32px;
    max-width: 800px;
    margin: 0 auto;
  }

  .setup .section-title { margin-bottom: 32px; }

  .setup-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .setup-card {
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: var(--radius);
    padding: 20px 24px;
    transition: border-color 0.3s ease;
  }

  .setup-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
  }

  .setup-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .setup-provider {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .setup-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--fg);
  }

  .setup-cmd {
    display: block;
    font-family: 'Ubuntu Mono', 'Courier New', monospace;
    font-size: 0.82rem;
    color: var(--fg);
    background: rgba(0, 0, 0, 0.3);
    padding: 10px 14px;
    border-radius: 6px;
    margin-bottom: 10px;
    overflow-x: auto;
    box-shadow: inset 0 1px 4px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.04);
  }

  .setup-desc {
    font-size: 0.82rem;
    color: var(--fg-mid);
    line-height: 1.5;
  }

  /* ============================
     CONTRIBUTE
     ============================ */
  .contribute {
    padding: 56px 32px;
    text-align: center;
  }

  .contribute-desc {
    font-size: 0.95rem;
    color: var(--fg-mid);
    margin-bottom: 24px;
  }

  .contributors {
    display: flex;
    justify-content: center;
    gap: 12px;
  }

  .avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.1);
    transition: border-color 0.3s ease, transform 0.2s ease;
  }

  .avatar:hover {
    border-color: rgba(255, 255, 255, 0.3);
    transform: scale(1.1);
  }

  /* ============================
     REVIEW
     ============================ */
  .review {
    padding: 32px;
    text-align: center;
  }

  .review p {
    font-size: 0.82rem;
    color: var(--fg-dim);
    font-style: italic;
  }

  /* ============================
     RESPONSIVE
     ============================ */
  @media (max-width: 900px) {
    .hero {
      padding: 32px 20px 40px;
    }

    .features,
    .setup {
      padding-left: 20px;
      padding-right: 20px;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>


