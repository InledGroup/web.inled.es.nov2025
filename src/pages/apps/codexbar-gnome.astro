---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

const lang = getLangFromLocals(Astro.locals);

const translations = {
  es: {
    meta: {
      title: "CodexBar for GNOME | AI Usage",
      description: "GNOME Shell extension to monitor AI provider usage directly on your Gnome Shell."
    },
    hero: {
      title: "CodexBar for GNOME",
      description: "Visualiza el consumo de tokens, usage restante y gasto económico de tus proveedores de IA. Destacado en el repo oficial de Codexbar",
      cta: "Instalar Extension",
      secondaryCta: "Ver en GitHub"
    },
    features: {
      title: "Funciones",
      items: [
        { title: "Multiples proveedores", desc: "Codexbar soporta casi todos los proveedores que soporta Codexbar CLI. Puedes tener multiples proveedores y cambiar entre ellos cómodamente" },
        { title: "Todas las ventanas de uso", desc: "Cada proveedor de IA tiene su modelo de billing y Codexbar los soporta perfectamente" },
        { title: "Cuando se reinicia", desc: "Puedes ver cuanto queda para que se te reinicie el contador de uso" },
        { title: "Consumido / restante", desc: "Barra de progreso con lo que se ha gastado y lo que queda disponible." },
        { title: "Prediccion de uso", desc: "Analiza tu patron de uso y predice si te van a ser suficientes tokens o se te van a acabar" },
        { title: "Por tu bolsillo", desc: "Mira cuanta fortuna te estás dejando en tokens ;)" }
      ]
    },
    providers: {
      title: "Proveedores",
      subtitle: "Soporta todos los que soporta codexbar-cli.",
      featured: "Los siguientes proveedores han sido probados y su compatibilidad asegurada"
    },
    setup: {
      title: "Herramientas recomendadas",
      items: [
        {
          name: "Importador de cookies de autenticación de Codex",
          provider: "Codex",
          cmd: "pip install codexbar-cookie-importer",
          desc: "Para extraer la cookie de autenticacion de Codex facilmente."
        },
        {
          name: "Herramienta para configurar el certificado autofirmado de AGY como confiable",
          provider: "Antigravity",
          cmd: "pip install codexbar-ssl-helper",
          desc: "Para que codexbar cli confie en el certificado autofirmado del lenguage server."
        }
      ]
    },
    contribute: {
      title: "Anímate a contribuir!",
      desc: "Tenemos unos fantásticos contribuidores y las PR's e issues se revisan en menos de un día, ¡anímate! Da igual si usas IA o no, lee la guía de contribución y comienza!",
      button: "Llévame al repo!"
    },
    reviewers: {
      title: "Revisado por el fantástico JustPerfection en EGO, asegurando la máxima calidad y compatibilidad parta tu Gnome Shell."
    }
  },
  en: {
    meta: {
      title: "CodexBar for GNOME | AI Usage",
      description: "GNOME Shell extension to monitor AI provider usage directly on your Gnome Shell."
    },
    hero: {
      title: "CodexBar for GNOME",
      description: "Visualize token consumption, remaining usage and economic cost of your AI providers. Featured in the official Codexbar repo.",
      cta: "Install Extension",
      secondaryCta: "View on GitHub"
    },
    features: {
      title: "Features",
      items: [
        { title: "Multiple providers", desc: "Codexbar supports almost every provider that Codexbar CLI supports. You can have multiple providers and switch between them comfortably." },
        { title: "All usage windows", desc: "Each AI provider has its own billing model and Codexbar handles them perfectly." },
        { title: "When it resets", desc: "See how long until your usage counter resets." },
        { title: "Used / remaining", desc: "Progress bar showing what's been spent and what's left." },
        { title: "Usage prediction", desc: "Analyzes your usage pattern and predicts whether your tokens will last or run out." },
        { title: "For your wallet", desc: "See how much fortune you're leaving in tokens ;)" }
      ]
    },
    providers: {
      title: "Providers",
      subtitle: "Supports all providers supported by codexbar-cli.",
      featured: "The following providers have been tested and their compatibility guaranteed."
    },
    setup: {
      title: "Recommended tools",
      items: [
        {
          name: "Codex authentication cookie importer",
          provider: "Codex",
          cmd: "pip install codexbar-cookie-importer",
          desc: "To easily extract the Codex authentication cookie."
        },
        {
          name: "Tool to set AGY's self-signed certificate as trusted",
          provider: "Antigravity",
          cmd: "pip install codexbar-ssl-helper",
          desc: "So codexbar cli trusts the self-signed certificate of the language server."
        }
      ]
    },
    contribute: {
      title: "Get involved!",
      desc: "We have some fantastic contributors and PRs and issues are reviewed in less than a day, get involved! Whether you use AI or not, read the contribution guide and get started!",
      button: "Take me to the repo!"
    },
    reviewers: {
      title: "Reviewed by the fantastic JustPerfection on EGO, ensuring maximum quality and compatibility for your Gnome Shell."
    }
  }
};

const t = translations[lang] || translations.es;
---

<Layout title={t.meta.title} description={t.meta.description}>
  <Header />

  <div class="page">
    <main>

      <!-- Hero -->
      <section class="hero">
        <div class="hero-content">
          <img src="https://hosted.inled.es/codexbar-logo.png" alt="CodexBar" class="hero-logo" />
          <h1 class="hero-title">{t.hero.title}</h1>
          <p class="hero-desc">{t.hero.description}</p>
          <div class="hero-btns">
            <a href="https://extensions.gnome.org/extension/9841/codexbar/" class="pill pill-accent">
              <span class="pill-inner">
                <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" width="18" height="18"><path d="M19.703 0c-4.99 0-5.927 7.111-3.12 7.111 2.81 0 8.113-7.111 3.12-7.111M11.99.872q-.119-.001-.25.016c-2.811.364-1.82 5.25-.324 5.34 1.449.09 3.032-5.347.574-5.356M7.123 2.803a1.4 1.4 0 0 0-.488.114c-2.259.933-.344 4.776.921 4.519 1.168-.24 1.319-4.671-.433-4.632Zm-3.6 3.016a1.05 1.05 0 0 0-.634.215c-1.807 1.248.607 4.269 1.671 3.799.93-.41.338-3.967-1.037-4.014m10.032 2.309c-3.835.033-8.716 1.978-9.567 5.784C3.044 18.14 7.875 24 12.915 24c2.48 0 5.34-2.24 5.875-5.077.409-2.163-4.81-1.295-4.623.137.225 1.715-1.258 2.561-2.711 1.454-4.623-3.52 7.658-5.276 6.847-10.086-.263-1.56-2.29-2.322-4.748-2.301Z"/></svg>
                {t.hero.cta}
              </span>
            </a>
            <a href="https://github.com/InledGroup/codexbar-gnome" class="pill pill-dark">
              <span class="pill-inner">
                <i class="fa-brands fa-github"></i>
                {t.hero.secondaryCta}
              </span>
            </a>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section class="features" id="features">
        <h2 class="section-title">{t.features.title}</h2>
        <div class="features-grid">
          {t.features.items.map((f) => (
            <div class="feature-card">
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Providers -->
      <section class="providers">
        <h2 class="section-title">{t.providers.title}</h2>
        <p class="section-subtitle">{t.providers.subtitle}</p>
        <p class="providers-label">{t.providers.featured}</p>
        <div class="provider-logos">
          <div class="provider-slot" title="Antigravity">
           <svg  viewBox="0 0 16 15" fill="none" {...Astro.props}><mask id="antigravity__mask0_111_52" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0"><path d="M14.0777 13.984C14.945 14.6345 16.2458 14.2008 15.0533 13.0084C11.476 9.53949 12.2349 0 7.79033 0C3.34579 0 4.10461 9.53949 0.527295 13.0084C-0.773543 14.3092 0.635692 14.6345 1.50293 13.984C4.86344 11.7076 4.64663 7.69664 7.79033 7.69664C10.934 7.69664 10.7172 11.7076 14.0777 13.984Z" fill="black"/></mask><g mask="url(#antigravity__mask0_111_52)"><g filter="url(#antigravity__filter0_f_111_52)"><path d="M-0.658907 -3.2306C-0.922679 -0.906781 1.07986 1.22861 3.81388 1.53894C6.54791 1.84927 8.97811 0.217009 9.24188 -2.10681C9.50565 -4.43063 7.50312 -6.56602 4.76909 -6.87635C2.03506 -7.18667 -0.395135 -5.55442 -0.658907 -3.2306Z" fill="#FFE432"/></g><g filter="url(#antigravity__filter1_f_111_52)"><path d="M9.88233 4.36642C10.5673 7.31568 13.566 9.13902 16.5801 8.43896C19.5942 7.73891 21.4823 4.78056 20.7973 1.83131C20.1123 -1.11795 17.1136 -2.94128 14.0995 -2.24123C11.0854 -1.54118 9.19733 1.41717 9.88233 4.36642Z" fill="#FC413D"/></g><g filter="url(#antigravity__filter2_f_111_52)"><path d="M-8.05291 6.34512C-7.18736 9.38883 -3.28925 10.9473 0.653774 9.82598C4.5968 8.7047 7.09158 5.32829 6.22603 2.28458C5.36048 -0.759142 1.46236 -2.31758 -2.48066 -1.19629C-6.42368 -0.0750048 -8.91846 3.3014 -8.05291 6.34512Z" fill="#00B95C"/></g><g filter="url(#antigravity__filter3_f_111_52)"><path d="M-8.05291 6.34512C-7.18736 9.38883 -3.28925 10.9473 0.653774 9.82598C4.5968 8.7047 7.09158 5.32829 6.22603 2.28458C5.36048 -0.759142 1.46236 -2.31758 -2.48066 -1.19629C-6.42368 -0.0750048 -8.91846 3.3014 -8.05291 6.34512Z" fill="#00B95C"/></g><g filter="url(#antigravity__filter4_f_111_52)"><path d="M-4.92402 8.86746C-2.75421 11.0837 0.982691 10.9438 3.42257 8.55507C5.86246 6.1663 6.08139 2.43321 3.91158 0.216963C1.74177 -1.99928 -1.99513 -1.85942 -4.43501 0.529349C-6.87489 2.91812 -7.09383 6.65122 -4.92402 8.86746Z" 