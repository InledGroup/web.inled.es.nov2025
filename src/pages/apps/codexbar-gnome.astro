<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.getElementById('extension-trigger');
    const menu = document.getElementById('extension-menu');
    const tabs = document.querySelectorAll('.tab');

    // Start with menu visible for the simulation "wow" effect
    setTimeout(() => {
      menu.classList.add('show');
    }, 1000);

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('show');
      trigger.classList.toggle('active');
    });

    document.addEventListener('click', () => {
      menu.classList.remove('show');
      trigger.classList.remove('active');
    });

    menu.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    // Tab switching simulation
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const providerTitle = menu.querySelector('.provider-title');
        const providerStatus = menu.querySelector('.provider-status');
        const usageSection = menu.querySelector('.usage-section');

        if (tab.textContent === 'Codex') {
          providerTitle.textContent = 'Codex';
          providerStatus.textContent = 'codex-api-key (Active)';
          usageSection.style.opacity = '0.5'; // Simulate loading/different view
          setTimeout(() => { usageSection.style.opacity = '1'; }, 200);
        } else {
          providerTitle.textContent = 'Gemini';
          providerStatus.textContent = 'user@inled.es (Paid)';
          usageSection.style.opacity = '1';
        }
      });
    });
  });
</script>
