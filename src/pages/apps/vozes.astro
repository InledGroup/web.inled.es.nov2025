        "feat_6_desc": "Choose from Tiny, Base, Small, or Medium. Find the perfect balance between accuracy and performance for your machine.",
        "feat_7_title": "Customizable Hotkey",
        "feat_7_desc": "Set any key combination to activate dictation: F12, Ctrl+Shift, or whatever works best for your workflow.",
        "how_title": "As simple as speaking",
        "step_1_title": "Activate with a key",
        "step_1_desc": "Press F12 (or your preferred key) to start listening. No menus, no distractions.",
        "step_2_title": "Or use your voice",
        "step_2_desc": "Simply say \"Hey Jarvis\" and Vozes will start transcribing your words instantly.",
        "step_3_title": "Finish and done",
        "step_3_desc": "Press the activation key again and Vozes will finish typing for you.",
        "visual_listening": "Vozes is listening...",
        "visual_typing": "Writing your thoughts letter by letter...",
        "demo_key": "F12",
        "demo_voice": "Hey Jarvis",
        "demo_silence": "Silence",
        "demo_listening": "Listening...",
        "demo_transcribing": "Transcribing...",
        "demo_typing": "Writing to system...",
        "demo_done": "✓ Done",
        "demo_waiting_key": "Waiting for F12...",
        "demo_waiting_voice": "Waiting for 'Hey Jarvis'...",
        "demo_detected_key": "Detected: F12",
        "demo_detected_silence": "Detected: Silence",
        "cta_title": "Start writing with your voice",
        "cta_desc": "Download Vozes for Linux and discover the freedom of private voice typing.",
        "cta_btn": "Download from GitHub",
        "cta_meta": "Ready for Arch Linux, Debian, and Fedora. Works on Wayland and X11. Free. Comes with 4 model sizes to choose the best one for your PC.",
        "footer_by": "Vozes by Inled Group",
