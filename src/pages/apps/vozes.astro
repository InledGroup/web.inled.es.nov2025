const t = translations[lang];

const logo = "https://hosted.inled.es/vozes.png";
const video = "https://hosted.inled.es/vozesdemo.mp4";
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title id="page-title">{t.title}</title>
    <meta name="description" id="page-description" content={t.description}>
    <link rel="icon" href={logo} type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar">
        <div class="container nav-content">
            <a href="/" class="logo">
                <img src={logo} alt="Vozes Logo">
                <span>Vozes</span>
            </a>
            <div class="nav-links">
                <a href="#features">{t.nav_features}</a>
                <a href="#how-it-works">{t.nav_how}</a>
                <button id="lang-switch" class="btn-icon" aria-label="Cambiar idioma" data-current-lang={lang}>
                    <i class="fa-solid fa-globe"></i>
                    <span>{lang === 'es' ? 'ES' : 'EN'}</span>
                </button>
                <a href="#download" class="btn-primary small">{t.nav_download}</a>
            </div>
        </div>
    </nav>

    <main>
        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-bg"></div>
            <div class="container hero-content">
                <div class="hero-text fade-up">
                    <div class="app-badge">{t.hero_badge}</div>
                    <h1 data-i18n-html="true" set:html={t.hero_title}></h1>
                    <p>{t.hero_desc}</p>
                    <div class="hero-buttons">
                        <a href="#download" class="btn-primary">{t.hero_btn_start}</a>
                        <a href="#features" class="btn-secondary">{t.hero_btn_more}</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Video Section -->
        <section class="video-section">
            <div class="container">
                <div class="video-container fade-up">
                    <video 
                        src={video} 
                        controls 
                        autoplay 
                        muted 
                        loop 
                        poster={logo}
                    ></video>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section id="features" class="features">
            <div class="container">
                <h2 class="section-title fade-up">{t.feat_section_title}</h2>
                <div class="features-grid">
                    <div class="feature-card fade-up">
                        <div class="icon-box">
                            <i class="fa-solid fa-shield-heart"></i>
                        </div>
                        <h3>{t.feat_1_title}</h3>
                        <p>{t.feat_1_desc}</p>
                    </div>
                    <div class="feature-card fade-up">
                        <div class="icon-box">
                            <i class="fa-solid fa-bolt"></i>
                        </div>
                        <h3>{t.feat_2_title}</h3>
                        <p>{t.feat_2_desc}</p>
                    </div>
                    <div class="feature-card fade-up">
                        <div class="icon-box">
                            <i class="fa-solid fa-keyboard"></i>
                        </div>
                        <h3>{t.feat_3_title}</h3>
                        <p>{t.feat_3_desc}</p>
                    </div>
                    <div class="feature-card fade-up">
                        <div class="icon-box">
                            <i class="fa-solid fa-universal-access"></i>
                        </div>
                        <h3>{t.feat_4_title}</h3>
                        <p>{t.feat_4_desc}</p>
                    </div>
                    <div class="feature-card fade-up">
                        <div class="icon-box">
                            <i class="fa-solid fa-ear-listen"></i>
                        </div>
                        <h3>{t.feat_5_title}</h3>
                        <p>{t.feat_5_desc}</p>
                    </div>
                    <div class="feature-card fade-up">
                        <div class="icon-box">
                            <i class="fa-solid fa-microchip"></i>
                        </div>
                        <h3>{t.feat_6_title}</h3>
                        <p>{t.feat_6_desc}</p>
                    </div>
                    <div class="feature-card fade-up">
                        <div class="icon-box">
                            <i class="fa-solid fa-keyboard"></i>
                        </div>
                        <h3>{t.feat_7_title}</h3>
                        <p>{t.feat_7_desc}</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- How it works -->
        <section id="how-it-works" class="how-it-works">
            <div class="container">
                <div class="content-split">
                    <div class="text-side fade-up">
                        <h2 class="section-title align-left">{t.how_title}</h2>
                        <div class="steps-list">
                            <div class="step-item">
                                <div class="step-icon">F12</div>
                                <div class="step-info">
                                    <h3>{t.step_1_title}</h3>
                                    <p>{t.step_1_desc}</p>
                                </div>
                            </div>
                            <div class="step-item">
                                <div class="step-icon"><i class="fa-solid fa-microphone"></i></div>
                                <div class="step-info">
                                    <h3>{t.step_2_title}</h3>
                                    <p set:html={t.step_2_desc}></p>
                                </div>
                            </div>
                            <div class="step-item">
                                <div class="step-icon"><i class="fa-solid fa-check"></i></div>
                                <div class="step-info">
                                    <h3>{t.step_3_title}</h3>
                                    <p>{t.step_3_desc}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="image-side fade-up">
                        <div id="demo-i18n"
                            data-key={t.demo_key}
                            data-voice={t.demo_voice}
                            data-silence={t.demo_silence}
                            data-listening={t.demo_listening}
                            data-transcribing={t.demo_transcribing}
                            data-typing={t.demo_typing}
                            data-done={t.demo_done}
                            data-waiting-key={t.demo_waiting_key}
                            data-waiting-voice={t.demo_waiting_voice}
                            data-detected-key={t.demo_detected_key}
                            data-detected-silence={t.demo_detected_silence}
                            style="display:none"
                        ></div>
                        <div class="demo-card" id="demo-card">
                            <div class="demo-overlap">
                                <div class="card-wave">
                                    <div class="card-wave-head">
                                        <span class="w-dot"></span>
                                        <span class="w-dot"></span>
                                        <span class="w-dot"></span>
                                        <span class="w-label" id="demo-status">Vozes</span>
                                    </div>
                                    <div class="card-wave-body">
                                        <div id="demo-siri-container"></div>
                                        <div class="demo-phrase" id="demo-transcription"></div>
                                    </div>
                                </div>
                                <div class="demo-cli">
                                    <span class="cli-dollar">$</span>
                                    <span id="demo-typed-text"></span>
                                    <span class="cli-cursor" id="demo-cursor">▊</span>
                                </div>
                            </div>
                            <div class="demo-nav">
                                <span class="nav-dot active"></span>
                                <span class="nav-dot"></span>
                                <span class="nav-dot"></span>
                                <span class="nav-dot"></span>
                                <span class="nav-info" id="mode-trigger"></span>
                                <span class="nav-arrow">→</span>
                                <span class="nav-info" id="mode-stop"></span>
                            </div>
                            <div class="demo-pop" id="trigger-overlay"></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA / Download -->
        <section id="download" class="cta-section">
            <div class="container">
                <div class="cta-box fade-up">
                    <h2>{t.cta_title}</h2>
                    <p>{t.cta_desc}</p>
                    <div class="cta-buttons">
                        <a href="https://github.com/InledGroup/vozes/releases/latest" class="btn-primary big">
                            <i class="fa-brands fa-github"></i> <span>{t.cta_btn}</span>
                        </a>
                        <p class="meta-info">{t.cta_meta}</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container footer-content">
            <div class="footer-logo">
                <img src={logo} alt="Vozes Logo">
                <span>{t.footer_by}</span>
            </div>
            <p>{t.footer_love}</p>
            <div class="socials">
                <a href="https://github.com/InledGroup/vozes"><i class="fa-brands fa-github"></i></a>
            </div>
        </div>
    </footer>

    <script is:inline>
        // Language selector logic (sets cookie globally)
        const langSwitch = document.getElementById('lang-switch');
        if (langSwitch) {
            langSwitch.addEventListener('click', () => {
                const currentLang = langSwitch.getAttribute('data-current-lang');
                const newLang = currentLang === 'es' ? 'en' : 'es';
                
                // Set cookie for the whole site
                document.cookie = `preferred-lang=${newLang}; path=/; max-age=${60*60*24*365}; SameSite=Lax`;
                localStorage.setItem('preferred-lang', newLang);
                
                // Reload to apply changes server-side
                window.location.reload();
            });
        }

        // Scroll Animation Observer
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-up').forEach(el => {
            observer.observe(el);
        });

        // Smooth Scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const targetId = this.getAttribute('href');
                if (targetId) {
                    document.querySelector(targetId)?.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            });
        });

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                navbar?.classList.add('scrolled');
            } else {
                navbar?.classList.remove('scrolled');
            }
        });
    </script>

    <script is:inline src="https://unpkg.com/siriwave/dist/siriwave.umd.min.js"></script>
    <script is:inline>
        var siriWave = new SiriWave({
            container: document.getElementById("demo-siri-container"),
            width: 450,
            height: 65,
            style: "ios9",
            amplitude: 0.8,
            speed: 0.15,
            autostart: true,
            lerpSpeed: 0.05,
            curveDefinition: [
                { color: "255,138,101", supportLine: true },
                { color: "244,81,30" },
                { color: "255,138,101" },
                { color: "255,112,67" },
            ]
        });

        var _i18n = document.getElementById('demo-i18n').dataset;
        var _key = _i18n.key;
        var _voice = _i18n.voice;
        var _silence = _i18n.silence;
        var _listening = _i18n.listening;
        var _transcribing = _i18n.transcribing;
        var _typing = _i18n.typing;
        var _done = _i18n.done;
        var _waitingKey = _i18n.waitingKey;
        var _waitingVoice = _i18n.waitingVoice;
        var _detectedKey = _i18n.detectedKey;
        var _detectedSilence = _i18n.detectedSilence;

        var modes = [
            { trigger: _key, triggerIcon: 'keyboard', stop: _key, stopIcon: 'keyboard', phrase: 'Hola, esto es una prueba de escritura por voz.' },
            { trigger: _voice, triggerIcon: 'microphone', stop: _silence, stopIcon: 'volume-off', phrase: 'Vozes funciona en local, sin internet y con total privacidad.' },
            { trigger: _key, triggerIcon: 'keyboard', stop: _silence, stopIcon: 'volume-off', phrase: 'Tu privacidad está garantizada. Todo queda en tu ordenador.' },
            { trigger: _voice, triggerIcon: 'microphone', stop: _key, stopIcon: 'keyboard', phrase: 'Compatible con cualquier aplicaci\u00f3n de tu sistema Linux.' }
        ];

        var currentMode = 0;
        var charIndex = 0;
        var glassEl = document.getElementById('demo-transcription');
        var typedEl = document.getElementById('demo-typed-text');
        var cursorEl = document.getElementById('demo-cursor');
        var statusEl = document.getElementById('demo-status');
        var overlayEl = document.getElementById('trigger-overlay');
        var demoCard = document.getElementById('demo-card');

        function showOverlay(icon, text) {
            overlayEl.innerHTML = '<i class="fa-solid fa-' + icon + '"></i> ' + text;
            overlayEl.classList.add('show');
        }

        function hideOverlay() {
            overlayEl.classList.remove('show');
        }

        function updateModeDots() {
            var dots = document.querySelectorAll('.nav-dot');
            for (var i = 0; i < dots.length; i++) {
                dots[i].classList.toggle('active', i === currentMode);
            }
        }

        function runMode() {
            var mode = modes[currentMode];
            updateModeDots();
            document.getElementById('mode-trigger').textContent = mode.trigger;
            document.getElementById('mode-stop').textContent = mode.stop;

            glassEl.textContent = '';
            typedEl.textContent = '';
            cursorEl.style.display = 'inline';
            siriWave.setAmplitude(0.2);
            statusEl.textContent = 'Vozes';
            demoCard.classList.remove('transcribing', 'show-cli');

            showOverlay(mode.triggerIcon, ' ' + mode.trigger);
            statusEl.textContent = mode.trigger === _key ? _waitingKey : _waitingVoice;

            setTimeout(function () {
                hideOverlay();
                statusEl.textContent = _listening;
                siriWave.setAmplitude(1.2);
                charIndex = 0;

                setTimeout(function () {
                    statusEl.textContent = _transcribing;
                    siriWave.setAmplitude(2.0);
                    demoCard.classList.add('transcribing');
                    typeInGlass();
                }, 800);
            }, 1200);
        }

        function typeInGlass() {
            var mode = modes[currentMode];
            if (charIndex < mode.phrase.length) {
                glassEl.textContent += mode.phrase[charIndex];
                charIndex++;
                var delay = 20 + Math.random() * 30;
                setTimeout(typeInGlass, delay);
            } else {
                siriWave.setAmplitude(0.3);
                showOverlay(mode.stopIcon, ' ' + mode.stop);
                statusEl.textContent = mode.stop === _silence ? _detectedSilence : _detectedKey;

                setTimeout(function () {
                    hideOverlay();
                    statusEl.textContent = _typing;
                    siriWave.setAmplitude(0.05);
                    demoCard.classList.add('show-cli');
                    typeInTerminal();
                }, 1200);
            }
        }

        function typeInTerminal() {
            var mode = modes[currentMode];
            var text = mode.phrase;
            var i = 0;

            function typeChar() {
                if (i < text.length) {
                    typedEl.textContent += text[i];
                    i++;
                    setTimeout(typeChar, 12 + Math.random() * 18);
                } else {
                    cursorEl.style.display = 'none';
                    statusEl.textContent = _done;
                    setTimeout(function () {
                        cursorEl.style.display = 'inline';
                        currentMode = (currentMode + 1) % modes.length;
                        setTimeout(runMode, 1000);
                    }, 2000);
                }
            }

            typedEl.textContent = '';
            typeChar();
        }

        setTimeout(runMode, 600);
    </script>

    <style>
        :root {
            --warm-primary: #ff8a65;
            --warm-secondary: #ff7043;
            --warm-accent: #f4511e;
            --warm-bg: #fffbf9;
            --warm-card: #ffffff;
            --text-main: #3e2723;
            --text-muted: #5d4037;
            --gradient: linear-gradient(135deg, #ff8a65 0%, #f4511e 100%);
            --shadow-soft: 0 10px 30px rgba(244, 81, 30, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--warm-bg);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* Navbar */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1.5rem 0;
            z-index: 1000;
            transition: all 0.3s ease;
        }

        .navbar.scrolled {
            background: rgba(255, 251, 249, 0.85);
            backdrop-filter: blur(10px);
            padding: 1rem 0;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }

        .nav-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 1rem;
            text-decoration: none;
            color: var(--text-main);
            font-weight: 700;
            font-size: 1.5rem;
        }

        .logo img {
            height: 40px;
            width: auto;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            align-items: center;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-links a:not(.btn-primary):hover {
            color: var(--warm-accent);
        }

        .btn-icon {
            background: rgba(0,0,0,0.03);
            border: 1px solid rgba(0,0,0,0.05);
            color: var(--text-muted);
            font-size: 0.9rem;
            cursor: pointer;
            padding: 0.4rem 0.8rem;
            border-radius: 50px;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
        }

        .btn-icon:hover {
            background: rgba(0,0,0,0.06);
            color: var(--warm-accent);
            border-color: var(--warm-accent);
        }

        /* Hero */
        .hero {
            padding: 160px 0 80px;
            min-height: 80vh;
            display: flex;
            align-items: center;
            position: relative;
        }

        .hero-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 70% 20%, rgba(255, 138, 101, 0.1), transparent 50%),
                        radial-gradient(circle at 10% 80%, rgba(244, 81, 30, 0.05), transparent 40%);
            z-index: -1;
        }

        .hero-content {
            text-align: center;
        }

        .app-badge {
            display: inline-block;
            padding: 0.5rem 1.25rem;
            background: rgba(255, 138, 101, 0.1);
            color: var(--warm-accent);
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(255, 138, 101, 0.2);
        }

        .hero-text h1 {
            font-size: 4.5rem;
            line-height: 1.1;
            font-weight: 800;
            margin-bottom: 1.5rem;
        }

        .gradient-text {
            background: var(--gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-text p {
            font-size: 1.4rem;
            color: var(--text-muted);
            max-width: 700px;
            margin: 0 auto 2.5rem;
        }

        .hero-buttons {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
        }

        /* Buttons */
        .btn-primary {
            background: var(--gradient);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(244, 81, 30, 0.2);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(244, 81, 30, 0.3);
        }

        .btn-primary.small {
            padding: 0.6rem 1.5rem;
            font-size: 0.95rem;
        }

        .btn-primary.big {
            font-size: 1.2rem;
            padding: 1.2rem 3rem;
        }

        .btn-secondary {
            background: white;
            color: var(--text-main);
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            border: 1px solid rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0,0,0,0.02);
        }

        .btn-secondary:hover {
            background: #fffcfb;
            border-color: var(--warm-primary);
        }

        /* Video Section */
        .video-section {
            padding: 40px 0 100px;
        }

        .video-container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 1rem;
            border-radius: 30px;
            box-shadow: 0 30px 60px rgba(244, 81, 30, 0.1);
            border: 1px solid rgba(255, 138, 101, 0.1);
        }

        .video-container video {
            width: 100%;
            border-radius: 20px;
            display: block;
        }

        /* Features */
        .features {
            padding: 100px 0;
            background: white;
        }

        .section-title {
            text-align: center;
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 4rem;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2.5rem;
        }

        .feature-card {
            padding: 2.5rem;
            background: var(--warm-bg);
            border-radius: 24px;
            border: 1px solid rgba(255, 138, 101, 0.05);
            transition: all 0.3s ease;
        }

        .feature-card:hover {
            transform: translateY(-10px);
            background: white;
            box-shadow: var(--shadow-soft);
            border-color: rgba(255, 138, 101, 0.2);
        }

        .icon-box {
            width: 60px;
            height: 60px;
            background: var(--gradient);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
        }

        .feature-card h3 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .feature-card p {
            color: var(--text-muted);
            font-size: 1.05rem;
        }

        /* How it works */
        .how-it-works {
            padding: 100px 0;
        }

        .content-split {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5rem;
            align-items: center;
        }

        .align-left {
            text-align: left;
            margin-bottom: 2.5rem;
        }

        .steps-list {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .step-item {
            display: flex;
            gap: 1.5rem;
        }

        .step-icon {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            color: var(--warm-accent);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            flex-shrink: 0;
            border: 1px solid rgba(255, 138, 101, 0.1);
        }

        .step-info h3 {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }

        .step-info p {
            color: var(--text-muted);
        }

        /* Glass Card Visual */
        .glass-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.08);
            border: 1px solid rgba(255, 138, 101, 0.1);
            overflow: hidden;
        }

        .card-header {
            padding: 1rem 1.5rem;
            background: #fdfaf9;
            border-bottom: 1px solid #f0e6e2;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .dots {
            display: flex;
            gap: 0.5rem;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        .dot.red { background: #ff5f56; }
        .dot.yellow { background: #ffbd2e; }
        .dot.green { background: #27c93f; }

        .title-bar {
            font-size: 0.85rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .card-content {
            padding: 4rem 2rem;
            text-align: center;
        }

        .demo-card {
            position: relative;
            background: white;
            border-radius: 24px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.08);
            border: 1px solid rgba(255, 138, 101, 0.1);
            padding: 24px;
            max-width: 520px;
            margin: 0 auto;
        }

        .card-wave {
            background: white;
            border-radius: 14px;
            box-shadow: var(--shadow-soft);
            border: 1px solid rgba(255, 138, 101, 0.1);
            overflow: hidden;
        }

        .card-wave-head {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            background: #fdfaf9;
            border-bottom: 1px solid #f0e6e2;
        }

        .w-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .w-dot:nth-child(1) { background: #ff5f56; }
        .w-dot:nth-child(2) { background: #ffbd2e; }
        .w-dot:nth-child(3) { background: #27c93f; }

        .w-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 500;
            margin-left: 6px;
        }

        .card-wave-body {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            min-height: 110px;
        }

        #demo-siri-container {
            width: 100%;
            height: 60px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        #demo-siri-container canvas {
            max-width: 100%;
        }

        .demo-phrase {
            font-size: 0.85rem;
            line-height: 1.4;
            text-align: center;
            color: var(--text-main);
            white-space: pre-wrap;
            word-break: break-word;
            padding: 0 4px;
            min-height: 1.4em;
        }

        .transcribing .demo-phrase {
            color: var(--warm-accent);
            font-weight: 600;
        }

        .demo-overlap {
            position: relative;
            min-height: 180px;
        }

        .demo-overlap > .card-wave {
            position: relative;
            z-index: 2;
            transition: transform 0.5s, opacity 0.5s;
        }

        .demo-cli {
            position: absolute;
            z-index: 1;
            top: 0;
            left: 0;
            right: 0;
            display: none;
            background: #fdfaf9;
            border: 1px solid #f0e6e2;
            border-radius: 14px;
            padding: 20px 16px;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
            color: var(--text-main);
            align-items: center;
            gap: 6px;
            min-height: 120px;
            flex-wrap: wrap;
            align-content: center;
            box-shadow: var(--shadow-soft);
        }

        .show-cli .demo-cli {
            display: flex;
            z-index: 3;
            animation: cliSlideUp 0.4s ease-out;
        }

        .show-cli .card-wave {
            transform: scale(0.92);
            opacity: 0.2;
        }

        @keyframes cliSlideUp {
            from { transform: translateY(20px); opacity: 0; }
            to   { transform: translateY(0);    opacity: 1; }
        }

        .cli-dollar {
            color: var(--warm-accent);
            font-weight: bold;
        }

        .cli-cursor {
            color: var(--warm-accent);
            animation: blink 0.8s step-end infinite;
        }

        @keyframes blink {
            50% { opacity: 0; }
        }

        .demo-nav {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 10px;
        }

        .nav-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #ddd;
            transition: all 0.3s;
        }

        .nav-dot.active {
            background: var(--warm-primary);
            box-shadow: 0 0 4px rgba(255, 138, 101, 0.4);
        }

        .nav-info {
            font-size: 0.72rem;
            color: var(--text-muted);
        }

        .nav-arrow {
            font-size: 0.72rem;
            color: #ccc;
        }

        .demo-pop {
            position: absolute;
            top: 42%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: var(--warm-card);
            padding: 12px 20px;
            border-radius: 12px;
            border: 1px solid rgba(255, 138, 101, 0.15);
            box-shadow: 0 8px 25px rgba(0,0,0,0.06);
            color: var(--text-main);
            font-size: 0.9rem;
            font-weight: 600;
            opacity: 0;
            transition: opacity 0.25s;
            pointer-events: none;
            z-index: 10;
            text-align: center;
            white-space: nowrap;
        }

        .demo-pop.show {
            opacity: 1;
        }

        .demo-pop i {
            margin-right: 6px;
            color: var(--warm-accent);
        }

        .typing-text {
            font-weight: 500;
            color: var(--warm-accent);
        }

        /* CTA Section */
        .cta-section {
            padding: 100px 0;
        }

        .cta-box {
            background: var(--gradient);
            border-radius: 40px;
            padding: 5rem 2rem;
            text-align: center;
            color: white;
            box-shadow: 0 30px 60px rgba(244, 81, 30, 0.2);
        }

        .cta-box h2 {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
        }

        .cta-box p {
            font-size: 1.25rem;
            opacity: 0.9;
            margin-bottom: 3rem;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .cta-buttons {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1.5rem;
        }

        .meta-info {
            font-size: 0.9rem;
            opacity: 0.8;
        }

        /* Footer */
        footer {
            padding: 4rem 0;
            background: #fdfaf9;
            border-top: 1px solid #f0e6e2;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 2rem;
        }

        .footer-logo {
            display: flex;
            align-items: center;
            gap: 1rem;
            font-weight: 700;
            font-size: 1.2rem;
        }

        .footer-logo img {
            height: 30px;
        }

        footer p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .socials {
            display: flex;
            gap: 1.5rem;
        }

        .socials a {
            color: var(--text-muted);
            font-size: 1.5rem;
            transition: color 0.3s;
        }

        .socials a:hover {
            color: var(--warm-accent);
        }

        /* Animations */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease;
        }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Responsive */
        @media (max-width: 968px) {
            .hero-text h1 {
                font-size: 3.2rem;
            }

            .content-split {
                grid-template-columns: 1fr;
                gap: 4rem;
                text-align: center;
            }

            .align-left {
                text-align: center;
            }

            .step-item {
                flex-direction: column;
                align-items: center;
            }

            .nav-links {
                display: none;
            }
        }

        @media (max-width: 480px) {
            .hero-text h1 {
                font-size: 2.5rem;
            }

            .hero-buttons {
                flex-direction: column;
            }

            .cta-box h2 {
                font-size: 2.2rem;
            }
        }
    </style>
</body>
</html>
