---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const app = {
  id: "bautilus",
  title: "Bautilus",
  logo: "https://hosted.inled.es/bautilus.png",
  downloadUrl: "https://github.com/InledGroup/bautilus/releases/latest/",
  githubUrl: "https://github.com/InledGroup/bautilus"
};

const i18n = {
  es: {
    hero: {
      title: "Tu navegador, ahora todopoderoso.",
      subtitle: "Transforma Chrome en el explorador de archivos definitivo. Inspirado en Nautilus, diseñado para la web moderna.",
      badge: "Extensión Beta Pública"
    },
    formats: {
      title: "Soporte Universal",
      subtitle: "Visores nativos integrados para una gestión de archivos sin interrupciones.",
      items: [
        { name: "Imágenes", ext: ".jpg, .png, .svg", theme: "blue" },
        { name: "Vídeo", ext: ".mp4, .webm", theme: "purple" },
        { name: "PDF", ext: ".pdf, .doc", theme: "red" },
        { name: "Archivos", ext: ".zip, .tar.gz", theme: "orange" },
        { name: "Código", ext: ".js, .py, .cpp", theme: "dark" }
      ]
    },
    roadmap: {
      title: "Roadmap 2026",
      items: [
        { 
          title: "Integración Microsoft Office", 
          description: "Edición y previsualización nativa de archivos .docx, .xlsx y .pptx sin salir del navegador.",
          status: "En Desarrollo",
          progress: 65
        },
        { 
          title: "IA Generativa Local", 
          description: "Análisis semántico de archivos, resúmenes automáticos y organización inteligente mediante LLMs locales.",
          status: "Planeado",
          progress: 15
        }
      ]
    },
    cta: {
      title: "Lleva tu navegador al siguiente nivel",
      button: "Descargar Bautilus",
      github: "Explorar Código"
    }
  },
  en: {
    hero: {
      title: "Your browser, now almighty.",
      subtitle: "Transform Chrome into the ultimate file explorer. Inspired by Nautilus, designed for the modern web.",
      badge: "Public Beta Extension"
    },
    formats: {
      title: "Universal Support",
      subtitle: "Built-in native viewers for seamless file management.",
      items: [
        { name: "Images", ext: ".jpg, .png, .svg", theme: "blue" },
        { name: "Video", ext: ".mp4, .webm", theme: "purple" },
        { name: "PDF", ext: ".pdf, .doc", theme: "red" },
        { name: "Archives", ext: ".zip, .tar.gz", theme: "orange" },
        { name: "Code", ext: ".js, .py, .cpp", theme: "dark" }
      ]
    },
    roadmap: {
      title: "2026 Roadmap",
      items: [
        { 
          title: "Microsoft Office Integration", 
          description: "Native editing and previewing of .docx, .xlsx, and .pptx files without leaving the browser.",
          status: "In Progress",
          progress: 65
        },
        { 
          title: "Local Generative AI", 
          description: "Semantic file analysis, automatic summaries, and intelligent organization using local LLMs.",
          status: "Planned",
          progress: 15
        }
      ]
    },
    cta: {
      title: "Take your browser to the next level",
      button: "Download Bautilus",
      github: "Explore Code"
    }
  }
};
---

<Layout title="Bautilus - El Explorador Todopoderoso - Inled Apps" description="Convierte tu navegador en un explorador de archivos similar al Nautilus de GNOME.">
  <div id="page-content" class="theme-light">
    <Header />
    
    <main>
      <!-- Hero Section (DarkPDF Style) -->
      <section class="hero-section">
        <div class="container">
          <div class="hero-content">
            <div class="badge fade-in">{i18n.es.hero.badge}</div>
            <h1 class="fade-in" id="hero-title">{i18n.es.hero.title}</h1>
            <p class="fade-in delay-1" id="hero-subtitle">{i18n.es.hero.subtitle}</p>
            
            <div class="app-icon-wrapper fade-in delay-2">
              <img src={app.logo} alt="Bautilus Logo" class="app-logo" />
            </div>
          </div>
        </div>
        
        <div class="scroll-indicator">
          <div class="mouse"></div>
          <p>Scroll</p>
        </div>
      </section>

      <!-- Ubuntu Formats Section -->
      <section class="formats-section">
        <div class="container">
          <h2 class="section-title fade-up" id="formats-title">{i18n.es.formats.title}</h2>
          <p class="section-subtitle fade-up" id="formats-subtitle">{i18n.es.formats.subtitle}</p>
          
          <div class="formats-grid">
            {i18n.es.formats.items.map((item, index) => (
              <div class="format-card fade-up" style={`--delay: ${index * 0.1}s`}>
                <div class={`ubuntu-icon icon-${item.theme}`}>
                  {/* Imagen - Yaru Blue */}
                  {item.theme === 'blue' && <svg viewBox="0 0 48 48"><rect x="4" y="8" width="40" height="32" rx="4" fill="#3584e4"/><path d="M4 32L16 20L28 32M24 28L36 16L44 24" stroke="white" stroke-width="2" stroke-linejoin="round"/><circle cx="34" cy="14" r="3" fill="white"/></svg>}
                  {/* Video - Yaru Purple */}
                  {item.theme === 'purple' && <svg viewBox="0 0 48 48"><rect x="4" y="8" width="40" height="32" rx="4" fill="#9141ac"/><path d="M18 16V32L34 24L18 16Z" fill="white"/></svg>}
                  {/* PDF - Yaru Red */}
                  {item.theme === 'red' && <svg viewBox="0 0 48 48"><path d="M10 4H30L40 14V44H10V4Z" fill="#e01b24"/><path d="M30 4L40 14H30V4Z" fill="#a51d2d"/><rect x="16" y="24" width="16" height="2" fill="white" opacity="0.8"/><rect x="16" y="32" width="16" height="2" fill="white" opacity="0.8"/></svg>}
                  {/* Archives - Yaru Orange */}
                  {item.theme === 'orange' && <svg viewBox="0 0 48 48"><path d="M10 10H38V42H10V10Z" fill="#e66100"/><path d="M10 10L24 4L38 10V10Z" fill="#c05100"/><rect x="22" y="16" width="4" height="12" fill="white" opacity="0.5"/><circle cx="24" cy="34" r="4" fill="white"/></svg>}
                  {/* Code - Yaru Dark */}
                  {item.theme === 'dark' && <svg viewBox="0 0 48 48"><rect x="4" y="8" width="40" height="32" rx="4" fill="#241f31"/><path d="M14 18L6 24L14 30M34 18L42 24L34 30" stroke="#3584e4" stroke-width="3" stroke-linecap="round"/></svg>}
                </div>
                <h3>{item.name}</h3>
                <p class="ext-tag">{item.ext}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Roadmap Section (Properly Styled) -->
      <section class="roadmap-section">
        <div class="container">
          <h2 class="section-title fade-up" id="roadmap-title">{i18n.es.roadmap.title}</h2>
          <div class="roadmap-grid">
            {i18n.es.roadmap.items.map((item, index) => (
              <div class="roadmap-card fade-up">
                <div class="roadmap-header">
                  <span class="status-badge">{item.status}</span>
                  <span class="progress-pct">{item.progress}%</span>
                </div>
                <h3 id={`roadmap-title-${index}`}>{item.title}</h3>
                <p id={`roadmap-desc-${index}`}>{item.description}</p>
                <div class="progress-container">
                  <div class="progress-bar" style={`width: ${item.progress}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="cta-section">
        <div class="container">
          <div class="cta-card fade-up">
            <h2 id="cta-title">{i18n.es.cta.title}</h2>
            <div class="cta-actions">
              <a href={app.downloadUrl} class="btn-primary" id="cta-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                {i18n.es.cta.button}
              </a>
              <a href={app.githubUrl} class="btn-outline" id="github-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                {i18n.es.cta.github}
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <div class="scroll-aberration" id="global-aberration"></div>
  </div>
</Layout>

<style is:global>
  #page-content {
    --bg-color: #ffffff;
    --text-color: #000000;
    --accent-color: #3584e4;
    --muted-color: #666666;
    --card-bg: #f8fafc;
    
    background-color: var(--bg-color);
    color: var(--text-color);
    transition: background-color 0.8s ease, color 0.8s ease;
    min-height: 100vh;
    font-family: -apple-system, BlinkMacSystemFont, "Inter", sans-serif;
  }

  body { background-color: #ffffff !important; }

  #page-content.theme-dark {
    --bg-color: #0a0a0a;
    --text-color: #ffffff;
    --muted-color: #a1a1a1;
    --card-bg: #111111;
  }

  #page-content :global(header) {
    background: transparent !important;
    backdrop-filter: blur(10px);
  }

  #page-content.theme-light :global(header a),
  #page-content.theme-light :global(header button) { color: #000000 !important; }

  #page-content.theme-dark :global(header a),
  #page-content.theme-dark :global(header button) { color: #ffffff !important; }
</style>

<style>
  .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

  /* Hero Section (Centred) */
  .hero-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: relative;
  }

  .badge {
    padding: 0.5rem 1rem;
    background: #fef2f2;
    color: #ef4444;
    border: 1px solid #fee2e2;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h1 {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  p {
    font-size: 1.25rem;
    color: var(--muted-color);
    max-width: 650px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .app-logo {
    width: 140px;
    height: 140px;
    border-radius: 32px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
  }

  .app-logo:hover { transform: scale(1.05); }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.5;
    text-align: center;
  }

  .mouse {
    width: 24px;
    height: 38px;
    border: 2px solid var(--text-color);
    border-radius: 12px;
    margin: 0 auto 0.5rem;
    position: relative;
  }

  .mouse::after {
    content: "";
    width: 4px;
    height: 8px;
    background: var(--text-color);
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 2px;
    animation: scroll 2s infinite;
  }

  @keyframes scroll {
    0% { opacity: 1; transform: translateX(-50%) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) translateY(12px); }
  }

  /* Formats Section */
  .formats-section { padding: 8rem 0; text-align: center; }
  .section-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; }
  .section-subtitle { margin-bottom: 4rem; color: var(--muted-color); }

  .formats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
  }

  .format-card {
    background: var(--card-bg);
    padding: 3rem 1.5rem;
    border-radius: 24px;
    border: 1px solid rgba(0,0,0,0.03);
    transition: all 0.3s ease;
  }

  .theme-dark .format-card { border-color: rgba(255,255,255,0.05); }

  .ubuntu-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem;
    filter: drop-shadow(0 8px 12px rgba(0,0,0,0.1));
  }

  .format-card h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }
  .ext-tag { font-size: 0.8rem; font-family: monospace; color: var(--accent-color); font-weight: 600; }

  /* Roadmap Section */
  .roadmap-section { padding: 8rem 0; }
  .roadmap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .roadmap-card {
    background: var(--card-bg);
    padding: 2.5rem;
    border-radius: 28px;
    border: 1px solid rgba(0,0,0,0.03);
  }

  .roadmap-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--accent-color);
    background: rgba(53, 132, 228, 0.1);
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
  }

  .progress-pct { font-weight: 800; color: var(--accent-color); }

  .roadmap-card h3 { font-size: 1.5rem; font-weight: 800; margin-bottom: 1rem; }
  .roadmap-card p { font-size: 1rem; margin-bottom: 2rem; text-align: left; max-width: 100%; }

  .progress-container {
    height: 8px;
    background: rgba(0,0,0,0.05);
    border-radius: 10px;
    overflow: hidden;
  }
  .theme-dark .progress-container { background: rgba(255,255,255,0.1); }
  .progress-bar { height: 100%; background: var(--accent-color); border-radius: 10px; }

  /* CTA Section */
  .cta-section { padding: 8rem 0; }
  .cta-card {
    background: var(--accent-color);
    padding: 5rem 2rem;
    border-radius: 40px;
    text-align: center;
    color: white;
  }

  .cta-card h2 { font-size: 3rem; font-weight: 800; margin-bottom: 3rem; }
  .cta-actions { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }

  .btn-primary, .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    border-radius: 100px;
    font-weight: 700;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .btn-primary { background: white; color: var(--accent-color); }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }

  .btn-outline { border: 2px solid white; color: white; }
  .btn-outline:hover { background: white; color: var(--accent-color); transform: translateY(-3px); }

  /* Aberration effect */
  .scroll-aberration {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 99;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .scroll-aberration.active { opacity: 0.1; }

  /* Animations */
  .fade-in { opacity: 0; transform: translateY(20px); animation: fadeIn 1s forwards; }
  .fade-up { opacity: 0; transform: translateY(30px); transition: all 1s ease; }
  .fade-up.visible { opacity: 1; transform: translateY(0); }
  @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }
  .delay-1 { animation-delay: 0.2s; }
  .delay-2 { animation-delay: 0.4s; }

  @media (max-width: 768px) {
    .cta-card { padding: 3rem 1.5rem; }
    .roadmap-grid { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ app, i18n }}>
  const pageContent = document.getElementById('page-content');
  const globalAberration = document.getElementById('global-aberration');
  const heroTitle = document.getElementById('hero-title');

  function updateLang(lang) {
    const data = i18n[lang];
    if (!data) return;
    document.getElementById('hero-title').textContent = data.hero.title;
    document.getElementById('hero-subtitle').textContent = data.hero.subtitle;
    document.querySelector('.badge').textContent = data.hero.badge;
    document.getElementById('formats-title').textContent = data.formats.title;
    document.getElementById('formats-subtitle').textContent = data.formats.subtitle;
    document.getElementById('roadmap-title').textContent = data.roadmap.title;
    data.roadmap.items.forEach((item, i) => {
      document.getElementById(`roadmap-title-${i}`).textContent = item.title;
      document.getElementById(`roadmap-desc-${i}`).textContent = item.description;
    });
    document.getElementById('cta-title').textContent = data.cta.title;
    document.getElementById('cta-btn').innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      ${data.cta.button}
    `;
    document.getElementById('github-btn').innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      ${data.cta.github}
    `;
  }

  let scrollTimeout;
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const windowHeight = window.innerHeight;
    
    // Theme Switch
    if (scrollY > windowHeight * 0.4) {
      pageContent.classList.add('theme-dark');
      pageContent.classList.remove('theme-light');
    } else {
      pageContent.classList.add('theme-light');
      pageContent.classList.remove('theme-dark');
    }

    // Aberration
    globalAberration.classList.add('active');
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => globalAberration.classList.remove('active'), 150);
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  updateLang(localStorage.getItem('preferred-lang') || 'es');
  window.addEventListener('langChanged', (e) => updateLang(e.detail.lang));
</script>