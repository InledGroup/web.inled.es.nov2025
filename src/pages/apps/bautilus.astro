---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const app = {
  id: "bautilus",
  title: "Bautilus",
  logo: "https://hosted.inled.es/bautilus.png",
  downloadUrl: "https://github.com/InledGroup/bautilus/releases/latest/",
  githubUrl: "https://github.com/InledGroup/bautilus"
};

const i18n = {
  es: {
    hero: {
      title: "Tu navegador, ahora todopoderoso.",
      subtitle: "Transforma Chrome en el explorador de archivos definitivo. Inspirado en Nautilus, diseñado para la web moderna.",
      badge: "Extensión Beta Pública"
    },
    formats: {
      title: "Soporte Universal",
      subtitle: "Visores nativos integrados para una gestión de archivos sin interrupciones.",
      items: [
        { name: "Imágenes", ext: ".jpg, .png, .svg", theme: "blue", icon: "https://raw.githubusercontent.com/ubuntu/yaru/refs/heads/master/icons/Yaru/256x256/mimetypes/image-x-generic.png" },
        { name: "Vídeo", ext: ".mp4, .webm", theme: "purple", icon: "https://github.com/ubuntu/yaru/blob/master/icons/Yaru/256x256@2x/mimetypes/video-x-generic.png?raw=true" },
        { name: "PDF", ext: ".pdf, .doc", theme: "red", icon: "https://github.com/ubuntu/yaru/blob/master/icons/Yaru/256x256/mimetypes/application-pdf.png?raw=true" },
        { name: "Archivos", ext: ".zip, .tar.gz", theme: "orange", icon: "https://github.com/ubuntu/yaru/blob/master/icons/Yaru/256x256/mimetypes/application-x-zip.png?raw=true" },
        { name: "Web/Código", ext: ".html, .js, .css", theme: "dark", icon: "https://github.com/ubuntu/yaru/blob/master/icons/Yaru/256x256/mimetypes/text-html.png?raw=true" }
      ]
    },
    cta: {
      title: "Lleva tu navegador al siguiente nivel",
      button: "Descargar Bautilus",
      github: "Explorar Código"
    }
  },
  en: {
    hero: {
      title: "Your browser, now almighty.",
      subtitle: "Transform Chrome into the ultimate file explorer. Inspired by Nautilus, designed for the modern web.",
      badge: "Public Beta Extension"
    },
    formats: {
      title: "Universal Support",
      subtitle: "Built-in native viewers for seamless file management.",
      items: [
        { name: "Images", ext: ".jpg, .png, .svg", theme: "blue", icon: "https://raw.githubusercontent.com/ubuntu/yaru/refs/heads/master/icons/Yaru/256x256/mimetypes/image-x-generic.png" },
        { name: "Video", ext: ".mp4, .webm", theme: "purple", icon: "https://github.com/ubuntu/yaru/blob/master/icons/Yaru/256x256@2x/mimetypes/video-x-generic.png?raw=true" },
        { name: "PDF", ext: ".pdf, .doc", theme: "red", icon: "https://github.com/ubuntu/yaru/blob/master/icons/Yaru/256x256/mimetypes/application-pdf.png?raw=true" },
        { name: "Archives", ext: ".zip, .tar.gz", theme: "orange", icon: "https://github.com/ubuntu/yaru/blob/master/icons/Yaru/256x256/mimetypes/application-x-zip.png?raw=true" },
        { name: "Web/Code", ext: ".html, .js, .css", theme: "dark", icon: "https://github.com/ubuntu/yaru/blob/master/icons/Yaru/256x256/mimetypes/text-html.png?raw=true" }
      ]
    },
    cta: {
      title: "Take your browser to the next level",
      button: "Download Bautilus",
      github: "Explore Code"
    }
  }
};
---

<Layout title="Bautilus - El Explorador Todopoderoso - Inled Apps" description="Convierte tu navegador en un explorador de archivos similar al Nautilus de GNOME.">
  <div id="page-content" class="theme-light">
    <Header />
    
    <main>
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="container">
          <div class="hero-content">
            <div class="badge fade-in">{i18n.es.hero.badge}</div>
            <h1 class="fade-in" id="hero-title">{i18n.es.hero.title}</h1>
            <p class="fade-in delay-1" id="hero-subtitle">{i18n.es.hero.subtitle}</p>
            <div class="app-icon-wrapper fade-in delay-2">
              <img src={app.logo} alt="Bautilus Logo" class="app-logo" />
            </div>
          </div>
        </div>
      </section>

      <!-- Scroll Animation Section -->
      <section class="scroll-anim-section" id="scroll-trigger">
        <div class="sticky-container">
          <!-- Laptop Mockup -->
          <div class="laptop-container" id="laptop-container">
            <div class="laptop-mockup">
              <div class="laptop-screen" id="laptop-screen">
                <div class="screen-content">
                  <div class="video-overlay" id="video-overlay"></div>
                  <iframe 
                    id="yt-player"
                    src="https://www.youtube.com/embed/QCUmerBLHIc?enablejsapi=1&mute=1&controls=0&rel=0&showinfo=0&autoplay=1&loop=1&playlist=QCUmerBLHIc" 
                    title="YouTube video player" 
                    frameborder="0" 
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                    allowfullscreen>
                  </iframe>
                </div>
              </div>
              <div class="laptop-base">
                <div class="trackpad"></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Ubuntu Formats Section -->
      <section class="formats-section">
        <div class="container">
          <h2 class="section-title fade-up" id="formats-title">{i18n.es.formats.title}</h2>
          <p class="section-subtitle fade-up" id="formats-subtitle">{i18n.es.formats.subtitle}</p>
          
          <div class="formats-grid">
            {i18n.es.formats.items.map((item, index) => (
              <div class="format-card fade-up" style={`--delay: ${index * 0.1}s`}>
                <div class={`ubuntu-icon icon-${item.theme}`}>
                  <img src={item.icon} alt={item.name} class="yaru-icon" />
                </div>
                <h3>{item.name}</h3>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="cta-section">
        <div class="container">
          <div class="cta-card fade-up">
            <h2 id="cta-title">{i18n.es.cta.title}</h2>
            <div class="cta-actions">
              <a href={app.downloadUrl} class="btn-primary" id="cta-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                {i18n.es.cta.button}
              </a>
              <a href={app.githubUrl} class="btn-outline" id="github-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                {i18n.es.cta.github}
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style is:global>
  #page-content {
    --bg-color: #ffffff;
    --text-color: #000000;
    --accent-color: #3584e4;
    --muted-color: #666666;
    --card-bg: #f8fafc;
    
    background-color: var(--bg-color);
    color: var(--text-color);
    transition: background-color 0.8s ease, color 0.8s ease;
    min-height: 100vh;
    font-family: -apple-system, BlinkMacSystemFont, "Inter", sans-serif;
  }

  body { background-color: #ffffff !important; overflow-x: hidden; }

  #page-content.theme-dark {
    --bg-color: #0a0a0a;
    --text-color: #ffffff;
    --muted-color: #a1a1a1;
    --card-bg: #111111;
  }

  #page-content :global(header) {
    background: transparent !important;
    backdrop-filter: blur(10px);
  }

  #page-content.theme-light :global(header a),
  #page-content.theme-light :global(header button) { color: #000000 !important; }

  #page-content.theme-dark :global(header a),
  #page-content.theme-dark :global(header button) { color: #ffffff !important; }
</style>

<style>
  .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

  /* Hero Section */
  .hero-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 10;
  }

  .badge {
    padding: 0.5rem 1rem;
    background: rgba(53, 132, 228, 0.1);
    color: var(--accent-color);
    border: 1px solid rgba(53, 132, 228, 0.2);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h1 {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  p {
    font-size: 1.25rem;
    color: var(--muted-color);
    max-width: 650px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .app-logo {
    width: 120px;
    height: 120px;
    border-radius: 28px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  /* Scroll Animation Section */
  .scroll-anim-section {
    height: 250vh; /* Scroll area */
    position: relative;
  }

  .sticky-container {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  /* Laptop Mockup */
  .laptop-container {
    opacity: 0;
    transform: scale(0.8) translateY(100px);
    z-index: 1;
    perspective: 2000px;
    width: 100%;
    max-width: 900px;
  }

  .laptop-mockup {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .laptop-screen {
    width: 100%;
    height: 95%;
    background: #1a1a1a;
    border: 12px solid #2a2a2a;
    border-bottom-width: 20px;
    border-radius: 20px 20px 0 0;
    position: relative;
    transform-origin: bottom;
    transform: rotateX(-90deg); /* Start closed */
    box-shadow: inset 0 0 100px rgba(0,0,0,0.5);
    overflow: hidden;
    transition: transform 0.1s linear;
  }

  .screen-content {
    width: 100%;
    height: 100%;
    position: relative;
    background: #000;
  }

  .screen-content iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .laptop-base {
    width: 110%;
    height: 15px;
    background: #3a3a3a;
    border-radius: 0 0 20px 20px;
    position: relative;
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }

  .trackpad {
    width: 30%;
    height: 80%;
    background: #2a2a2a;
    margin: 0 auto;
    border-radius: 5px;
    opacity: 0.5;
  }

  /* Formats Section */
  .formats-section { padding: 8rem 0; text-align: center; }
  .section-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; }
  .section-subtitle { margin-bottom: 4rem; color: var(--muted-color); }

  .formats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
  }

  .format-card {
    background: var(--card-bg);
    padding: 3rem 1.5rem;
    border-radius: 24px;
    border: 1px solid rgba(0,0,0,0.03);
    transition: all 0.3s ease;
  }

  .theme-dark .format-card { border-color: rgba(255,255,255,0.05); }

  .ubuntu-icon {
    width: 96px;
    height: 96px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .yaru-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 8px 12px rgba(0,0,0,0.1));
  }

  .format-card h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }
  .ext-tag { font-size: 0.8rem; font-family: monospace; color: var(--accent-color); font-weight: 600; }

  /* CTA Section */
  .cta-section { padding: 8rem 0; }
  .cta-card {
    background: var(--accent-color);
    padding: 5rem 2rem;
    border-radius: 40px;
    text-align: center;
    color: white;
  }

  .cta-card h2 { font-size: 3rem; font-weight: 800; margin-bottom: 3rem; }
  .cta-actions { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }

  .btn-primary, .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    border-radius: 100px;
    font-weight: 700;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .btn-primary { background: white; color: var(--accent-color); }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }

  .btn-outline { border: 2px solid white; color: white; }
  .btn-outline:hover { background: white; color: var(--accent-color); transform: translateY(-3px); }

  /* Animations */
  .fade-in { opacity: 0; transform: translateY(20px); animation: fadeIn 1s forwards; }
  .fade-up { opacity: 0; transform: translateY(30px); transition: all 1s ease; }
  .fade-up.visible { opacity: 1; transform: translateY(0); }
  @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }
  .delay-1 { animation-delay: 0.2s; }
  .delay-2 { animation-delay: 0.4s; }

  @media (max-width: 768px) {
    .cta-card { padding: 3rem 1.5rem; }
    .laptop-container { max-width: 90%; }
  }
</style>

<script define:vars={{ app, i18n }}>
  const pageContent = document.getElementById('page-content');
  const scrollTrigger = document.getElementById('scroll-trigger');
  const laptopContainer = document.getElementById('laptop-container');
  const laptopScreen = document.getElementById('laptop-screen');
  const videoOverlay = document.getElementById('video-overlay');
  const ytPlayer = document.getElementById('yt-player');

  let player;
  // Load YouTube API
  const tag = document.createElement('script');
  tag.src = "https://www.youtube.com/iframe_api";
  const firstScriptTag = document.getElementsByTagName('script')[0];
  firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

  window.onYouTubeIframeAPIReady = () => {
    player = new YT.Player('yt-player', {
      events: {
        'onReady': (event) => {
          event.target.mute();
        }
      }
    });
  };

  function updateLang(lang) {
    const data = i18n[lang];
    if (!data) return;
    document.getElementById('hero-title').textContent = data.hero.title;
    document.getElementById('hero-subtitle').textContent = data.hero.subtitle;
    document.querySelector('.badge').textContent = data.hero.badge;
    document.getElementById('formats-title').textContent = data.formats.title;
    document.getElementById('formats-subtitle').textContent = data.formats.subtitle;
    document.getElementById('cta-title').textContent = data.cta.title;
    document.getElementById('cta-btn').innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      ${data.cta.button}
    `;
    document.getElementById('github-btn').innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      ${data.cta.github}
    `;
  }

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const windowHeight = window.innerHeight;
    const triggerTop = scrollTrigger.offsetTop;
    const triggerHeight = scrollTrigger.offsetHeight;
    
    // Progress within the scroll-anim-section (0 to 1)
    let progress = (scrollY - triggerTop) / (triggerHeight - windowHeight);
    progress = Math.max(0, Math.min(1, progress));

    // Laptop Appearance & Opening
    if (progress >= 0 && progress <= 1) {
      // Appearance (faster at start)
      const laptopOpacity = Math.min(1, progress * 4);
      const laptopScale = 0.8 + Math.min(0.2, progress * 0.5);
      const laptopY = 100 * (1 - Math.min(1, progress * 2));
      
      laptopContainer.style.opacity = laptopOpacity;
      laptopContainer.style.transform = `scale(${laptopScale}) translateY(${laptopY}px)`;

      // Opening the screen (rotate from -90 to 0)
      const rotation = -90 + Math.min(90, progress * 150);
      laptopScreen.style.transform = `rotateX(${Math.min(0, rotation)}deg)`;

      // Video focus logic
      if (rotation >= -10) {
        videoOverlay.style.opacity = 0;
        if (player && player.playVideo) player.playVideo();
      } else {
        videoOverlay.style.opacity = 1;
        if (player && player.pauseVideo) player.pauseVideo();
      }
    }

    // Theme Switch
    if (scrollY > windowHeight * 0.4) {
      pageContent.classList.add('theme-dark');
      pageContent.classList.remove('theme-light');
    } else {
      pageContent.classList.add('theme-light');
      pageContent.classList.remove('theme-dark');
    }
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  updateLang(localStorage.getItem('preferred-lang') || 'es');
  window.addEventListener('langChanged', (e) => updateLang(e.detail.lang));
</script>