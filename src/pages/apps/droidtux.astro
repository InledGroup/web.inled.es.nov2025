---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

// Force page language to English
Astro.locals.lang = 'en';
const lang = 'en';

const app = {
  id: "droidtux",
  title: "DroidTux",
  logo: "https://hosted.inled.es/droidtux.png",
  downloadUrl: "https://github.com/InledGroup/DroidTux/releases/latest",
  githubUrl: "https://github.com/InledGroup/DroidTux",
  releasesUrl: "https://github.com/InledGroup/DroidTux/releases/"
};

const t = {
  meta: {
    title: "DroidTux | Android Apps on your Linux Desktop",
    description: "Run your Android applications as native windows on Linux by connecting your phone."
  },
  nav: {
    comparison: "Comparison",
    screenshots: "Screenshots",
    install: "Install",
    github: "GitHub"
  },
  hero: {
    title: "Run Android Apps on 🐧 Linux",
    subtitle: " ✨ Just connect your phone ",
    explore: "See Comparison",
    download: "Download"
  },
  comparison: {
    title: "Why DroidTux is different",
    waydroid: {
      name: "Waydroid",
      desc: "Installs a full Android system on your PC. It often uses obsolete Android versions and consumes many resources.",
      diff: "DroidTux uses YOUR phone's Android, with YOUR data and updated apps."
    },
    scrcpy: {
      name: "Scrcpy",
      desc: "Excellent for screen mirroring, but very difficult to integrate individual apps as windows.",
      diff: "DroidTux integrates each app as an independent window on your desktop."
    }
  },
  install: {
    arch: {
      title: "Arch Linux",
      command: "sudo pacman -U (filename).pkg.tar.xz",
      instructions: "Download the .pkg.tar.xz package from releases and run it in your terminal.",
      note: "Not available on AUR. After the AUR malware attack, they are not accepting new packages for now."
    },
    debian: {
      title: "Debian / Ubuntu",
      command: "sudo dpkg -i (filename).deb",
      instructions: "Download the .deb package from releases and install it with dpkg."
    },
    fedora: {
      title: "Fedora",
      command: "sudo rpm -i (filename).rpm",
      instructions: "Download the .rpm package from releases and install it with rpm."
    },
    requirements: "Requires USB debugging enabled on your Android phone."
  },
  compat: {
    title: "Compatible with",
    debian: "Debian / Ubuntu",
    fedora: "Fedora",
    arch: "Arch Linux",
    hint: "Click a logo for installation instructions"
  },
  complement: {
    title: "Enhance the experience",
    desc: "For full file and notification integration, we recommend using:",
    kde: "KDE Connect",
    gs: "GSConnect"
  }
};
---

<Layout title={t.meta.title} description={t.meta.description}>
  <Header />
  <div class="droidtux-page">
    <main>
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="hero-logo">
          <img src={app.logo} alt="DroidTux Logo" />
        </div>
        <h1 class="hero-title">
          {t.hero.title} <br/>
          <span class="gradient-text">{t.hero.subtitle}</span>
        </h1>
        <div class="hero-actions">
          <a href="#comparison" class="btn-outline">
            <i class="fa-solid fa-layer-group gradient-icon"></i>
            {t.hero.explore}
          </a>
          <a href={app.downloadUrl} class="btn-primary">
            <i class="fa-solid fa-download"></i>
            {t.hero.download}
          </a>
        </div>
      </section>

      <!-- Comparison Section -->
      <section id="comparison" class="comparison-section">
        <h2 class="section-title">
          <span class="gradient-text">{t.comparison.title}</span>
        </h2>
        
        <div class="comparison-grid">
          <!-- Waydroid -->
          <div class="glass-card comparison-card">
            <div class="card-header">
              <img src="https://hosted.inled.es/waydroid.svg" alt="Waydroid" class="comp-logo" />
              <h3>{t.comparison.waydroid.name}</h3>
            </div>
            <div class="card-body">
              <p class="desc">{t.comparison.waydroid.desc}</p>
              <div class="vs-divider">VS</div>
              <p class="diff"><i class="fa-solid fa-check gradient-icon"></i> {t.comparison.waydroid.diff}</p>
            </div>
          </div>

          <!-- Scrcpy -->
          <div class="glass-card comparison-card">
            <div class="card-header">
              <img src="https://hosted.inled.es/Scrcpy_logo.svg.png" alt="Scrcpy" class="comp-logo" />
              <h3>{t.comparison.scrcpy.name}</h3>
            </div>
            <div class="card-body">
              <p class="desc">{t.comparison.scrcpy.desc}</p>
              <div class="vs-divider">VS</div>
              <p class="diff"><i class="fa-solid fa-check gradient-icon"></i> {t.comparison.scrcpy.diff}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Screenshots Section -->
      <section id="screenshots" class="screenshots-section">
        <h2 class="section-title">
          <span class="gradient-text">{t.nav.screenshots}</span>
        </h2>
        <div class="screenshot-showcase">
          <div class="screenshot-container">
            <img src="https://hosted.inled.es/apps-droidtux-integradas.png" alt="DroidTux Integrated Apps" class="main-screenshot" />
            <div class="screenshot-caption">{lang === 'es' ? 'Apps integradas como ventanas nativas' : 'Apps integrated as native windows'}</div>
          </div>
          <div class="screenshot-container">
            <img src="https://hosted.inled.es/apps-droidtux-demo2.png" alt="DroidTux Demo" class="main-screenshot" />
            <div class="screenshot-caption">{lang === 'es' ? 'Multitarea real entre Android y Linux' : 'Real multitasking between Android and Linux'}</div>
          </div>
        </div>
      </section>

      <!-- Compatibility & Installation Section -->
      <section id="compat" class="compat-section">
        <h2 class="section-title">
          <span class="gradient-text">{t.compat.title}</span>
        </h2>
        <div class="distro-grid">
          <div class="distro-item" data-distro="debian">
            <img src="https://hosted.inled.es/debian.svg" alt="Debian" />
            <span>{t.compat.debian}</span>
          </div>
          <div class="distro-item" data-distro="fedora">
            <img src="https://hosted.inled.es/Fedora_logo.svg" alt="Fedora" />
            <span>{t.compat.fedora}</span>
          </div>
          <div class="distro-item" data-distro="arch">
            <img src="https://hosted.inled.es/archlinux-logo.png" alt="Arch Linux" />
            <span>{t.compat.arch}</span>
          </div>
        </div>
        <p class="compat-hint">{t.compat.hint}</p>
        <div class="install-cards">
          <div class="install-toggle" id="install-debian">
            <div class="install-card glass-card">
              <div class="terminal-header">
                <div class="dots"><span></span><span></span><span></span></div>
                <span class="terminal-title">{t.install.debian.title}</span>
              </div>
              <div class="terminal-body">
                <code>{t.install.debian.command}</code>
              </div>
              <p class="install-note">{t.install.debian.instructions}</p>
              <div class="requirement-tag">
                <i class="fa-solid fa-circle-info"></i> {t.install.requirements}
              </div>
            </div>
          </div>
          <div class="install-toggle" id="install-fedora">
            <div class="install-card glass-card">
              <div class="terminal-header">
                <div class="dots"><span></span><span></span><span></span></div>
                <span class="terminal-title">{t.install.fedora.title}</span>
              </div>
              <div class="terminal-body">
                <code>{t.install.fedora.command}</code>
              </div>
              <p class="install-note">{t.install.fedora.instructions}</p>
              <div class="requirement-tag">
                <i class="fa-solid fa-circle-info"></i> {t.install.requirements}
              </div>
            </div>
          </div>
          <div class="install-toggle" id="install-arch">
            <div class="install-card glass-card">
              <div class="terminal-header">
                <div class="dots"><span></span><span></span><span></span></div>
                <span class="terminal-title">{t.install.arch.title}</span>
              </div>
              <div class="terminal-body">
                <code>{t.install.arch.command}</code>
              </div>
              <p class="install-note">{t.install.arch.instructions}</p>
              <div class="requirement-tag">
                <i class="fa-solid fa-circle-info"></i> {t.install.requirements}
              </div>
              <p class="install-note install-warn">
                <i class="fa-solid fa-triangle-exclamation"></i> {t.install.arch.note}
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Complementary Section -->
      <section class="complement-section">
        <h2 class="section-title">
          <span class="gradient-text">{t.complement.title}</span>
        </h2>
        <p class="section-subtitle">{t.complement.desc}</p>
        
        <div class="complement-grid">
          <a href="https://kdeconnect.kde.org/" target="_blank" class="glass-card complement-card">
            <img src="https://hosted.inled.es/KDE_connectLogo.png" alt="KDE Connect" />
            <h3>{t.complement.kde}</h3>
          </a>
          <a href="https://github.com/GSConnect/gnome-shell-extension-gsconnect" target="_blank" class="glass-card complement-card">
            <img src="https://hosted.inled.es/gsconnect.png" alt="GSConnect" />
            <h3>{t.complement.gs}</h3>
          </a>
        </div>
      </section>

    </main>

    <footer class="page-footer">
      <div class="support-badge">
        <i class="fa-solid fa-heart gradient-icon"></i>
        <span>Made by Inled Group</span>
      </div>
    </footer>
  </div>
</Layout>

<script>
  document.querySelectorAll('.distro-item').forEach(function(item) {
    item.addEventListener('click', function() {
      var distro = this.dataset.distro;
      var target = document.getElementById('install-' + distro);
      if (!target) return;
      var isActive = this.classList.contains('active');
      document.querySelectorAll('.distro-item.active').forEach(function(el) {
        el.classList.remove('active');
      });
      document.querySelectorAll('.install-toggle.visible').forEach(function(el) {
        el.classList.remove('visible');
      });
      if (!isActive) {
        this.classList.add('active');
        target.classList.add('visible');
      }
    });
  });
</script>

<style>
  /* Hide language selector on this page since it is English-only */
  :global(.lang-selector-container) {
    display: none !important;
  }

  :root {
    --dt-primary: #3DDC84; /* Android Green */
    --dt-secondary: #073042;
    --glass-bg: rgba(20, 20, 25, 0.6);
    --glass-border: rgba(61, 220, 132, 0.2);
    --text-color: #ffffff;
    --text-muted: rgba(255, 255, 255, 0.6);
  }

  .droidtux-page {
    background-color: #050505;
    background-image: 
      radial-gradient(circle at 20% 20%, rgba(61, 220, 132, 0.05) 0%, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(7, 48, 66, 0.1) 0%, transparent 40%);
    color: var(--text-color);
    min-height: 100vh;
    font-family: 'Inter', -apple-system, sans-serif;
    padding-bottom: 50px;
  }

  .gradient-icon {
    background: linear-gradient(135deg, var(--dt-primary), #00ff88);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--dt-primary), #00ff88);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Hero Section */
  .hero-section {
    padding-top: 160px;
    padding-bottom: 100px;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-logo img {
    width: 140px;
    height: 140px;
    filter: drop-shadow(0 0 30px rgba(61, 220, 132, 0.3));
    margin-bottom: 40px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 30px;
    letter-spacing: -0.03em;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 40px;
  }

  .btn-primary, .btn-outline {
    padding: 14px 32px;
    border-radius: 14px;
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .btn-primary {
    background: var(--dt-primary);
    color: #000;
  }

  .btn-outline {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(61, 220, 132, 0.3);
  }

  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--dt-primary);
    transform: translateY(-4px);
  }

  /* Comparison Section */
  .comparison-section {
    padding: 80px 20px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    text-align: center;
    margin-bottom: 60px;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
  }

  .glass-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    padding: 40px;
    backdrop-filter: blur(12px);
    transition: transform 0.3s;
  }

  .comparison-card:hover {
    transform: translateY(-8px);
    border-color: var(--dt-primary);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px;
  }

  .comp-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .card-header h3 {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .card-body .desc {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
    font-size: 1.05rem;
  }

  .vs-divider {
    font-weight: 900;
    font-size: 0.8rem;
    color: var(--dt-primary);
    text-align: center;
    margin: 20px 0;
    position: relative;
    opacity: 0.5;
  }

  .vs-divider::before, .vs-divider::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 40%;
    height: 1px;
    background: var(--glass-border);
  }

  .vs-divider::before { left: 0; }
  .vs-divider::after { right: 0; }

  .diff {
    font-weight: 600;
    line-height: 1.5;
    color: #fff;
  }

  /* Screenshots Section */
  .screenshots-section {
    padding: 80px 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .screenshot-showcase {
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .screenshot-container {
    text-align: center;
  }

  .main-screenshot {
    width: 100%;
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    transition: transform 0.5s ease;
  }

  .main-screenshot:hover {
    transform: scale(1.02);
  }

  .screenshot-caption {
    margin-top: 20px;
    font-size: 1.1rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Compatibility Section */
  .compat-section {
    padding: 80px 20px;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .distro-grid {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .distro-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    padding: 20px;
    border-radius: 16px;
    transition: all 0.3s;
    min-width: 120px;
    border: 1px solid transparent;
    position: relative;
  }

  .distro-item img {
    width: 64px;
    height: 64px;
    object-fit: contain;
    filter: grayscale(0.3);
    transition: all 0.3s;
  }

  .distro-item span {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 0.3s;
  }

  .distro-item:hover img {
    filter: grayscale(0);
    transform: scale(1.1);
  }

  .distro-item:hover span {
    color: #fff;
  }

  .distro-item.active {
    background: rgba(61, 220, 132, 0.08);
    border-color: rgba(61, 220, 132, 0.2);
  }

  .distro-item.active img {
    filter: grayscale(0);
  }

  .distro-item.active span {
    color: var(--dt-primary);
  }

  .distro-item::after {
    content: '\f078';
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    font-size: 0.7rem;
    color: var(--dt-primary);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .distro-item:hover::after,
  .distro-item.active::after {
    opacity: 1;
  }

  .compat-hint {
    font-size: 0.8rem;
    color: var(--text-muted);
    opacity: 0.5;
    margin-bottom: 30px;
  }

  .install-toggle {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease, opacity 0.4s ease, margin 0.3s;
    opacity: 0;
    margin-bottom: 0;
  }

  .install-toggle.visible {
    max-height: 400px;
    opacity: 1;
    margin-bottom: 20px;
  }

  .install-warn {
    color: #ffbd2e !important;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 8px;
    border-top: 1px solid rgba(255, 189, 46, 0.15);
    margin-top: 0;
    padding-top: 16px;
  }

  .install-warn i {
    font-size: 1rem;
  }

  /* Install Card styles */
  .install-card {
    padding: 0;
    overflow: hidden;
  }

  .terminal-header {
    background: #1a1a1a;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 15px;
    border-bottom: 1px solid #333;
  }

  .dots {
    display: flex;
    gap: 8px;
  }

  .dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dots span:nth-child(1) { background: #ff5f56; }
  .dots span:nth-child(2) { background: #ffbd2e; }
  .dots span:nth-child(3) { background: #27c93f; }

  .terminal-title {
    font-size: 0.8rem;
    color: #888;
    font-family: monospace;
  }

  .terminal-body {
    padding: 30px;
    background: #0c0c0c;
  }

  .terminal-body code {
    font-family: 'Fira Code', monospace;
    color: var(--dt-primary);
    font-size: 1.2rem;
  }

  .install-note {
    padding: 24px 30px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .requirement-tag {
    margin: 0 30px 30px 30px;
    background: rgba(61, 220, 132, 0.1);
    border: 1px solid rgba(61, 220, 132, 0.2);
    padding: 12px 20px;
    border-radius: 12px;
    color: var(--dt-primary);
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Complementary Section */
  .complement-section {
    padding: 80px 20px;
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .section-subtitle {
    color: var(--text-muted);
    margin-bottom: 40px;
    font-size: 1.1rem;
  }

  .complement-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
  }

  .complement-card {
    padding: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    color: white;
  }

  .complement-card img {
    width: 64px;
    height: 64px;
    object-fit: contain;
  }

  .complement-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
  }

  .complement-card:hover {
    transform: translateY(-5px);
    background: rgba(61, 220, 132, 0.05);
  }

  /* Footer */
  .page-footer {
    padding: 60px 20px;
    display: flex;
    justify-content: center;
  }

  .support-badge {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
    .btn-primary, .btn-outline {
      width: 100%;
      max-width: 300px;
      justify-content: center;
    }
  }
</style>
