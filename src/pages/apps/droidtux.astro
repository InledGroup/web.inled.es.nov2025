---
import Layout from '../../layouts/Layout.astro';
import { getLangFromLocals } from '../../i18n/utils';

const lang = getLangFromLocals(Astro.locals);

const app = {
  id: "droidtux",
  title: "DroidTux",
  logo: "https://hosted.inled.es/droidtux.png",
  downloadUrl: "https://github.com/InledGroup/DroidTux/releases/latest",
  githubUrl: "https://github.com/InledGroup/DroidTux",
  releasesUrl: "https://github.com/InledGroup/DroidTux/releases/"
};

const translations = {
  es: {
    meta: {
      title: "DroidTux | Apps de Android en tu escritorio Linux",
      description: "Ejecuta tus aplicaciones de Android como ventanas nativas en Linux conectando tu teléfono."
    },
    nav: {
      comparison: "Comparativa",
      screenshots: "Capturas",
      install: "Instalación",
      github: "GitHub"
    },
    hero: {
      title: "Usa tus Apps de Android en 🐧 Linux",
      subtitle: " ✨ Conecta tu móvil y listo ",
      explore: "Ver Comparativa",
      download: "Descargar"
    },
    comparison: {
      title: "Por qué DroidTux es diferente",
      waydroid: {
        name: "Waydroid",
        desc: "Instala un sistema Android completo en tu PC. Suele usar versiones de Android obsoletas y consume muchos recursos.",
        diff: "DroidTux usa el Android de TU móvil, con TUS datos y apps actualizadas."
      },
      scrcpy: {
        name: "Scrcpy",
        desc: "Excelente para ver la pantalla, pero muy difícil de integrar aplicaciones individuales como ventanas.",
        diff: "DroidTux integra cada app como una ventana independiente en tu escritorio."
      }
    },
    install: {
      title: "Instalación en Arch Linux",
      command: "sudo pacman -U (nombrearchivo).pkg.tar.xz",
      instructions: "Descarga el paquete .pkg.tar.xz de las releases y ejecútalo en tu terminal.",
      requirements: "Requiere tener activada la depuración USB en tu teléfono Android."
    },
    complement: {
      title: "Mejora la experiencia",
      desc: "Para una integración total de archivos y notificaciones, recomendamos usar:",
      kde: "KDE Connect",
      gs: "GSConnect"
    }
  },
  en: {
    meta: {
      title: "DroidTux | Android Apps on your Linux Desktop",
      description: "Run your Android applications as native windows on Linux by connecting your phone."
    },
    nav: {
      comparison: "Comparison",
      screenshots: "Screenshots",
      install: "Install",
      github: "GitHub"
    },
    hero: {
      title: "Run Android Apps on 🐧 Linux",
      subtitle: " ✨ Just connect your phone ",
      explore: "See Comparison",
      download: "Download"
    },
    comparison: {
      title: "Why DroidTux is different",
      waydroid: {
        name: "Waydroid",
        desc: "Installs a full Android system on your PC. It often uses obsolete Android versions and consumes many resources.",
        diff: "DroidTux uses YOUR phone's Android, with YOUR data and updated apps."
      },
      scrcpy: {
        name: "Scrcpy",
        desc: "Excellent for screen mirroring, but very difficult to integrate individual apps as windows.",
        diff: "DroidTux integrates each app as an independent window on your desktop."
      }
    },
    install: {
      title: "Arch Linux Installation",
      command: "sudo pacman -U (filename).pkg.tar.xz",
      instructions: "Download the .pkg.tar.xz package from releases and run it in your terminal.",
      requirements: "Requires USB debugging enabled on your Android phone."
    },
    complement: {
      title: "Enhance the experience",
      desc: "For full file and notification integration, we recommend using:",
      kde: "KDE Connect",
      gs: "GSConnect"
    }
  }
};

const t = translations[lang] || translations.es;
---

<Layout title={t.meta.title} description={t.meta.description}>
  <div class="droidtux-page">
    
    <!-- Floating Navbar -->
    <nav class="floating-nav">
      <div class="nav-logo">
        <a href="/" style="text-decoration: none; color: white;">
          <img src={app.logo} alt="DroidTux" />
          <span>DroidTux</span>
        </a>
      </div>
      <div class="nav-links">
        <a href="#comparison">{t.nav.comparison}</a>
        <a href="#screenshots">{t.nav.screenshots}</a>
        <a href="#install">{t.nav.install}</a>
        <a href={app.githubUrl} target="_blank">{t.nav.github}</a>
      </div>
    </nav>

    <main>
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="hero-logo">
          <img src={app.logo} alt="DroidTux Logo" />
        </div>
        <h1 class="hero-title">
          {t.hero.title} <br/>
          <span class="gradient-text">{t.hero.subtitle}</span>
        </h1>
        <div class="hero-actions">
          <a href="#comparison" class="btn-outline">
            <i class="fa-solid fa-layer-group gradient-icon"></i>
            {t.hero.explore}
          </a>
          <a href={app.downloadUrl} class="btn-primary">
            <i class="fa-solid fa-download"></i>
            {t.hero.download}
          </a>
        </div>
      </section>

      <!-- Comparison Section -->
      <section id="comparison" class="comparison-section">
        <h2 class="section-title">
          <span class="gradient-text">{t.comparison.title}</span>
        </h2>
        
        <div class="comparison-grid">
          <!-- Waydroid -->
          <div class="glass-card comparison-card">
            <div class="card-header">
              <img src="https://hosted.inled.es/waydroid.svg" alt="Waydroid" class="comp-logo" />
              <h3>{t.comparison.waydroid.name}</h3>
            </div>
            <div class="card-body">
              <p class="desc">{t.comparison.waydroid.desc}</p>
              <div class="vs-divider">VS</div>
              <p class="diff"><i class="fa-solid fa-check gradient-icon"></i> {t.comparison.waydroid.diff}</p>
            </div>
          </div>

          <!-- Scrcpy -->
          <div class="glass-card comparison-card">
            <div class="card-header">
              <img src="https://hosted.inled.es/Scrcpy_logo.svg.png" alt="Scrcpy" class="comp-logo" />
              <h3>{t.comparison.scrcpy.name}</h3>
            </div>
            <div class="card-body">
              <p class="desc">{t.comparison.scrcpy.desc}</p>
              <div class="vs-divider">VS</div>
              <p class="diff"><i class="fa-solid fa-check gradient-icon"></i> {t.comparison.scrcpy.diff}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Screenshots Section -->
      <section id="screenshots" class="screenshots-section">
        <h2 class="section-title">
          <span class="gradient-text">{t.nav.screenshots}</span>
        </h2>
        <div class="screenshot-showcase">
          <div class="screenshot-container">
            <img src="https://hosted.inled.es/apps-droidtux-integradas.png" alt="DroidTux Integrated Apps" class="main-screenshot" />
            <div class="screenshot-caption">{lang === 'es' ? 'Apps integradas como ventanas nativas' : 'Apps integrated as native windows'}</div>
          </div>
          <div class="screenshot-container">
            <img src="https://hosted.inled.es/apps-droidtux-demo2.png" alt="DroidTux Demo" class="main-screenshot" />
            <div class="screenshot-caption">{lang === 'es' ? 'Multitarea real entre Android y Linux' : 'Real multitasking between Android and Linux'}</div>
          </div>
        </div>
      </section>

      <!-- Installation Section -->
      <section id="install" class="install-section">
        <h2 class="section-title">
          <span class="gradient-text">{t.install.title}</span>
        </h2>
        <div class="install-card glass-card">
          <div class="terminal-header">
            <div class="dots"><span></span><span></span><span></span></div>
            <span class="terminal-title">Terminal</span>
          </div>
          <div class="terminal-body">
            <code>{t.install.command}</code>
          </div>
          <p class="install-note">{t.install.instructions}</p>
          <div class="requirement-tag">
            <i class="fa-solid fa-circle-info"></i> {t.install.requirements}
          </div>
        </div>
      </section>

      <!-- Complementary Section -->
      <section class="complement-section">
        <h2 class="section-title">
          <span class="gradient-text">{t.complement.title}</span>
        </h2>
        <p class="section-subtitle">{t.complement.desc}</p>
        
        <div class="complement-grid">
          <a href="https://kdeconnect.kde.org/" target="_blank" class="glass-card complement-card">
            <img src="https://hosted.inled.es/KDE_connectLogo.png" alt="KDE Connect" />
            <h3>{t.complement.kde}</h3>
          </a>
          <a href="https://github.com/GSConnect/gnome-shell-extension-gsconnect" target="_blank" class="glass-card complement-card">
            <img src="https://hosted.inled.es/gsconnect.png" alt="GSConnect" />
            <h3>{t.complement.gs}</h3>
          </a>
        </div>
      </section>

    </main>

    <footer class="page-footer">
      <div class="support-badge">
        <i class="fa-solid fa-heart gradient-icon"></i>
        <span>Made by Inled Group</span>
      </div>
    </footer>
  </div>
</Layout>

<style>
  :root {
    --dt-primary: #3DDC84; /* Android Green */
    --dt-secondary: #073042;
    --glass-bg: rgba(20, 20, 25, 0.6);
    --glass-border: rgba(61, 220, 132, 0.2);
    --text-color: #ffffff;
    --text-muted: rgba(255, 255, 255, 0.6);
  }

  .droidtux-page {
    background-color: #050505;
    background-image: 
      radial-gradient(circle at 20% 20%, rgba(61, 220, 132, 0.05) 0%, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(7, 48, 66, 0.1) 0%, transparent 40%);
    color: var(--text-color);
    min-height: 100vh;
    font-family: 'Inter', -apple-system, sans-serif;
    padding-bottom: 50px;
  }

  .gradient-icon {
    background: linear-gradient(135deg, var(--dt-primary), #00ff88);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--dt-primary), #00ff88);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Floating Nav */
  .floating-nav {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 50px;
    padding: 8px 24px;
    display: flex;
    align-items: center;
    gap: 32px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
  }

  .nav-logo img {
    width: 28px;
    height: 28px;
  }

  .nav-links {
    display: flex;
    gap: 20px;
  }

  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.3s;
  }

  .nav-links a:hover {
    color: var(--dt-primary);
  }

  /* Hero Section */
  .hero-section {
    padding-top: 160px;
    padding-bottom: 100px;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-logo img {
    width: 140px;
    height: 140px;
    filter: drop-shadow(0 0 30px rgba(61, 220, 132, 0.3));
    margin-bottom: 40px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 30px;
    letter-spacing: -0.03em;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 40px;
  }

  .btn-primary, .btn-outline {
    padding: 14px 32px;
    border-radius: 14px;
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .btn-primary {
    background: var(--dt-primary);
    color: #000;
  }

  .btn-outline {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(61, 220, 132, 0.3);
  }

  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--dt-primary);
    transform: translateY(-4px);
  }

  /* Comparison Section */
  .comparison-section {
    padding: 80px 20px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    text-align: center;
    margin-bottom: 60px;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
  }

  .glass-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    padding: 40px;
    backdrop-filter: blur(12px);
    transition: transform 0.3s;
  }

  .comparison-card:hover {
    transform: translateY(-8px);
    border-color: var(--dt-primary);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px;
  }

  .comp-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .card-header h3 {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .card-body .desc {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
    font-size: 1.05rem;
  }

  .vs-divider {
    font-weight: 900;
    font-size: 0.8rem;
    color: var(--dt-primary);
    text-align: center;
    margin: 20px 0;
    position: relative;
    opacity: 0.5;
  }

  .vs-divider::before, .vs-divider::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 40%;
    height: 1px;
    background: var(--glass-border);
  }

  .vs-divider::before { left: 0; }
  .vs-divider::after { right: 0; }

  .diff {
    font-weight: 600;
    line-height: 1.5;
    color: #fff;
  }

  /* Screenshots Section */
  .screenshots-section {
    padding: 80px 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .screenshot-showcase {
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .screenshot-container {
    text-align: center;
  }

  .main-screenshot {
    width: 100%;
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    transition: transform 0.5s ease;
  }

  .main-screenshot:hover {
    transform: scale(1.02);
  }

  .screenshot-caption {
    margin-top: 20px;
    font-size: 1.1rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Install Section */
  .install-section {
    padding: 80px 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  .install-card {
    padding: 0;
    overflow: hidden;
  }

  .terminal-header {
    background: #1a1a1a;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 15px;
    border-bottom: 1px solid #333;
  }

  .dots {
    display: flex;
    gap: 8px;
  }

  .dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dots span:nth-child(1) { background: #ff5f56; }
  .dots span:nth-child(2) { background: #ffbd2e; }
  .dots span:nth-child(3) { background: #27c93f; }

  .terminal-title {
    font-size: 0.8rem;
    color: #888;
    font-family: monospace;
  }

  .terminal-body {
    padding: 30px;
    background: #0c0c0c;
  }

  .terminal-body code {
    font-family: 'Fira Code', monospace;
    color: var(--dt-primary);
    font-size: 1.2rem;
  }

  .install-note {
    padding: 24px 30px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .requirement-tag {
    margin: 0 30px 30px 30px;
    background: rgba(61, 220, 132, 0.1);
    border: 1px solid rgba(61, 220, 132, 0.2);
    padding: 12px 20px;
    border-radius: 12px;
    color: var(--dt-primary);
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Complementary Section */
  .complement-section {
    padding: 80px 20px;
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .section-subtitle {
    color: var(--text-muted);
    margin-bottom: 40px;
    font-size: 1.1rem;
  }

  .complement-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
  }

  .complement-card {
    padding: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    color: white;
  }

  .complement-card img {
    width: 64px;
    height: 64px;
    object-fit: contain;
  }

  .complement-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
  }

  .complement-card:hover {
    transform: translateY(-5px);
    background: rgba(61, 220, 132, 0.05);
  }

  /* Footer */
  .page-footer {
    padding: 60px 20px;
    display: flex;
    justify-content: center;
  }

  .support-badge {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .floating-nav {
      width: 90%;
      gap: 16px;
      padding: 8px 16px;
    }
    .nav-links { gap: 12px; }
    .nav-logo span { display: none; }
    
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
    .btn-primary, .btn-outline {
      width: 100%;
      max-width: 300px;
      justify-content: center;
    }
  }
</style>
