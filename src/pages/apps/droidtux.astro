---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

// Force page language to English
Astro.locals.lang = 'en';
const lang = 'en';

const app = {
  id: "droidtux",
  title: "DroidTux",
  logo: "https://hosted.inled.es/droidtux.png",
  downloadUrl: "https://github.com/InledGroup/DroidTux/releases/latest",
  githubUrl: "https://github.com/InledGroup/DroidTux",
  releasesUrl: "https://github.com/InledGroup/DroidTux/releases/"
};

const t = {
  meta: {
    title: "DroidTux | Android Apps on your Linux Desktop",
    description: "Run your Android applications as native windows on Linux by connecting your phone."
  },
  nav: {
    comparison: "Comparison",
    screenshots: "Screenshots",
    install: "Install",
    github: "GitHub"
  },
  hero: {
    title: "Use your phone's 📱 Android apps on 🐧 Linux",
    subtitle: "Just connect your phone over USB or Wi-Fi",
    explore: "Contribute",
    download: "Download Latest Release"
  },
  comparison: {
    title: "Why DroidTux is different",
    waydroid: {
      name: "Waydroid",
      desc: "Install an Android on an LXC on your PC. It normally uses obsolete versions which requires using third-party compilation options.",
      diff: "DroidTux displays the apps on your Android phone and everything runs on your phone. You can pick it up and take the information with you comfortably."
    },
    scrcpy: {
      name: "Scrcpy",
      desc: "What Droidtux uses below, perfect for expert users who want to have full control.",
      diff: "Droidtux makes it easy for users with an interface and app extraction automation."
    }
  },
  install: {
    title: "Installation Instructions",
    arch: {
      title: "Arch Linux Package",
      command: "sudo pacman -U droidtux-latest.pkg.tar.xz",
      instructions: "Download the .pkg.tar.xz archive from GitHub releases and run the local installation in your terminal.",
      note: "It is planned to upload it to AUR but for now they do not allow new accounts."
    },
    debian: {
      title: "Debian / Ubuntu Package",
      command: "sudo dpkg -i droidtux-latest.deb",
      instructions: "Download the .deb binary installer from the official GitHub releases and run dpkg to unpack.",
      note: ""
    },
    fedora: {
      title: "Fedora Package",
      command: "sudo rpm -i droidtux-latest.rpm",
      instructions: "Download the .rpm binary installer from releases and perform a standard rpm system installation.",
      note: ""
    },
    requirements: "It is recommended to enable USB debugging on the phone and from Droidtux there is a configurator to configure wireless debugging so that the phone is discoverable on the network."
  },
  compat: {
    title: "Compatible Distros",
    debian: "Debian / Ubuntu",
    fedora: "Fedora",
    arch: "Arch Linux",
    hint: "Choose your distribution tab below to view installation commands"
  },
  complement: {
    title: "And if you use these apps, you'll nail it!",
    desc: "These apps add more functionality and work perfectly alongside Droidtux.",
    kde: "KDE Connect",
    gs: "GSConnect"
  }
};
---

<Layout title={t.meta.title} description={t.meta.description}>
  <Header />
  
  <div class="droidtux-page">
    <main>
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="hero-logo">
          <img src={app.logo} alt="DroidTux Logo" />
        </div>
        <h1 class="hero-title">
          {t.hero.title}
        </h1>
        <p class="hero-subtitle">
          {t.hero.subtitle}
        </p>
        <div class="hero-actions">
          <a href={app.githubUrl}>
            <md-outlined-button>
              {t.hero.explore}
            </md-outlined-button>
          </a>
          <a href={app.downloadUrl} target="_blank">
            <md-filled-button>
              <span slot="icon" class="material-symbols-rounded">download</span>
              {t.hero.download}
            </md-filled-button>
          </a>
        </div>
      </section>

      <!-- Comparison Section -->
      <section id="comparison" class="comparison-section">
        <h2 class="section-title">
          {t.comparison.title}
        </h2>
        
        <div class="comparison-grid">
          <!-- Waydroid -->
          <div class="m3-card">
            <md-elevation></md-elevation>
            <div class="card-header">
              <img src="https://hosted.inled.es/waydroid.svg" alt="Waydroid" class="comp-logo" />
              <h3>{t.comparison.waydroid.name}</h3>
            </div>
            <md-divider></md-divider>
            <div class="card-body">
              <p class="desc">{t.comparison.waydroid.desc}</p>
              <p class="diff">
                <span class="material-symbols-rounded check-icon">check</span>
                <span>{t.comparison.waydroid.diff}</span>
              </p>
            </div>
          </div>

          <!-- Scrcpy -->
          <div class="m3-card">
            <md-elevation></md-elevation>
            <div class="card-header">
              <img src="https://hosted.inled.es/Scrcpy_logo.svg.png" alt="Scrcpy" class="comp-logo" />
              <h3>{t.comparison.scrcpy.name}</h3>
            </div>
            <md-divider></md-divider>
            <div class="card-body">
              <p class="desc">{t.comparison.scrcpy.desc}</p>
              <p class="diff">
                <span class="material-symbols-rounded check-icon">check</span>
                <span>{t.comparison.scrcpy.diff}</span>
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Screenshots Section -->
      <section id="screenshots" class="screenshots-section">
        <h2 class="section-title">
          {t.nav.screenshots}
        </h2>
        <div class="screenshot-showcase">
          <div class="screenshot-container">
            <md-elevation></md-elevation>
            <img src="https://hosted.inled.es/apps-droidtux-integradas.png" alt="DroidTux Integrated Apps" class="main-screenshot" />
            <div class="screenshot-caption">{lang === 'es' ? 'Apps integradas como ventanas nativas' : 'Apps integrated as native desktop windows'}</div>
          </div>

          <div class="screenshot-container">
            <md-elevation></md-elevation>
            <img src="https://hosted.inled.es/apps-droidtux-demo2.png" alt="DroidTux Demo" class="main-screenshot" />
            <div class="screenshot-caption">{lang === 'es' ? 'Multitarea real entre Android y Linux' : 'Multi-window multitasking between Android phone and Linux'}</div>
          </div>
        </div>
      </section>

      <!-- Compatibility & Installation Section -->
      <section id="install" class="install-section">
        <h2 class="section-title">{t.install.title}</h2>
        
        <div class="install-container">
          <md-elevation></md-elevation>
          <md-tabs active-tab-index="0" id="distro-tabs">
            <md-primary-tab>
              <img slot="icon" src="https://hosted.inled.es/debian.svg" class="tab-distro-icon" alt="" />
              {t.compat.debian}
            </md-primary-tab>
            <md-primary-tab>
              <img slot="icon" src="https://hosted.inled.es/Fedora_logo.svg" class="tab-distro-icon" alt="" />
              {t.compat.fedora}
            </md-primary-tab>
            <md-primary-tab>
              <img slot="icon" src="https://hosted.inled.es/archlinux-logo.png" class="tab-distro-icon" alt="" />
              {t.compat.arch}
            </md-primary-tab>
          </md-tabs>

          <div class="install-panels">
            <!-- Debian -->
            <div class="install-panel active">
              <div class="code-box">
                <md-elevation></md-elevation>
                <code>{t.install.debian.command}</code>
                <md-outlined-button class="copy-btn">
                  <span slot="icon" class="material-symbols-rounded">content_copy</span>
                  Copy
                </md-outlined-button>
              </div>
              <p class="install-note" style="margin-top: 1.5rem;">{t.install.debian.instructions}</p>
            </div>

            <!-- Fedora -->
            <div class="install-panel">
              <div class="code-box">
                <md-elevation></md-elevation>
                <code>{t.install.fedora.command}</code>
                <md-outlined-button class="copy-btn">
                  <span slot="icon" class="material-symbols-rounded">content_copy</span>
                  Copy
                </md-outlined-button>
              </div>
              <p class="install-note" style="margin-top: 1.5rem;">{t.install.fedora.instructions}</p>
            </div>

            <!-- Arch -->
            <div class="install-panel">
              <div class="code-box">
                <md-elevation></md-elevation>
                <code>{t.install.arch.command}</code>
                <md-outlined-button class="copy-btn">
                  <span slot="icon" class="material-symbols-rounded">content_copy</span>
                  Copy
                </md-outlined-button>
              </div>
              <p class="install-note" style="margin-top: 1.5rem; margin-bottom: 1.5rem;">{t.install.arch.instructions}</p>
              <div class="install-warn install-note">
                <span class="material-symbols-rounded warn-icon">warning</span>
                <span>{t.install.arch.note}</span>
              </div>
            </div>
          </div>

          <div class="requirement-tag">
            <span class="material-symbols-rounded info-icon">info</span>
            <span>{t.install.requirements}</span>
          </div>
        </div>
      </section>

      <!-- Complementary Section -->
      <section class="complements-section">
        <h2 class="section-title">
          {t.complement.title}
        </h2>
        <p class="complements-subtitle">{t.complement.desc}</p>
        
        <div class="complements-grid">
          <a href="https://kdeconnect.kde.org/" target="_blank" rel="noopener" class="m3-card complement-card">
            <md-elevation></md-elevation>
            <img src="https://hosted.inled.es/KDE_connectLogo.png" alt="KDE Connect" />
            <h3>{t.complement.kde}</h3>
          </a>
          <a href="https://github.com/GSConnect/gnome-shell-extension-gsconnect" target="_blank" rel="noopener" class="m3-card complement-card">
            <md-elevation></md-elevation>
            <img src="https://hosted.inled.es/gsconnect.png" alt="GSConnect" />
            <h3>{t.complement.gs}</h3>
          </a>
        </div>
      </section>
    </main>
  </div>
</Layout>

<script>
  import '@material/web/button/filled-button.js';
  import '@material/web/button/outlined-button.js';
  import '@material/web/tabs/tabs.js';
  import '@material/web/tabs/primary-tab.js';
  import '@material/web/divider/divider.js';
  import '@material/web/chips/chip-set.js';
  import '@material/web/chips/assist-chip.js';
  import '@material/web/elevation/elevation.js';

  function initInstallToggles() {
    const tabs = document.getElementById('distro-tabs');
    const panels = document.querySelectorAll('.install-panel');
    
    if (tabs) {
      tabs.addEventListener('change', () => {
        const activeIdx = (tabs as any).activeTabIndex;
        panels.forEach((panel, idx) => {
          panel.classList.toggle('active', idx === activeIdx);
        });
      });
    }

    // Copy command code logic
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const container = this.closest('.code-box');
        if (!container) return;
        const codeEl = container.querySelector('code');
        if (!codeEl) return;
        const codeText = codeEl.innerText.trim();

        navigator.clipboard.writeText(codeText).then(() => {
          const originalHTML = this.innerHTML;
          this.innerHTML = '<span slot="icon" class="material-symbols-rounded">check</span> Copied!';
          setTimeout(() => {
            this.innerHTML = originalHTML;
          }, 2000);
        });
      });
    });
  }

  // Bind events on page load and support Astro transitions
  document.addEventListener('astro:page-load', initInstallToggles);
  initInstallToggles();
</script>

<style>
  /* Hide language selector on this page since it is English-only */
  :global(.lang-selector-container) {
    display: none !important;
  }

  /* MD3 Base Theme Tokens */
  .droidtux-page {
    --md-sys-color-primary: #3DDC84; /* Android Green */
    --md-sys-color-on-primary: #00391c;
    --md-sys-color-primary-container: #00532d;
    --md-sys-color-on-primary-container: #82f7a9;
    
    --md-sys-color-surface: #111412;
    --md-sys-color-on-surface: #e1e3df;
    --md-sys-color-on-surface-variant: #a2aba4;
    --md-sys-color-surface-container: #1b1e1c;
    --md-sys-color-surface-container-high: #242926;
    --md-sys-color-background: #0a0d0b;
    --md-sys-color-on-background: #e1e3df;
    --md-sys-color-outline: #88938c;
    --md-sys-color-outline-variant: #3f4942;
    
    /* Typography tokens - inherit site-wide font family (Ubuntu) */
    --md-sys-typescale-label-large-font: 'Ubuntu', system-ui, -apple-system, sans-serif;
    --md-sys-typescale-body-large-font: 'Ubuntu', system-ui, -apple-system, sans-serif;
    --md-sys-typescale-body-medium-font: 'Ubuntu', system-ui, -apple-system, sans-serif;
    --md-sys-typescale-title-large-font: 'Ubuntu', system-ui, -apple-system, sans-serif;
    --md-sys-typescale-headline-large-font: 'Ubuntu', system-ui, -apple-system, sans-serif;
    
    background-color: var(--md-sys-color-background);
    color: var(--md-sys-color-on-background);
    min-height: 100vh;
    font-family: var(--md-sys-typescale-body-large-font);
    padding-bottom: 80px;
    background-image: 
      radial-gradient(circle at 10% 20%, rgba(61, 220, 132, 0.04) 0%, transparent 50%),
      radial-gradient(circle at 90% 80%, rgba(7, 48, 66, 0.08) 0%, transparent 50%);
  }

  /* Evita que los resets globales (* { padding: 0; margin: 0; }) rompan los componentes de Material Web */
  md-filled-button,
  md-outlined-button,
  md-tabs,
  md-primary-tab,
  md-assist-chip,
  md-divider,
  md-elevation {
    padding: revert !important;
    margin: revert !important;
  }

  /* Custom typography inheritance and premium MD3 button size/weight tokens */
  md-filled-button, md-outlined-button {
    font-family: var(--md-sys-typescale-label-large-font) !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 24px !important;
    height: 48px !important;
    box-sizing: border-box !important;
    --md-filled-button-container-height: 48px;
    --md-outlined-button-container-height: 48px;
    --md-filled-button-label-text-size: 15px;
    --md-outlined-button-label-text-size: 15px;
    --md-filled-button-label-text-weight: 700;
    --md-outlined-button-label-text-weight: 700;
  }

  /* Spacing between icon and text inside host-flexed buttons */
  md-filled-button .material-symbols-rounded, 
  md-outlined-button .material-symbols-rounded {
    font-size: 20px !important;
    margin-right: 8px !important;
    display: inline-block;
    line-height: 1;
    vertical-align: middle;
  }

  md-primary-tab, md-assist-chip {
    font-family: var(--md-sys-typescale-label-large-font) !important;
  }

  md-primary-tab {
    flex: 1; /* Distribuye las pestañas de forma proporcional a lo ancho de la barra */
    --md-primary-tab-active-indicator-color: var(--md-sys-color-primary);
    --md-primary-tab-active-label-text-color: var(--md-sys-color-primary);
    --md-primary-tab-active-icon-color: var(--md-sys-color-primary);
    --md-primary-tab-label-text-color: var(--md-sys-color-on-surface-variant);
    --md-primary-tab-icon-color: var(--md-sys-color-on-surface-variant);
    font-weight: 700;
  }

  md-tabs {
    --md-tabs-divider-color: var(--md-sys-color-outline-variant);
    width: 100%;
  }

  md-assist-chip {
    --md-assist-chip-container-color: rgba(255, 255, 255, 0.03);
    --md-assist-chip-outline-color: var(--md-sys-color-outline-variant);
    --md-assist-chip-label-text-color: var(--md-sys-color-on-surface);
  }

  /* Icon styles in page */
  .material-symbols-rounded {
    font-family: 'Material Symbols Rounded' !important;
    font-weight: normal;
    font-style: normal;
    font-size: 24px;
    line-height: 1;
    letter-spacing: normal;
    text-transform: none;
    display: inline-block;
    white-space: nowrap;
    word-wrap: normal;
    direction: ltr;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    font-feature-settings: 'liga';
  }

  .check-icon {
    color: var(--md-sys-color-primary);
    font-size: 20px;
    margin-top: 0.2rem;
  }

  .warn-icon {
    color: #ffbd2e;
    font-size: 22px;
  }

  .info-icon {
    color: var(--md-sys-color-primary);
    font-size: 22px;
  }

  .heart-icon {
    color: #ff5f56;
    font-size: 20px;
    z-index: 2;
  }

  /* Structural elements */
  .hero-section {
    padding-top: 140px;
    padding-bottom: 80px;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-logo {
    width: 140px;
    height: 140px;
    margin-bottom: 2.5rem;
  }

  .hero-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 0 35px rgba(61, 220, 132, 0.25));
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--md-sys-color-on-surface-variant);
    max-width: 650px;
    margin-bottom: 3rem;
    font-weight: 500;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  .hero-actions a {
    display: inline-flex;
    text-decoration: none;
  }

  /* Comparison Section */
  .comparison-section {
    padding: 80px 24px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    text-align: center;
    margin-bottom: 4rem;
    letter-spacing: -0.02em;
  }

  .comparison-grid {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .comparison-grid .m3-card {
    width: 100%;
    max-width: 450px;
  }

  .m3-card {
    position: relative;
    background: var(--md-sys-color-surface-container-low);
    border-radius: var(--md-sys-shape-corner-medium, 12px);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    --md-elevation-level: 1;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .m3-card:hover {
    --md-elevation-level: 2;
    transform: translateY(-4px);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    z-index: 2;
  }

  .comp-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .card-header h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    flex-grow: 1;
    z-index: 2;
  }

  .card-body .desc {
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.6;
    margin: 0;
    font-size: 1rem;
  }

  .card-body .diff {
    font-weight: 600;
    color: #fff;
    line-height: 1.5;
    margin: 0;
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  /* Screenshots Section */
  .screenshots-section {
    padding: 80px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .screenshot-showcase {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .screenshot-container {
    position: relative;
    background: var(--md-sys-color-surface-container-low);
    border-radius: var(--md-sys-shape-corner-medium, 12px);
    padding: 1.5rem;
    text-align: center;
    --md-elevation-level: 1;
    transition: transform 0.3s ease;
  }

  .main-screenshot {
    width: 100%;
    border-radius: var(--md-sys-shape-corner-medium, 12px);
    display: block;
    z-index: 2;
    position: relative;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .screenshot-container:hover .main-screenshot {
    transform: scale(1.01);
  }

  .screenshot-caption {
    margin-top: 1.5rem;
    font-size: 1rem;
    color: var(--md-sys-color-on-surface-variant);
    font-weight: 600;
    z-index: 2;
    position: relative;
  }

  /* Installation Section */
  .install-section {
    padding: 80px 24px;
    max-width: 750px;
    margin: 0 auto;
  }

  .install-container {
    position: relative;
    background: var(--md-sys-color-surface-container-low);
    border-radius: var(--md-sys-shape-corner-medium, 12px);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    --md-elevation-level: 1;
  }

  .tab-distro-icon {
    width: 24px;
    height: 24px;
    object-fit: contain;
    margin-right: 0.5rem;
  }

  .install-panels {
    z-index: 2;
  }

  .install-panel {
    display: none;
    animation: fadeIn 0.4s ease forwards;
  }

  .install-panel.active {
    display: block;
  }

  .code-box {
    position: relative;
    background: #000;
    border-radius: var(--md-sys-shape-corner-small, 8px);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    z-index: 2;
    --md-elevation-level: 1;
  }

  .code-box code {
    font-family: 'Fira Code', monospace;
    color: var(--md-sys-color-primary);
    font-size: clamp(1rem, 2vw, 1.2rem);
    word-break: break-all;
  }

  .copy-btn {
    flex-shrink: 0 !important; /* Previene que flexbox deforme y aplaste el botón en resoluciones bajas */
    height: 40px !important;
    padding: 0 16px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .install-note {
    font-size: 0.95rem;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.6;
    margin: 0;
  }

  .install-warn {
    color: #ffbd2e;
    font-weight: 500;
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    border-top: 1px solid rgba(255, 189, 46, 0.15);
    padding-top: 1.25rem;
  }

  .install-warn .warn-icon {
    margin-top: 0.1rem;
