---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getLangFromLocals } from '../../i18n/utils';

const lang = getLangFromLocals(Astro.locals);

const translations = {
  es: {
    meta: {
      title: "AppInstall - Tu gestor de paquetes todo en uno para cualquier distro Linux",
      description: "Instala, desinstala y gestiona paquetes de forma profesional. Soporte para APT, Homebrew, DNF, PWAs y mas."
    },
    hero: {
      title: "Tu gestor de paquetes, todo en uno",
      desc: "AppInstall es la herramienta definitiva para gestionar tu software en Linux. Olvidate de la terminal para gestionar aplicaciones y paquetes. Hazlo todo con un clic.",
      download: "Descargar AppInstall",
      repo: "Ver en GitHub"
    },
    grid: {
      title: "Todo lo que hacias con comandos, ahora con clics",
      items: [
        { title: "Desinstalador", desc: "Elimina aplicaciones que las stores no te listan, como paquetes del sistema y apps no graficas." },
        { title: "Busca apps", desc: "Encuentra cualquier aplicacion en los repositorios de APT, Homebrew, DNF, Flathub, Snap y AUR desde una sola interfaz." },
        { title: "Creador de PWAs", desc: "Convierte cualquier sitio web en una aplicacion de escritorio nativa con un solo clic. No pesa mas, no te instala Electron." },
        { title: "Soporta todas las distros", desc: "Disfruta de la comodidad de Appinstall en cualquier distro como Debian, Fedora o Arch." },
        { title: "Instalador sencillo", desc: "Instala cualquier paquete facilmente." },
        { title: "Limpia basura y soluciona errores", desc: "Corrige instalaciones fallidas con un clic. Borra basura de tu sistema con otro clic." }
      ]
    },
    demo: {
      title: "En accion",
      desc: "Mira como funciona AppInstall."
    },
    final: {
      title: "Empieza a usar AppInstall hoy",
      desc: "Compatible con Ubuntu, Debian, Fedora y Arch Linux.",
      download: "Descargar",
      oss: "Gratuito y de Codigo Abierto"
    }
  },
  en: {
    meta: {
      title: "AppInstall - Your All-in-One Package Manager for Any Linux Distribution",
      description: "Professionally install, uninstall, and manage packages. Full support for APT, Homebrew, DNF, PWAs, and more."
    },
    hero: {
      title: "Your all-in-one package manager",
      desc: "AppInstall is the ultimate tool for managing your software on Linux. Forget the terminal for managing applications and packages. Do it all with a single click.",
      download: "Download AppInstall",
      repo: "View on GitHub"
    },
    grid: {
      title: "Everything you did with commands, now with clicks",
      items: [
        { title: "Uninstaller", desc: "Remove applications that app stores don't list, such as system packages and non-graphical apps." },
        { title: "Search Apps", desc: "Find any application in APT, Homebrew, DNF, Flathub, Snap, and AUR repositories from a single interface." },
        { title: "PWA Creator", desc: "Convert any website into a native desktop application with a single click. No extra weight, no Electron installation." },
        { title: "Multi-Distro Support", desc: "Enjoy AppInstall on any distribution like Debian, Fedora, or Arch Linux." },
        { title: "Simple Installer", desc: "Easily install any package with a single click." },
        { title: "Clean Junk & Fix Errors", desc: "Fix failed installations with one click. Clear junk from your system with another." }
      ]
    },
    demo: {
      title: "See it in action",
      desc: "Watch how AppInstall works."
    },
    final: {
      title: "Start using AppInstall today",
      desc: "Compatible with Ubuntu, Debian, Fedora, and Arch Linux.",
      download: "Download",
      oss: "Free and Open Source"
    }
  }
};

const t = translations[lang] || translations.es;
---

<Layout title={t.meta.title} description={t.meta.description}>
  <Header />

  <div class="page">
    <main>

      <!-- Hero -->
      <section class="hero">
        <img src="https://hosted.inled.es/swiftinstall-logo.png" alt="AppInstall" class="hero-logo" />
        <h1 class="hero-title">{t.hero.title}</h1>
        <p class="hero-desc">{t.hero.desc}</p>
        <div class="hero-btns">
          <a href="https://github.com/InledGroup/appinstall/releases/latest" class="pill pill-white">
            <span class="pill-inner">
              <i class="fa-solid fa-download"></i>
              {t.hero.download}
            </span>
          </a>
          <a href="https://github.com/InledGroup/appinstall" class="pill pill-dark">
            <span class="pill-inner">
              <i class="fa-brands fa-github"></i>
              {t.hero.repo}
            </span>
          </a>
        </div>
      </section>

      <!-- Demo Video 
      <section class="demo">
        <div class="demo-wrap">
          <div class="demo-video">
            <iframe
              src="https://www.youtube.com/embed/dQw4w9WgXcQ"
              title="AppInstall Demo"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </section> -->

      <!-- Features Grid -->
      <section class="features" id="features">
        <h2 class="section-title">{t.grid.title}</h2>
        <div class="features-grid">
          {t.grid.items.map((f) => (
            <div class="feature-card">
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Final CTA -->
      <section class="final">
        <h2 class="final-title">{t.final.title}</h2>
        <p class="final-desc">{t.final.desc}</p>
        <a href="https://github.com/InledGroup/appinstall/releases/latest" class="pill pill-white">
          <span class="pill-inner">
            <i class="fa-solid fa-download"></i>
            {t.final.download}
          </span>
        </a>
        <p class="final-oss">{t.final.oss}</p>
      </section>

    </main>
  </div>
</Layout>

<style is:global>
  body { background: #0a0a0a !important; }
</style>

<style>
  :root {
    --fg: #ffffff;
    --fg-dim: rgba(255, 255, 255, 0.45);
    --fg-mid: rgba(255, 255, 255, 0.6);
    --bg: #0a0a0a;
    --surface: rgba(255, 255, 255, 0.04);
    --border: rgba(255, 255, 255, 0.08);
    --depth-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.5), inset 0 4px 12px rgba(0, 0, 0, 0.3);
    --depth-border: 1px solid rgba(255, 255, 255, 0.06);
    --radius: 10px;
    --radius-pill: 9999px;
  }

  .page {
    min-height: 100vh;
    background: var(--bg);
    padding-top: 72px;
    padding-bottom: 60px;
  }

  /* ============================
     PILLS
     ============================ */
  .pill {
    display: inline-flex;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.3s ease;
  }

  .pill:hover { transform: translateY(-2px); }

  .pill-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    position: relative;
    z-index: 2;
    border-radius: var(--radius-pill);
  }

  .pill-white {
    background: #fff;
    color: #0a0a0a;
    box-shadow: 0 2px 20px rgba(255, 255, 255, 0.1);
  }

  .pill-white:hover {
    box-shadow: 0 4px 30px rgba(255, 255, 255, 0.18);
  }

  .pill-white .pill-inner { color: #0a0a0a; }

  .pill-dark {
    background: #111;
    color: var(--fg);
    box-shadow: var(--depth-shadow);
    border: var(--depth-border);
  }

  .pill-dark:hover {
    box-shadow: var(--depth-shadow), 0 0 20px rgba(255, 255, 255, 0.04);
  }

  .pill-dark .pill-inner { color: var(--fg); }

  /* ============================
     HERO
     ============================ */
  .hero {
    padding: 48px 32px 40px;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-logo {
    width: 72px;
    height: 72px;
    margin-bottom: 20px;
    filter: drop-shadow(0 4px 20px rgba(255, 255, 255, 0.08));
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: var(--fg);
    line-height: 1.2;
    margin-bottom: 14px;
    letter-spacing: -0.02em;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--fg-mid);
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto 28px;
  }

  .hero-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ============================
     DEMO VIDEO
     ============================ */
  .demo {
    padding: 16px 32px 48px;
    max-width: 800px;
    margin: 0 auto;
  }

  .demo-wrap {
    width: 100%;
  }

  .demo-video {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--depth-shadow);
    border: var(--depth-border);
    background: #000;
  }

  .demo-video iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* ============================
     FEATURES
     ============================ */
  .features {
    padding: 56px 32px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--fg);
    text-align: center;
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px;
  }

  .feature-card {
    padding: 24px;
    background: var(--surface);
    border: var(--depth-border);
    box-shadow: var(--depth-shadow);
    border-radius: var(--radius);
    transition: border-color 0.3s ease;
  }

  .feature-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 6px;
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--fg-mid);
    line-height: 1.5;
  }

  /* ============================
     FINAL CTA
     ============================ */
  .final {
    padding: 56px 32px 48px;
    text-align: center;
  }

  .final-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 8px;
  }

  .final-desc {
    font-size: 0.95rem;
    color: var(--fg-dim);
    margin-bottom: 28px;
  }

  .final-oss {
    font-size: 0.8rem;
    color: var(--fg-dim);
    margin-top: 16px;
  }

  /* ============================
     RESPONSIVE
     ============================ */
  @media (max-width: 768px) {
    .hero { padding: 32px 20px 32px; }
    .demo { padding-left: 16px; padding-right: 16px; }
    .features { padding-left: 16px; padding-right: 16px; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
