---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
export const prerender = false;
import ContactForm from '../components/ContactForm.astro';

import { getLangFromLocals, useTranslations } from '../i18n/utils';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
---

<Layout
  title="Contacto - Inled Group"
  description="¿Alguna duda? Resuélvela con nosotros."
>
  <Header />

  <main class="contact-page-content">
    <div class="page-hero">
      <div class="hero-content">
        <h1 class="hero-title">¿Hablamos?</h1>
        <p class="hero-description">
          Contacta con nosotros
        </p>
      </div>
    </div>

    <div class="contact-section-wrapper">
      <div class="recommendation-container">
        <p class="recommendation">
          {lang === 'es' ? 'Para una atención inmediata, utiliza el formulario:' : 'For immediate attention, please use the form below:'}
        </p>
      </div>

      <ContactForm showBackground={false} />

      <div class="email-footer-section">
        <div class="email-footer-card">
          <p class="email-footer-label">
            {lang === 'es' ? 'O si lo prefieres, escríbenos directamente a' : 'Or if you prefer, write to us directly at'} 
          </p>
          <div class="email-copy-wrapper">
            <a href="mailto:hi@inled.es" class="email-address">hi@inled.es</a>
            <button id="copy-email" class="copy-button" aria-label="Copy email">
              <span class="copy-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-copy"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
              </span>
              <span class="success-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>

  </main>

<style>
  .contact-page-content {
    position: relative;
    min-height: 100vh;
    width: 100%;
    overflow: hidden;
    padding-bottom: 8rem;
  }

  .contact-page-content::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url('https://hosted.inled.es/better.inled.svg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
    filter: brightness(0.5);
    z-index: -2;
  }

  .contact-page-content::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
    z-index: -1;
  }

  .page-hero {
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .hero-content {
    text-align: center;
    max-width: 800px;
  }

  .hero-title {
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: #fff;
    text-shadow: 0 0 50px rgba(255, 255, 255, 0.2);
  }

  .hero-description {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
  }

  .contact-section-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .recommendation-container {
    margin-bottom: -3rem;
    text-align: center;
    position: relative;
    z-index: 20;
  }

  .recommendation {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin: 0;
  }

  .email-footer-section {
    width: 100%;
    max-width: 650px;
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .email-footer-card {
    width: 100%;
    background: rgba(10, 10, 10, 0.4);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 32px;
    padding: 2.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .email-footer-label {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.1rem;
    margin: 0;
    font-weight: 300;
  }

  .email-copy-wrapper {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.8rem 2rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .email-copy-wrapper:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  .email-address {
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.02em;
    font-family: 'Ubuntu', sans-serif;
  }

  .copy-button {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    position: relative;
    padding: 0;
  }

  .copy-button:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .success-icon {
    position: absolute;
    opacity: 0;
    transform: scale(0.5);
    color: #2ed573;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .copy-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .copy-button.success .copy-icon {
    opacity: 0;
    transform: scale(0.5);
  }

  .copy-button.success .success-icon {
    opacity: 1;
    transform: scale(1);
  }

  @media (max-width: 768px) {
    .page-hero { min-height: 30vh; }
    .hero-title { font-size: 3.5rem; }
    .recommendation-container { margin-bottom: -1.5rem; }
    .recommendation { font-size: 0.75rem; letter-spacing: 0.15em; }
    .email-footer-card { padding: 2rem 1.5rem; }
    .email-address { font-size: 1.2rem; }
    .email-copy-wrapper { gap: 1rem; padding: 0.6rem 1.2rem; }
    .copy-button { width: 38px; height: 38px; }
  }
</style>

<script>
  function initCopy() {
    const copyBtn = document.getElementById('copy-email');
    const emailAddr = 'hi@inled.es';

    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(emailAddr);
        copyBtn.classList.add('success');
        setTimeout(() => {
          copyBtn.classList.remove('success');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy: ', err);
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initCopy);
  document.addEventListener('astro:page-load', initCopy);
</script>
</Layout>