---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
export const prerender = false;

import Hero from '../components/Hero.astro';
import AppUpdates from '../components/AppUpdates.astro';
import ScrollSection from '../components/ScrollSection.astro';
import StatsCounter from '../components/StatsCounter.astro';
import HeroCTA from '../components/HeroCTA.astro';
import FeatureSection from '../components/FeatureSection.astro';
import { apps } from '../config/apps';
import { saas } from '../config/saas';
import SaaSShowcase from '../components/SaaSShowcase.astro';

import NewsletterSection from '../components/NewsletterSection.astro';
import BlogSection from '../components/BlogSection.astro';
import Changelog from '../components/Changelog.astro';
import Planning from '../components/Planning.astro';
import Contribute from '../components/Contribute.astro';
import CommunityLinks from '../components/CommunityLinks.astro';
import IncubatorProjects from '../components/IncubatorProjects.astro';
import NewsletterNotification from '../components/NewsletterNotification.astro';
import ContactForm from '../components/ContactForm.astro';

import { getLangFromLocals, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
const translatePath = useTranslatedPath();

const stats = [
  { value: 60, label: t('stats.apps'), suffix: '+' },
  { value: 100, label: t('stats.users'), suffix: '%' },
];

const appProducts = apps.filter(a => !a.archive).map(a => ({
  icon: a.icon,
  name: a.name,
  description: a.description[lang],
  link: a.link,
  notice: a.notice ? {
    type: a.notice.type,
    message: a.notice.message[lang]
  } : undefined
}));

const saasProducts = saas.filter(s => !s.archive).map(s => ({
  icon: s.icon,
  name: s.name,
  description: s.description[lang],
  link: s.link
}));

const archivedProducts = [
  ...saas.filter(s => s.archive).map(s => ({
    icon: s.icon,
    name: s.name,
    description: s.description[lang],
    link: s.link
  })),
  ...apps.filter(a => a.archive).map(a => ({
    icon: a.icon,
    name: a.name,
    description: a.description[lang],
    link: a.link,
    notice: a.notice ? {
      type: a.notice.type,
      message: a.notice.message[lang]
    } : undefined
  }))
];
---

<Layout title="Inled Group - Dream, Build" description={t('scroll.description')}>
  <Header />
  <Hero />

  <div id="showcase-strip" data-lenis-prevent>
    <div class="showcase-track">
      <SaaSShowcase
        ids={['office', 'start', 'mypdf', 'mymetadata', 'seafari']}
        title={lang === 'es' ? 'No dependas de quien no respeta tu privacidad' : 'Do not depend on those who do not respect your privacy'}
        subtitle={lang === 'es' ? 'Alternativas Europeas, programadas en España, que no venden tus datos por que básicamente no los obtienen.' : 'European alternatives, programmed in Spain, that do not sell your data because they basically do not obtain it.'}
      />

      <SaaSShowcase
        ids={['appinstall', 'codexbar-gnome', 'vozes']}
        title={lang === 'es' ? 'Ya no hay excusa: ¡usa Linux!' : 'There is no excuse anymore: use Linux!'}
        subtitle={lang === 'es' ? 'Haz que Linux sea más fácil de usar y tenga lo que necesitas. Potentes herramientas para que disfrutes usando Linux.' : 'Make Linux easier to use and have what you need. Powerful tools for you to enjoy using Linux'}
      />

      <SaaSShowcase
        ids={['macboat', 'droidtux']}
        title={lang === 'es' ? 'Nadie lo había pensado. Pues lo programamos.' : 'Nobody had thought about it. So we programmed it.'}
        subtitle={lang === 'es' ? 'Los límites de los sistemas operativos desaparecen gracias a estas aplicaciones, listas para que comiences a disfrutar de una experiencia del futuro' : 'The limits of operating systems disappear thanks to these applications, ready for you to start enjoying an experience of the future.'}The limits of operating systems disappear thanks to these applications, ready for you to start enjoying an experience of the future
 />
      <SaaSShowcase
        ids={['codexbar-gnome', 'mdpedia', 'ai-exporter', 'web2skill', 'vozes']}
        title={lang === 'es' ? 'Exprime las capacidades de la IA' : 'Unleash the capabilities of AI'}
        subtitle={lang === 'es' ? 'Todas estas apps son privadas y te permiten exprimir las capacidades de la IA' : 'All these apps are private and allow you to take advantage of the capabilities of AI'}
      />

      <SaaSShowcase
        ids={['bautilus', 'tabnest', 'cleany', 'moodlenotifier']}
        title={lang === 'es' ? 'Desbloquea el potencial del navegador' : "Unlock the browser's potential"}
        subtitle={lang === 'es' ? 'Extensiones que transforman tu navegador en algo mucho más potente.' : 'Extensions that turn your browser into something far more powerful.'}
      />

      <SaaSShowcase
        ids={['oap']}
        title={lang === 'es' ? 'Consigue tus objetivos' : "Achieve your goals"}
        subtitle={lang === 'es' ? 'Organiza tu vida con objetivos claros y seguimiento visual.' : 'Organize your life with clear goals and visual tracking.'}
      />



      <SaaSShowcase
        ids={['mdpdf', 'inlinked', 'inmd', 'inqr', 'mymetadata']}
        badge={lang === 'es' ? 'Inteligencia Libre' : 'Open Intelligence'}
        title={lang === 'es' ? 'Para cada cosa, un editor' : 'For every need, an editor'}
        subtitle={lang === 'es' ? 'Sin instalar, con privacidad. Todo se procesa en tu navegador.' : 'No installation, full privacy. Everything runs in your browser.'}
      />
    </div>
  </div>

  <div class="comunidad-wrapper">
    <section class="comunidad-header-section">
      <div class="comunidad-header-container">
        <h2 class="comunidad-title">{t('community.title')}</h2>
        <p class="comunidad-subtitle">{t('community.subtitle')}</p>
        <div class="comunidad-contribute-inline">
          <div class="contribute-card-inline">
            <div class="contribute-card-content">
              <h3 class="contribute-card-title">{t('contribute.title')}</h3>
              <p class="contribute-card-text">{t('contribute.text')}</p>
              <p class="contribute-card-warning">{t('contribute.warning')}</p>
            </div>
            <div class="contribute-card-actions">
              <a href="https://discord.com/invite/PSeTkDMnr" target="_blank" rel="noopener noreferrer" class="btn-card btn-card-discord">
                <i class="fa-brands fa-discord"></i>
                {t('contribute.discord')}
              </a>
              <a href="https://matrix.inled.es" target="_blank" rel="noopener noreferrer" class="btn-card btn-card-matrix">
                {t('contribute.matrix')}
              </a>
              <a href="https://github.com/InledGroup" target="_blank" rel="noopener noreferrer" class="btn-card btn-card-github">
                <i class="fa-brands fa-github"></i>
                {t('contribute.github')}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CommunityLinks />
    <AppUpdates />
    <BlogSection />
    <IncubatorProjects />
    <Changelog />
   <!-- <Planning />  -->
    <!-- <Contribute /> -->



  </div>

<!--  <HeroCTA
    title={t('cta.title')}
    description={t('cta.description')}
    primaryButtonText={t('cta.primary')}
    secondaryButtonText={t('cta.secondary')}
    primaryButtonHref="/proyectos"
    secondaryButtonHref="#apps"
  />
  <!-- <FeatureSection
    title={t('feature.edge.title')}
    description={t('feature.edge.description')}
    imageSrc="https://hosted.inled.es/edgeai.png"
    buttonText={t('feature.edge.button')}
    buttonHref="https://edge.inled.es/landing"
    reversed={true}
  />

  <FeatureSection
    title={t('feature.ai.title')}
    description={t('feature.ai.description')}
    imageSrc="https://hosted.inled.es/ainclouddeco.png"
    buttonText={t('feature.ai.button')}
    buttonHref="https://ai.inled.es"
  />-->


  {archivedProducts.length > 0 && (
    <section class="archived-section">
      <div class="archived-container">
        <div class="archived-header">
          <h2 class="archived-title">{lang === 'es' ? 'Archivos' : 'Archives'}</h2>
          <p class="archived-subtitle">
            {lang === 'es' ? 'Proyectos que por ahora no se mantienen' : 'Projects not maintained for now'}
          </p>
        </div>
        
        <div class="archived-grid">
          {archivedProducts.map(product => (
            <a href={product.link} class="archived-card">
              <div class="archived-card-icon">
                <img src={product.icon} alt={product.name} />
              </div>
              <div class="archived-card-content">
                <h3 class="archived-card-title">{product.name}</h3>
                <p class="archived-card-desc">{product.description}</p>
