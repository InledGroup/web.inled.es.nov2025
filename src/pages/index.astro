        'oap': 'https://hosted.inled.es/oap-shot.png',
    }}
  />

  <SaaSShowcase
    ids={['bastion',]}
    reversed={true}
    badge={lang === 'es' ? 'Inteligencia Libre' : 'Open Intelligence'}
    title={lang === 'es' ? 'Seguridad cuando la necesitas' : "Security when you need it"}
    screenshots={{
        'bastion': 'https://hosted.inled.es/bastion-shot.png',
    }}
  />

  <SaaSShowcase
    ids={['mdpdf', 'inlinked', 'inmd', 'inqr', 'mymetadata']}
    badge={lang === 'es' ? 'Inteligencia Libre' : 'Open Intelligence'}
    title={lang === 'es' ? 'Para cada cosa, un editor. Sin instalar, con privacidad' : "For every need, an editor. No installation required, with privacy guaranteed."}
    screenshots={{
        'mdpdf': 'https://hosted.inled.es/mdpdf-shot.png',
        'inlinked': 'https://hosted.inled.es/inlinked-shot.png',
        'inqr': 'https://hosted.inled.es/inqr-shot.png',
        'inmd': 'https://hosted.inled.es/inmd-shot.png',
        'mymetadata': 'https://hosted.inled.es/mymetadata-shot.png',
    }}
  />

  <Planning />

  <Changelog />

  <BlogSection />

<!--  <HeroCTA
    title={t('cta.title')}
    description={t('cta.description')}
    primaryButtonText={t('cta.primary')}
    secondaryButtonText={t('cta.secondary')}
    primaryButtonHref="/proyectos"
    secondaryButtonHref="#apps"
  />
  <!-- <FeatureSection
    title={t('feature.edge.title')}
