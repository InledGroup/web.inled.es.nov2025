---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
export const prerender = false;

import Hero from '../components/Hero.astro';
import ScrollSection from '../components/ScrollSection.astro';
import StatsCounter from '../components/StatsCounter.astro';
import HeroCTA from '../components/HeroCTA.astro';
import ProductsGrid from '../components/ProductsGrid.astro';
import FeatureSection from '../components/FeatureSection.astro';
import { apps } from '../config/apps';
import { saas } from '../config/saas';
import SaaSShowcase from '../components/SaaSShowcase.astro';

import NewsletterSection from '../components/NewsletterSection.astro';
import BlogSection from '../components/BlogSection.astro';
import Changelog from '../components/Changelog.astro';
import Planning from '../components/Planning.astro';
import NewsletterNotification from '../components/NewsletterNotification.astro';
import ContactForm from '../components/ContactForm.astro';

import { getLangFromLocals, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
const translatePath = useTranslatedPath();

const stats = [
  { value: 60, label: t('stats.apps'), suffix: '+' },
  { value: 100, label: t('stats.users'), suffix: '%' },
];

const appProducts = apps.map(a => ({
  icon: a.icon,
  name: a.name,
  description: a.description[lang],
  link: a.link,
  notice: a.notice ? {
    type: a.notice.type,
    message: a.notice.message[lang]
  } : undefined
}));

const saasProducts = saas.map(s => ({
  icon: s.icon,
  name: s.name,
  description: s.description[lang],
  link: s.link
}));
---

<Layout title="Inled Group - Dream, Build" description={t('scroll.description')}>
  <Header />
  <Hero />

  <SaaSShowcase
    ids={['office', 'start', 'mypdf']}
    badge={lang === 'es' ? 'Soberanía Digital' : 'Digital Sovereignty'}
    title={lang === 'es' ? 'Tus herramientas, bajo tu control' : 'Your tools, under your control'}
    screenshots={{
        'office': 'https://hosted.inled.es/insuite-office-matrix.gif',
        'start': 'https://hosted.inled.es/start-shot.png',
        'mypdf': 'https://hosted.inled.es/mypdf-shot.png'
    }}
  />

  <SaaSShowcase
    ids={['appinstall', 'codexbar-gnome', 'vozes',]}
    reversed={true}
    badge={lang === 'es' ? 'Inteligencia Libre' : 'Open Intelligence'}
    title={lang === 'es' ? 'Linux a tope!' : 'Linux at its best!'}
    screenshots={{
        'appinstall': 'https://hosted.inled.es/appinstall-shot.png',
        'codexbar-gnome': 'https://hosted.inled.es/codexbar-shot.gif',
        'vozes': 'https://hosted.inled.es/vozes-frame.png'
    }}

  />

  <SaaSShowcase
    ids={['codexbar-gnome', 'ai-exporter', 'edgeai', 'agent-tunnel', 'web2skill', 'vozes', 'gemini-notifier', 'weby',]}
    badge={lang === 'es' ? 'Inteligencia Libre' : 'Open Intelligence'}
    title={lang === 'es' ? 'La IA puede hacer mucho.' : 'AI can do a lot'}
    screenshots={{
        'codexbar-gnome': 'https://hosted.inled.es/codexbar-shot.gif',
        'ai-exporter': 'https://hosted.inled.es/aiexporter-converter.gif',
        'edgeai': 'https://hosted.inled.es/edgeai.png',
        'agent-tunnel': 'https://hosted.inled.es/new-agent-tunnel.png',
        'web2skill': 'https://hosted.inled.es/web2skill.mp4',
        'vozes': 'https://hosted.inled.es/vozes-frame.png',
        'weby': 'https://hosted.inled.es/demoweby.mp4',
    }}
  />

  <SaaSShowcase
    ids={['bautilus', 'tabnest', 'cleany', 'moodlenotifier',]}
    reversed={true}
    badge={lang === 'es' ? 'Inteligencia Libre' : 'Open Intelligence'}
    title={lang === 'es' ? 'Desbloquea el potencial del navegador' : "Unlock the browser's potential"}
    screenshots={{
        'bautilus': 'https://hosted.inled.es/bautilus-demo.png',
        'tabnest': 'https://hosted.inled.es/tabnest-shot.png',
        'moodlenotifier': 'https://hosted.inled.es/moodlenotifier-screenshot1.png',
    }}
  />

  <SaaSShowcase
    ids={['oap',]}
    badge={lang === 'es' ? 'Inteligencia Libre' : 'Open Intelligence'}
    title={lang === 'es' ? 'Consigue tus objetivos' : "Achieve your goals"}
