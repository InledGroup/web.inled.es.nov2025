</Layout>

<style>
  #showcase-strip {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  .showcase-track {
    display: flex;
    width: 100%;
    height: 100%;
    will-change: transform;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 1024px), (orientation: portrait) {
    #showcase-strip {
      width: 100%;
      height: auto;
      overflow: visible;
    }

    .showcase-track {
      flex-direction: column;
      width: 100%;
      height: auto;
      transform: none !important;
    }
  }

  .comunidad-wrapper {
    background: rgba(10, 10, 15, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 4rem;
  }

  .comunidad-header-section {
    padding: 6rem 2rem 2rem 2rem;
    background: transparent;
  }

  .comunidad-header-container {
    max-width: 1400px;
    margin: 0 auto;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 2rem;
  }

  .comunidad-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    color: #fff;
    margin: 0;
    letter-spacing: -0.05em;
    line-height: 1.1;
  }

  .comunidad-subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0.75rem 0 0 0;
    font-weight: 400;
  }

  .comunidad-contribute-inline {
    margin-top: 2rem;
  }

  .contribute-card-inline {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 2.5rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
    position: relative;
    overflow: hidden;
  }

  .contribute-card-inline::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 0%,
      transparent 40%,
      rgba(255, 255, 255, 0.03) 45%,
      rgba(255, 255, 255, 0.08) 50%,
      rgba(255, 255, 255, 0.03) 55%,
      transparent 60%,
      transparent 100%
    );
    animation: shimmer 4s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }

  @keyframes shimmer {
    0% { left: -100%; }
    50% { left: 150%; }
    100% { left: 150%; }
  }

  .contribute-card-content {
    flex: 1;
    min-width: 300px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contribute-card-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: #fff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .contribute-card-text {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  .contribute-card-warning {
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    border-left: 2px solid rgba(255, 255, 255, 0.15);
    padding-left: 0.75rem;
  }

  .contribute-card-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-card {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.4rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-card-discord {
    background: rgba(88, 101, 242, 0.12);
    color: #7289da;
    border: 1px solid rgba(88, 101, 242, 0.3);
  }

  .btn-card-discord:hover {
    background: #5865f2;
    color: #fff;
    border-color: #5865f2;
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(88, 101, 242, 0.3);
  }

  .btn-card-matrix {
    background: rgba(13, 189, 139, 0.1);
    color: #0dbd8b;
    border: 1px solid rgba(13, 189, 139, 0.25);
  }

  .btn-card-matrix:hover {
    background: #0dbd8b;
    color: #fff;
    border-color: #0dbd8b;
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(13, 189, 139, 0.3);
  }

  .btn-card-github {
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn-card-github:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.05);
  }

  .archived-section {
    padding: 6rem 2rem;
    background: rgba(10, 10, 15, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .archived-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .archived-header {
    text-align: left;
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1.5rem;
  }

  .archived-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    margin: 0;
    letter-spacing: -0.04em;
  }

  .archived-subtitle {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0.5rem 0 0 0;
    font-weight: 400;
  }

  .archived-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .archived-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    text-decoration: none;
    transition: background-color 0.2s, border-color 0.2s, transform 0.2s;
  }

  .archived-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px);
  }

  .archived-card-icon img {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: contain;
  }

  .archived-card-content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .archived-card-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
  }

  .archived-card-desc {
    font-size: 0.95rem;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }
</style>

<style is:global>
  .showcase-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 90px;
    height: 90px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 50%;
    pointer-events: none;
    z-index: 99999;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0);
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .showcase-cursor.active {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  @media (max-width: 1024px), (orientation: portrait) {
    .showcase-cursor {
      display: none !important;
    }
  }
</style>

<script is:inline>
  function initShowcaseStrip() {
    const strip = document.getElementById('showcase-strip');
    if (!strip) return;
    if (strip.dataset.init) return;
    strip.dataset.init = '1';

    const track = strip.querySelector('.showcase-track');
    const sections = track.querySelectorAll('.saas-showcase');
    const count = sections.length;
    if (count < 2) return;

    let currentIndex = 0;
    let isTransitioning = false;
    let autoTimer = null;
    let progressStartTime = 0;
    let progressRafId = null;
    const AUTO_DELAY = 6000;

    // Helper to check if screen is mobile size or vertical orientation
    function isVerticalOrMobile() {
      return window.innerWidth <= 1024 || window.innerHeight > window.innerWidth;
    }

    // Set initial style/transform
    track.style.transform = 'translate3d(0px, 0px, 0px)';

    function scrollToShowcase(index) {
      if (isVerticalOrMobile()) return;
      if (index < 0 || index >= count || isTransitioning) return;

      currentIndex = index;
      isTransitioning = true;

      const tx = index * 100;
      track.style.transform = `translate3d(-${tx}vw, 0px, 0px)`;

      updateProgressBars();
      startAutoRotation();

      setTimeout(() => {
        isTransitioning = false;
      }, 800);
    }

    function updateProgressBars() {
      if (isVerticalOrMobile()) return;
      sections.forEach((sec, idx) => {
        const fill = sec.querySelector('.sec-progress-fill');
        if (fill) {
          fill.style.transition = 'none';
          fill.style.width = idx < currentIndex ? '100%' : '0%';
        }
      });

      if (progressRafId) cancelAnimationFrame(progressRafId);

      const currentFill = sections[currentIndex].querySelector('.sec-progress-fill');
      if (currentFill) {
        currentFill.offsetHeight; // trigger reflow
        progressStartTime = performance.now();

        function animateProgress(now) {
          const elapsed = now - progressStartTime;
          const progress = Math.min(elapsed / AUTO_DELAY, 1);
          currentFill.style.width = (progress * 100) + '%';

          if (progress < 1) {
            progressRafId = requestAnimationFrame(animateProgress);
          }
        }
        progressRafId = requestAnimationFrame(animateProgress);
      }
    }

    function startAutoRotation() {
      if (isVerticalOrMobile()) return;
      if (autoTimer) clearTimeout(autoTimer);

      autoTimer = setTimeout(() => {
        const next = currentIndex + 1;
        scrollToShowcase(next >= count ? 0 : next);
      }, AUTO_DELAY);
    }

    // Intercept vertical scroll on strip to scroll horizontally
    strip.addEventListener('wheel', (e) => {
      if (isVerticalOrMobile()) return;
      if (e.deltaY === 0) return;

      if (isTransitioning) {
        e.preventDefault();
        return;
      }

      if (e.deltaY > 0) {
        // Scroll down -> next section
        if (currentIndex < count - 1) {
          e.preventDefault();
          scrollToShowcase(currentIndex + 1);
        }
      } else {
        // Scroll up -> prev section
        if (currentIndex > 0) {
          e.preventDefault();
          scrollToShowcase(currentIndex - 1);
        }
      }
    }, { passive: false });

    // Touch support for swiping
    let touchStartX = 0;
    let touchStartY = 0;

    strip.addEventListener('touchstart', (e) => {
      if (isVerticalOrMobile()) return;
      touchStartX = e.changedTouches[0].clientX;
      touchStartY = e.changedTouches[0].clientY;
    }, { passive: true });

    strip.addEventListener('touchend', (e) => {
      if (isVerticalOrMobile()) return;
      if (isTransitioning) return;

      const touchEndX = e.changedTouches[0].clientX;
      const touchEndY = e.changedTouches[0].clientY;

      const diffX = touchEndX - touchStartX;
      const diffY = touchEndY - touchStartY;

      if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 50) {
        if (diffX < 0) {
          if (currentIndex < count - 1) {
            scrollToShowcase(currentIndex + 1);
          }
        } else {
          if (currentIndex > 0) {
            scrollToShowcase(currentIndex - 1);
          }
        }
      }
    }, { passive: true });

    // Dynamic lightweight custom cursor follower
    let cursor = document.querySelector('.showcase-cursor');
    if (!cursor) {
      cursor = document.createElement('div');
      cursor.className = 'showcase-cursor';
      cursor.textContent = 'CLICK';
      document.body.appendChild(cursor);
    }

    document.addEventListener('mousemove', (e) => {
      if (isVerticalOrMobile()) return;
      cursor.style.left = e.clientX + 'px';
      cursor.style.top = e.clientY + 'px';

      const target = (e.target && typeof e.target.closest === 'function') ? e.target.closest('.product-card') : null;
      if (target) {
        cursor.classList.add('active');
      } else {
        cursor.classList.remove('active');
      }
    });

    document.addEventListener('mouseleave', () => {
      cursor.classList.remove('active');
    });

    // Intersection observer to control progress bar animation
    const observer = new IntersectionObserver((entries) => {
      if (isVerticalOrMobile()) return;
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          updateProgressBars();
        } else {
          if (progressRafId) cancelAnimationFrame(progressRafId);
          const currentFill = sections[currentIndex].querySelector('.sec-progress-fill');
          if (currentFill) {
            currentFill.style.transition = 'none';
            currentFill.style.width = '0%';
          }
        }
      });
    }, { threshold: 0.2 });

    observer.observe(strip);

    // Auto-center observer: centers the showcase section in screen when 50% becomes visible
    const centerObserver = new IntersectionObserver((entries) => {
      if (isVerticalOrMobile()) return;
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const rect = strip.getBoundingClientRect();
          if (Math.abs(rect.top) > 20) {
            const lenis = window.lenis;
            if (lenis) {
              lenis.scrollTo(strip, { duration: 1.0 });
            } else {
              window.scrollTo({
                top: strip.offsetTop,
                behavior: 'smooth'
              });
            }
          }
        }
      });
    }, { threshold: 0.5 });

    centerObserver.observe(strip);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShowcaseStrip);
  } else {
    initShowcaseStrip();
  }
  document.addEventListener('astro:page-load', initShowcaseStrip);
</script>
